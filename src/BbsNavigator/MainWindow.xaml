<Window
    x:Class="BbsNavigator.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ad="https://github.com/blakepell/MosaicUIWpf"
    xmlns:converters="clr-namespace:BbsNavigator.Converters"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:models="clr-namespace:BbsNavigator.Models"
    xmlns:mosaic="http://schemas.apexgate.net/wpf/mosaic-ui"
    xmlns:views="clr-namespace:BbsNavigator.Views"
    Title="BBS Navigator"
    Width="1280"
    Height="820"
    MinWidth="900"
    MinHeight="600"
    mosaic:WindowChromeBehavior.CaptionHeight="0"
    mosaic:WindowChromeBehavior.CornerRadius="10"
    mosaic:WindowChromeBehavior.GlassFrameThickness="0"
    mosaic:WindowChromeBehavior.IsEnabled="True"
    mosaic:WindowChromeBehavior.ResizeBorderThickness="5"
    mosaic:WindowChromeBehavior.UseAeroCaptionButtons="True"
    Background="{DynamicResource {x:Static mosaic:MosaicTheme.WindowBackgroundBrush}}"
    Foreground="{DynamicResource {x:Static mosaic:MosaicTheme.WindowForegroundBrush}}"
    Loaded="MainWindow_OnLoaded"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True"
    WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition Height="28" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <mosaic:WindowTitleBar
            Grid.Row="0"
            IconSource="pack://application:,,,/BbsNavigator;component/Assets/app.png"
            ShowIcon="True"
            TitleAlignment="Center"
            TitleText="BBS Navigator">
            <mosaic:WindowTitleBar.RightContent>
                <Button
                    Width="48"
                    Click="ToggleTheme_OnClick"
                    Content="◐"
                    FontSize="17"
                    Style="{DynamicResource {x:Static mosaic:MosaicTheme.WindowTitleBarButtonStyle}}"
                    ToolTip="Toggle light and dark themes" />
            </mosaic:WindowTitleBar.RightContent>
        </mosaic:WindowTitleBar>

        <Menu
            Grid.Row="1"
            Margin="4,0,4,0"
            Background="{DynamicResource {x:Static mosaic:MosaicTheme.WindowBackgroundBrush}}">
            <MenuItem Header="_File">
                <MenuItem
                    Click="ConnectSelected_OnClick"
                    Header="_Connect"
                    InputGestureText="Enter" />
                <MenuItem Click="DisconnectSelected_OnClick" Header="_Disconnect" />
                <Separator />
                <MenuItem Click="SaveSettings_OnClick" Header="_Save Settings" />
                <MenuItem Click="BackupSettings_OnClick" Header="_Backup Settings" />
                <Separator />
                <MenuItem Click="Exit_OnClick" Header="E_xit" />
            </MenuItem>
            <MenuItem Header="_Transfer">
                <MenuItem Click="DownloadFile_OnClick" Header="_Download Files…" />
                <MenuItem Click="UploadFile_OnClick" Header="_Upload Files…" />
                <Separator />
                <MenuItem Click="ToggleCapture_OnClick" Header="Toggle Session _Capture" />
                <MenuItem Click="OpenDownloadFolder_OnClick" Header="_Open Download Folder" />
            </MenuItem>
            <MenuItem Header="_Directory">
                <MenuItem
                    Click="AddBbs_OnClick"
                    Header="_Add BBS…"
                    InputGestureText="Ctrl+N" />
                <MenuItem Click="ImportBbsList_OnClick" Header="_Import BBS List File…" />
                <MenuItem Click="ImportBigList_OnClick" Header="Import _Big List" />
                <Separator />
                <MenuItem Click="EditBbs_OnClick" Header="_Edit BBS…" />
                <MenuItem Click="RemoveBbs_OnClick" Header="_Remove BBS" />
            </MenuItem>
            <MenuItem Header="_Setup">
                <MenuItem Click="Options_OnClick" Header="_Options…" />
                <MenuItem Header="_Theme">
                    <MenuItem
                        x:Name="LightThemeMenuItem"
                        Click="LightTheme_OnClick"
                        Header="_Light"
                        IsCheckable="True" />
                    <MenuItem
                        x:Name="DarkThemeMenuItem"
                        Click="DarkTheme_OnClick"
                        Header="_Dark"
                        IsCheckable="True" />
                    <MenuItem
                        x:Name="BlueThemeMenuItem"
                        Click="BlueTheme_OnClick"
                        Header="_Blue"
                        IsCheckable="True" />
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem
                    Click="UserGuide_OnClick"
                    Header="_User Guide"
                    InputGestureText="F1" />
                <Separator />
                <MenuItem Click="About_OnClick" Header="_About BBS Navigator" />
            </MenuItem>
        </Menu>

        <Border
            Grid.Row="2"
            Margin="4,0,4,4"
            BorderBrush="{DynamicResource {x:Static mosaic:MosaicTheme.ControlBorderBrush}}"
            BorderThickness="1,0,1,1">
            <ad:DockingManager x:Name="DockingManager" DocumentClosed="DockingManager_OnDocumentClosed">
                <ad:DockingManager.Theme>
                    <ad:MosaicTheme />
                </ad:DockingManager.Theme>
                <ad:LayoutRoot>
                    <ad:LayoutPanel Orientation="Horizontal">
                        <ad:LayoutAnchorablePane DockMinWidth="230" DockWidth="315">
                            <ad:LayoutAnchorable
                                Title="BBS Directory"
                                CanAutoHide="True"
                                CanClose="False"
                                CanHide="False"
                                ContentId="bbs-directory">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Border
                                        Padding="2"
                                        Background="{DynamicResource {x:Static mosaic:MosaicTheme.ControlBackgroundBrush}}"
                                        BorderBrush="{DynamicResource {x:Static mosaic:MosaicTheme.ControlBorderBrush}}"
                                        BorderThickness="0,0,0,1">
                                        <DockPanel>
                                            <ToolBar>
                                                <Button Margin="2,0,0,0" Click="AddBbs_OnClick">
                                                    <mosaic:SimpleStackPanel Orientation="Horizontal">
                                                        <Image
                                                            Width="18"
                                                            Height="18"
                                                            Source="pack://application:,,,/BbsNavigator;component/Assets/add-48.png" />
                                                        <TextBlock Margin="4,0,0,0" Text="Add" />
                                                    </mosaic:SimpleStackPanel>
                                                </Button>

                                                <Button Margin="2,0,0,0" Click="EditBbs_OnClick">
                                                    <mosaic:SimpleStackPanel Orientation="Horizontal">
                                                        <Image
                                                            Width="18"
                                                            Height="18"
                                                            Source="pack://application:,,,/BbsNavigator;component/Assets/edit-property-48.png" />
                                                        <TextBlock Margin="4,0,0,0" Text="Edit" />
                                                    </mosaic:SimpleStackPanel>
                                                </Button>

                                                <Button Margin="2,0,0,0" Click="RemoveBbs_OnClick">
                                                    <mosaic:SimpleStackPanel Orientation="Horizontal">
                                                        <Image
                                                            Width="18"
                                                            Height="18"
                                                            Source="pack://application:,,,/BbsNavigator;component/Assets/minus-48.png" />
                                                        <TextBlock Margin="4,0,0,0" Text="Remove" />
                                                    </mosaic:SimpleStackPanel>
                                                </Button>

                                                <Button
                                                    x:Name="SortBbsButton"
                                                    Margin="2,0,0,0"
                                                    Click="SortBbs_OnClick">
                                                    <mosaic:SimpleStackPanel Orientation="Horizontal">
                                                        <Image
                                                            Width="18"
                                                            Height="18"
                                                            Source="pack://application:,,,/BbsNavigator;component/Assets/sort-48.png" />
                                                        <TextBlock Margin="4,0,0,0" Text="Sort" />
                                                    </mosaic:SimpleStackPanel>
                                                </Button>
                                            </ToolBar>
                                        </DockPanel>
                                    </Border>

                                    <mosaic:SearchBox
                                        Grid.Row="1"
                                        Margin="8"
                                        Watermark="Search saved systems…">
                                        <i:Interaction.Behaviors>
                                            <mosaic:ItemsControlFilterBehavior TargetItemsControl="{Binding ElementName=BbsTree}" />
                                        </i:Interaction.Behaviors>
                                    </mosaic:SearchBox>

                                    <TreeView
                                        x:Name="BbsTree"
                                        Grid.Row="2"
                                        BorderThickness="0"
                                        ItemsSource="{Binding BbsProfiles}"
                                        MouseDoubleClick="BbsTree_OnMouseDoubleClick"
                                        ScrollViewer.CanContentScroll="True"
                                        VirtualizingPanel.IsVirtualizing="True"
                                        VirtualizingPanel.VirtualizationMode="Recycling">
                                        <TreeView.ItemTemplate>
                                            <DataTemplate DataType="{x:Type models:BbsProfile}">
                                                <Border
                                                    Padding="8,7"
                                                    Background="Transparent"
                                                    CornerRadius="3">
                                                    <Border.ContextMenu>
                                                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                            <MenuItem Click="EditBbsDetails_OnClick" Header="_Edit BBS Details…" />
                                                            <Separator />
                                                            <MenuItem Click="ToggleFavorite_OnClick" Header="_Toggle Favorite" />
                                                            <Separator />
                                                            <MenuItem Click="EditCredentials_OnClick" Header="_Edit Credentials…" />
                                                            <MenuItem
                                                                Click="ViewCredentials_OnClick"
                                                                Header="_View Credentials…"
                                                                IsEnabled="{Binding EncryptedCredentials, Converter={x:Static converters:HasCredentialsConverter.Instance}}" />
                                                        </ContextMenu>
                                                    </Border.ContextMenu>
                                                    <Grid ToolTip="{Binding LastConnected, Converter={x:Static converters:LastConnectedConverter.Instance}}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="28" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <Image
                                                            x:Name="ConnectionIcon"
                                                            Width="18"
                                                            Height="18"
                                                            Margin="0,0,8,0"
                                                            VerticalAlignment="Center"
                                                            Source="Assets/terminal-gray-48.png" />
                                                        <mosaic:FavoriteCheckBox
                                                            Grid.Row="1"
                                                            Width="18"
                                                            Height="18"
                                                            Margin="0,2,8,0"
                                                            HorizontalAlignment="Left"
                                                            IsChecked="{Binding Favorite, Mode=TwoWay}"
                                                            Symbol="&#x2605;"
                                                            SymbolSize="14"
                                                            ToolTip="Favorite" />
                                                        <TextBlock
                                                            Grid.Column="1"
                                                            FontSize="12"
                                                            FontWeight="SemiBold"
                                                            Text="{Binding Name}"
                                                            TextTrimming="CharacterEllipsis" />
                                                        <mosaic:Shield
                                                            Grid.Row="1"
                                                            Grid.Column="1"
                                                            Margin="0,2,0,0"
                                                            Label="{Binding Host}"
                                                            ValueBackgroundBrush="Green"
                                                            ValueForegroundBrush="White"
                                                            Value="{Binding Port}" />
                                                    </Grid>
                                                </Border>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding ConnectionState}" Value="{x:Static models:BbsConnectionState.Connected}">
                                                        <Setter TargetName="ConnectionIcon" Property="Source" Value="Assets/terminal-48.png" />
                                                    </DataTrigger>
                                                    <!--  Placeholder until a dedicated connecting icon is available.  -->
                                                    <DataTrigger Binding="{Binding ConnectionState}" Value="{x:Static models:BbsConnectionState.Connecting}">
                                                        <Setter TargetName="ConnectionIcon" Property="Source" Value="Assets/terminal-gray-48.png" />
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </TreeView.ItemTemplate>
                                    </TreeView>

                                    <TextBlock
                                        Grid.Row="3"
                                        Margin="10,7"
                                        FontSize="11"
                                        Opacity="0.7"
                                        Text="Double-click a system to connect" />
                                </Grid>
                            </ad:LayoutAnchorable>
                        </ad:LayoutAnchorablePane>

                        <ad:LayoutDocumentPane>
                            <ad:LayoutDocument
                                x:Name="InitialUserGuideDocument"
                                Title="User Guide"
                                CanClose="True"
                                ContentId="user-guide"
                                IsSelected="True">
                                <views:UserGuideView />
                            </ad:LayoutDocument>
                        </ad:LayoutDocumentPane>
                    </ad:LayoutPanel>
                </ad:LayoutRoot>
            </ad:DockingManager>
        </Border>
    </Grid>
</Window>
