<Window
    x:Class="BbsNavigator.Views.CredentialPassphraseWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mosaic="http://schemas.apexgate.net/wpf/mosaic-ui"
    Title="Credential Encryption"
    Width="560"
    Height="350"
    mosaic:WindowChromeBehavior.CaptionHeight="0"
    mosaic:WindowChromeBehavior.CornerRadius="10"
    mosaic:WindowChromeBehavior.GlassFrameThickness="0"
    mosaic:WindowChromeBehavior.IsEnabled="True"
    mosaic:WindowChromeBehavior.ResizeBorderThickness="5"
    mosaic:WindowChromeBehavior.RoundBorder="True"
    mosaic:WindowChromeBehavior.UseAeroCaptionButtons="True"
    Background="{DynamicResource {x:Static mosaic:MosaicTheme.WindowBackgroundBrush}}"
    Foreground="{DynamicResource {x:Static mosaic:MosaicTheme.WindowForegroundBrush}}"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="35" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <mosaic:WindowTitleBar
            Grid.Row="0"
            IconSource="pack://application:,,,/BbsNavigator;component/Assets/app.png"
            ShowMaxRestoreButton="False"
            ShowMinimizeButton="False" />

        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="145" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock
                x:Name="HeadingTextBlock"
                Grid.ColumnSpan="2"
                Margin="0,0,0,8"
                FontSize="20"
                FontWeight="SemiBold" />
            <TextBlock
                x:Name="ExplanationTextBlock"
                Grid.Row="1"
                Grid.ColumnSpan="2"
                Margin="0,0,0,12"
                Opacity="0.75"
                TextWrapping="Wrap" />

            <TextBlock Grid.Row="2" Margin="0,6" VerticalAlignment="Center" Text="Passphrase" />
            <PasswordBox x:Name="PassphraseBox" Grid.Row="2" Grid.Column="1" Margin="0,4" />

            <TextBlock x:Name="ConfirmLabel" Grid.Row="3" Margin="0,6" VerticalAlignment="Center" Text="Confirm passphrase" />
            <PasswordBox x:Name="ConfirmPassphraseBox" Grid.Row="3" Grid.Column="1" Margin="0,4" />

            <TextBlock
                Grid.Row="4"
                Grid.ColumnSpan="2"
                Margin="0,10,0,0"
                Opacity="0.75"
                Text="The passphrase itself is not stored. If it is forgotten, saved credentials cannot be recovered."
                TextWrapping="Wrap" />

            <StackPanel Grid.Row="5" Grid.ColumnSpan="2" HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Width="90" Margin="0,0,8,0" Content="Cancel" IsCancel="True" />
                <mosaic:AccentButton
                    x:Name="AcceptButton"
                    Width="110"
                    AccentButtonType="ThemeAccent"
                    Click="Accept_OnClick"
                    IsDefault="True" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
