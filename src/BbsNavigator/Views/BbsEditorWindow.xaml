<Window
    x:Class="BbsNavigator.Views.BbsEditorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:BbsNavigator.Converters"
    xmlns:mosaic="http://schemas.apexgate.net/wpf/mosaic-ui"
    Title="BBS Connection"
    Width="520"
    Height="460"
    mosaic:WindowChromeBehavior.CaptionHeight="0"
    mosaic:WindowChromeBehavior.CornerRadius="10"
    mosaic:WindowChromeBehavior.GlassFrameThickness="0"
    mosaic:WindowChromeBehavior.IsEnabled="True"
    mosaic:WindowChromeBehavior.ResizeBorderThickness="5"
    mosaic:WindowChromeBehavior.RoundBorder="True"
    mosaic:WindowChromeBehavior.UseAeroCaptionButtons="True"
    Background="{DynamicResource {x:Static mosaic:MosaicTheme.WindowBackgroundBrush}}"
    BorderThickness="1"
    Foreground="{DynamicResource {x:Static mosaic:MosaicTheme.WindowForegroundBrush}}"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="35" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <mosaic:WindowTitleBar
            Grid.Row="0"
            IconSource="pack://application:,,,/BbsNavigator;component/Assets/app.png"
            ShowMaxRestoreButton="False"
            ShowMinimizeButton="False" />

        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="125" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock
                Grid.ColumnSpan="2"
                Margin="0,0,0,18"
                FontSize="20"
                FontWeight="SemiBold"
                Text="Connection profile" />
            <TextBlock
                Grid.Row="1"
                Margin="0,6"
                VerticalAlignment="Center"
                Text="Display name" />
            <TextBox
                x:Name="NameTextBox"
                Grid.Row="1"
                Grid.Column="1"
                Margin="0,4"
                Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock
                Grid.Row="2"
                Margin="0,6"
                VerticalAlignment="Center"
                Text="Host name" />
            <TextBox
                Grid.Row="2"
                Grid.Column="1"
                Margin="0,4"
                Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock
                Grid.Row="3"
                Margin="0,6"
                VerticalAlignment="Center"
                Text="Telnet port" />
            <mosaic:NumericTextBox
                Grid.Row="3"
                Grid.Column="1"
                Padding="4"
                Margin="0,4"
                DecimalPlaces="0"
                Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock
                Grid.Row="4"
                Margin="0,6"
                VerticalAlignment="Center"
                Text="Description" />
            <TextBox
                Grid.Row="4"
                Grid.Column="1"
                Margin="0,4"
                Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock
                Grid.Row="5"
                Margin="0,6"
                VerticalAlignment="Center"
                Text="Text encoding" />
            <ComboBox
                x:Name="EncodingComboBox"
                Grid.Row="5"
                Grid.Column="1"
                Margin="0,4"
                SelectedItem="{Binding TerminalEncoding}"
                ToolTip="CP437 renders classic DOS box-drawing and ANSI art; UTF-8 suits modern systems and MUDs.">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Converter={x:Static converters:EnumDescriptionConverter.Instance}}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <StackPanel
                Grid.Row="6"
                Grid.Column="1"
                Margin="0,8,0,0"
                VerticalAlignment="Top">
                <CheckBox Content="Reconnect automatically after a dropped connection" IsChecked="{Binding AutoReconnect}" />
                <CheckBox
                    Margin="0,4,0,0"
                    Content="Show typed characters locally"
                    IsChecked="{Binding LocalEcho}"
                    ToolTip="Enable this for MUDs and BBSs that do not echo keyboard input back to the terminal." />
                <CheckBox
                    Margin="0,4,0,0"
                    Content="Send DEL (0x7F) for Backspace"
                    IsChecked="{Binding BackspaceSendsDelete}"
                    ToolTip="Most classic BBSs expect Ctrl-H/BS (0x08). Enable this for systems that expect DEL (0x7F)." />
            </StackPanel>

            <StackPanel
                Grid.Row="7"
                Grid.ColumnSpan="2"
                Margin="0,4,0,0"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
                <Button
                    Width="90"
                    Margin="0,0,8,0"
                    IsCancel="True">
                    Cancel
                </Button>
                <mosaic:AccentButton
                    Width="90"
                    AccentButtonType="ThemeAccent"
                    Click="Save_OnClick"
                    Content="Save"
                    IsDefault="True" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
