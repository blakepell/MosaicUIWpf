<UserControl
    x:Class="BbsNavigator.Views.UserGuideView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mosaic="http://schemas.apexgate.net/wpf/mosaic-ui"
    Background="{DynamicResource {x:Static mosaic:MosaicTheme.WindowBackgroundBrush}}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Padding="8,6"
            Background="{DynamicResource {x:Static mosaic:MosaicTheme.ControlBackgroundBrush}}"
            BorderBrush="{DynamicResource {x:Static mosaic:MosaicTheme.ControlBorderBrush}}"
            BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Button
                    MinWidth="70"
                    Click="Back_OnClick"
                    Content="← Back"
                    IsEnabled="{Binding CanGoBack, ElementName=Viewer}" />
                <Button
                    MinWidth="70"
                    Margin="6,0,0,0"
                    Click="Home_OnClick"
                    Content="Contents" />
            </StackPanel>
        </Border>

        <mosaic:MarkdownViewer
            x:Name="Viewer"
            Grid.Row="1"
            FontSize="{Binding UserGuideFontSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            Padding="24,16"
            LinkClicked="Viewer_OnLinkClicked"
            Source="/BbsNavigator;component/Docs/index.md" />
    </Grid>
</UserControl>
