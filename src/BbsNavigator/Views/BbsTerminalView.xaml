<UserControl
    x:Class="BbsNavigator.Views.BbsTerminalView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mosaic="http://schemas.apexgate.net/wpf/mosaic-ui"
    xmlns:vt52="clr-namespace:Mosaic.UI.Wpf.Controls.VT52Terminal;assembly=Mosaic.UI.Wpf"
    Background="{DynamicResource {x:Static mosaic:MosaicTheme.WindowBackgroundBrush}}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            x:Name="StatusBanner"
            Padding="10,7"
            Background="{DynamicResource {x:Static mosaic:MosaicTheme.ControlBackgroundBrush}}"
            BorderBrush="{DynamicResource {x:Static mosaic:MosaicTheme.ControlBorderBrush}}"
            BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <mosaic:Badge x:Name="StatusBadge" MinWidth="88" Text="Disconnected" />
                <TextBlock x:Name="StatusText" Grid.Column="1" Margin="12,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                <mosaic:ProgressRing x:Name="BusyRing" Grid.Column="2" Width="20" Height="20" Margin="4,0,12,0" IsActive="False" />
                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <mosaic:AccentButton x:Name="ReconnectButton" MinWidth="90" Margin="0,0,6,0" AccentButtonType="ThemeAccent" Click="Reconnect_OnClick" Content="Reconnect" />
                    <Button x:Name="DisconnectButton" MinWidth="90" Click="Disconnect_OnClick" Content="Disconnect" />
                </StackPanel>
            </Grid>
        </Border>

        <vt52:VT52Terminal
            x:Name="Terminal"
            Grid.Row="1"
            AutoConnect="False"
            Background="#FF080B10"
            DisconnectOnUnload="False"
            FontFamily="Cascadia Mono, Consolas"
            Foreground="#FFD8DEE9"
            HorizontalScrollBarVisibility="Hidden"
            LocalEcho="{Binding LocalEcho}"
            SendKeyboardInputToConnection="True"
            ShowLineNumbers="False"
            VerticalScrollBarVisibility="Hidden" />
    </Grid>
</UserControl>
