<Window
    x:Class="BbsNavigator.Views.CredentialEditorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mosaic="http://schemas.apexgate.net/wpf/mosaic-ui"
    Title="Edit BBS Credentials"
    Width="560"
    Height="370"
    mosaic:WindowChromeBehavior.CaptionHeight="0"
    mosaic:WindowChromeBehavior.CornerRadius="10"
    mosaic:WindowChromeBehavior.GlassFrameThickness="0"
    mosaic:WindowChromeBehavior.IsEnabled="True"
    mosaic:WindowChromeBehavior.ResizeBorderThickness="5"
    mosaic:WindowChromeBehavior.RoundBorder="True"
    mosaic:WindowChromeBehavior.UseAeroCaptionButtons="True"
    Background="{DynamicResource {x:Static mosaic:MosaicTheme.WindowBackgroundBrush}}"
    Foreground="{DynamicResource {x:Static mosaic:MosaicTheme.WindowForegroundBrush}}"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="35" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <mosaic:WindowTitleBar
            Grid.Row="0"
            IconSource="/Assets/app.png"
            ShowMaxRestoreButton="False"
            ShowMinimizeButton="False" />

        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="145" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock
                x:Name="HeadingTextBlock"
                Grid.ColumnSpan="2"
                Margin="0,0,0,8"
                FontSize="20"
                FontWeight="SemiBold" />
            <TextBlock
                x:Name="ExistingCredentialsTextBlock"
                Grid.Row="1"
                Grid.ColumnSpan="2"
                Margin="0,0,0,12"
                Opacity="0.75"
                Text="Saving replaces the existing encrypted credentials. Use View Credentials first if you need the current values."
                TextWrapping="Wrap" />

            <TextBlock Grid.Row="2" Margin="0,6" VerticalAlignment="Center" Text="Username" />
            <TextBox x:Name="UserNameTextBox" Grid.Row="2" Grid.Column="1" Margin="0,4" />

            <TextBlock Grid.Row="3" Margin="0,6" VerticalAlignment="Center" Text="BBS password" />
            <PasswordBox x:Name="BbsPasswordBox" Grid.Row="3" Grid.Column="1" Margin="0,4" />

            <TextBlock
                Grid.Row="4"
                Grid.ColumnSpan="2"
                Margin="0,10,0,0"
                Opacity="0.75"
                Text="These credentials will be protected with the app-wide encryption passphrase."
                TextWrapping="Wrap" />

            <Grid Grid.Row="5" Grid.ColumnSpan="2" Margin="0,12,0,0">
                <Button
                    x:Name="RemoveButton"
                    Width="145"
                    HorizontalAlignment="Left"
                    Click="Remove_OnClick"
                    Content="Remove Credentials" />
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button Width="90" Margin="0,0,8,0" Content="Cancel" IsCancel="True" />
                    <mosaic:AccentButton
                        Width="90"
                        AccentButtonType="ThemeAccent"
                        Click="Save_OnClick"
                        Content="Save"
                        IsDefault="True" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
