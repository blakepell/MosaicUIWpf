<Window
    x:Class="BbsNavigator.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mosaic="http://schemas.apexgate.net/wpf/mosaic-ui"
    Title="BBS Navigator Options"
    Width="620"
    Height="500"
    mosaic:WindowChromeBehavior.CaptionHeight="0"
    mosaic:WindowChromeBehavior.CornerRadius="10"
    mosaic:WindowChromeBehavior.GlassFrameThickness="0"
    mosaic:WindowChromeBehavior.IsEnabled="True"
    mosaic:WindowChromeBehavior.ResizeBorderThickness="5"
    mosaic:WindowChromeBehavior.RoundBorder="True"
    mosaic:WindowChromeBehavior.UseAeroCaptionButtons="True"
    Background="{DynamicResource {x:Static mosaic:MosaicTheme.WindowBackgroundBrush}}"
    BorderBrush="#2F43A8"
    BorderThickness="1"
    Foreground="{DynamicResource {x:Static mosaic:MosaicTheme.WindowForegroundBrush}}"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="35" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <mosaic:WindowTitleBar
            Grid.Row="0"
            IconSource="pack://application:,,,/BbsNavigator;component/Assets/app.png"
            ShowMaxRestoreButton="False"
            ShowMinimizeButton="False" />

        <Grid Grid.Row="1" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock
                Margin="0,0,0,0"
                FontSize="20"
                FontWeight="SemiBold"
                Text="Application options" />
            <ScrollViewer
                Grid.Row="1"
                MaxHeight="350"
                Margin="0,6,0,0">
                <mosaic:PropertyGrid Object="{Binding}" />
            </ScrollViewer>
            <Button
                Grid.Row="2"
                Width="90"
                Height="25"
                Margin="0,12,0,0"
                HorizontalAlignment="Right"
                IsCancel="True"
                IsDefault="True">
                Close
            </Button>
        </Grid>
    </Grid>
</Window>
