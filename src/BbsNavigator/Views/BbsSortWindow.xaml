<Window
    x:Class="BbsNavigator.Views.BbsSortWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:BbsNavigator.Converters"
    xmlns:mosaic="http://schemas.apexgate.net/wpf/mosaic-ui"
    Title="Sort BBS Directory"
    Width="620"
    Height="440"
    mosaic:WindowChromeBehavior.CaptionHeight="0"
    mosaic:WindowChromeBehavior.CornerRadius="10"
    mosaic:WindowChromeBehavior.GlassFrameThickness="0"
    mosaic:WindowChromeBehavior.IsEnabled="True"
    mosaic:WindowChromeBehavior.ResizeBorderThickness="5"
    mosaic:WindowChromeBehavior.RoundBorder="True"
    mosaic:WindowChromeBehavior.UseAeroCaptionButtons="True"
    Background="{DynamicResource {x:Static mosaic:MosaicTheme.WindowBackgroundBrush}}"
    Foreground="{DynamicResource {x:Static mosaic:MosaicTheme.WindowForegroundBrush}}"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="35" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <mosaic:WindowTitleBar
            Grid.Row="0"
            IconSource="/Assets/app.png"
            ShowMaxRestoreButton="False"
            ShowMinimizeButton="False" />

        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock FontSize="20" FontWeight="SemiBold" Text="Sort BBS Directory" />
            <TextBlock
                Grid.Row="1"
                Margin="0,6,0,14"
                Opacity="0.75"
                Text="Add sort levels in priority order. Rules are applied from top to bottom."
                TextWrapping="Wrap" />

            <Grid Grid.Row="2" Margin="8,0,44,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="140" />
                </Grid.ColumnDefinitions>
                <TextBlock FontWeight="SemiBold" Text="Sort By" />
                <TextBlock Grid.Column="1" Margin="8,0,0,0" FontWeight="SemiBold" Text="Direction" />
            </Grid>

            <Border
                Grid.Row="3"
                Padding="8"
                Background="{DynamicResource {x:Static mosaic:MosaicTheme.ControlBackgroundBrush}}"
                BorderBrush="{DynamicResource {x:Static mosaic:MosaicTheme.ControlBorderBrush}}"
                BorderThickness="1"
                CornerRadius="4">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Criteria}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <ComboBox
                                        ItemsSource="{Binding DataContext.AvailableFields, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                        SelectedItem="{Binding Field, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Converter={x:Static converters:EnumDescriptionConverter.Instance}}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>

                                    <ComboBox
                                        Grid.Column="1"
                                        Margin="8,0,0,0"
                                        ItemsSource="{Binding DataContext.AvailableDirections, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                        SelectedItem="{Binding Direction, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Converter={x:Static converters:EnumDescriptionConverter.Instance}}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>

                                    <Button
                                        Grid.Column="2"
                                        Width="32"
                                        Margin="8,0,0,0"
                                        Click="RemoveCriterion_OnClick"
                                        Content="−"
                                        FontSize="16"
                                        ToolTip="Remove sort level" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <Grid Grid.Row="4" Margin="0,12,0,0">
                <Button
                    x:Name="AddCriterionButton"
                    Width="110"
                    HorizontalAlignment="Left"
                    Click="AddCriterion_OnClick"
                    Content="Add Sort Level" />
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button Width="90" Margin="0,0,8,0" Content="Cancel" IsCancel="True" />
                    <mosaic:AccentButton
                        Width="90"
                        AccentButtonType="ThemeAccent"
                        Click="Apply_OnClick"
                        Content="Sort"
                        IsDefault="True" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
