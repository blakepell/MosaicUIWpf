<UserControl
    x:Class="MosaicWpfDemo.Views.Examples.BlockCaretBehaviorExample"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Mosaic.UI.Wpf.Behaviors;assembly=Mosaic.UI.Wpf"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Default block (color follows Foreground)  -->
        <StackPanel Grid.Row="0">
            <TextBlock
                Margin="0,0,0,6"
                FontWeight="SemiBold"
                Text="Default — block color inherits Foreground" />
            <TextBox
                Width="340"
                HorizontalAlignment="Left"
                FontFamily="Consolas"
                FontSize="14"
                Text="Click here and move the cursor">
                <i:Interaction.Behaviors>
                    <behaviors:BlockCaretBehavior />
                </i:Interaction.Behaviors>
            </TextBox>
        </StackPanel>

        <!--  Terminal-style: green on black  -->
        <StackPanel Grid.Row="2">
            <TextBlock
                Margin="0,0,0,6"
                FontWeight="SemiBold"
                Text="Terminal style — green block on black background" />
            <TextBox
                Width="340"
                HorizontalAlignment="Left"
                Background="#0D0D0D"
                BorderBrush="#333"
                CaretBrush="Transparent"
                FontFamily="Consolas"
                FontSize="14"
                Foreground="#33FF33"
                Text="GREEN BLOCK CARET">
                <i:Interaction.Behaviors>
                    <behaviors:BlockCaretBehavior BlockBrush="#33FF33" CharacterBrush="#0D0D0D" />
                </i:Interaction.Behaviors>
            </TextBox>
        </StackPanel>

        <!--  Solid block (character hidden)  -->
        <StackPanel Grid.Row="4">
            <TextBlock
                Margin="0,0,0,6"
                FontWeight="SemiBold"
                Text="ShowCharacterUnderCaret=False — solid opaque block" />
            <TextBox
                Width="340"
                HorizontalAlignment="Left"
                FontFamily="Consolas"
                FontSize="14"
                Text="Solid block hides the character">
                <i:Interaction.Behaviors>
                    <behaviors:BlockCaretBehavior ShowCharacterUnderCaret="False" />
                </i:Interaction.Behaviors>
            </TextBox>
        </StackPanel>

        <!--  Multi-line  -->
        <StackPanel Grid.Row="6">
            <TextBlock
                Margin="0,0,0,6"
                FontWeight="SemiBold"
                Text="Multi-line TextBox — block tracks across lines and scroll" />
            <TextBox
                Width="340"
                Height="80"
                HorizontalAlignment="Left"
                AcceptsReturn="True"
                FontFamily="Consolas"
                FontSize="13"
                Text="Line one&#x0a;Line two&#x0a;Line three"
                TextWrapping="NoWrap"
                VerticalScrollBarVisibility="Auto">
                <i:Interaction.Behaviors>
                    <behaviors:BlockCaretBehavior />
                </i:Interaction.Behaviors>
            </TextBox>
        </StackPanel>
    </Grid>
</UserControl>
