<UserControl
    x:Class="MosaicWpfDemo.Views.Examples.ModalDialogExample"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Mosaic.UI.Wpf.Controls;assembly=Mosaic.UI.Wpf"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MosaicWpfDemo.Views.Examples"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:themes="clr-namespace:Mosaic.UI.Wpf.Themes;assembly=Mosaic.UI.Wpf"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <StackPanel Margin="10">
        <TextBlock
            Margin="0,0,0,4"
            FontWeight="SemiBold"
            Text="ModalDialog displays content centered in the adorner layer while blurring and dimming everything beneath it." />
        <TextBlock
            Margin="0,0,0,12"
            Foreground="{DynamicResource {x:Static themes:MosaicTheme.ControlTextSecondaryForegroundBrush}}"
            Text="Await ShowAsync(host) to get the bool? result passed to Close. The dialog itself stays sharp because the blur is applied to the adorned element, not the adorner layer."
            TextWrapping="Wrap" />

        <WrapPanel>
            <controls:AccentButton
                Width="160"
                Margin="0,0,8,8"
                Click="OnSimpleClick"
                Content="Simple Dialog" />
            <controls:AccentButton
                Width="160"
                Margin="0,0,8,8"
                Click="OnConfirmationClick"
                Content="Confirmation" />
            <controls:AccentButton
                Width="160"
                Margin="0,0,8,8"
                Click="OnFormClick"
                Content="Form Dialog" />
            <controls:AccentButton
                Width="160"
                Margin="0,0,8,8"
                Click="OnNoBlurClick"
                Content="No Blur (Dim Only)" />
        </WrapPanel>

        <controls:LabeledSeparator Margin="0,8" Content="Options" />

        <WrapPanel>
            <CheckBox
                x:Name="BackdropCloseCheckBox"
                Margin="0,0,18,8"
                Content="Close on backdrop click"
                IsChecked="True" />
            <CheckBox
                x:Name="EscapeCloseCheckBox"
                Margin="0,0,18,8"
                Content="Close on Escape"
                IsChecked="True" />
            <CheckBox
                x:Name="CloseButtonCheckBox"
                Margin="0,0,18,8"
                Content="Show close button"
                IsChecked="True" />
        </WrapPanel>

        <controls:InfoCard
            Title="Last Result"
            Margin="0,8,0,0"
            AccentBrush="{DynamicResource {x:Static themes:MosaicTheme.AccentBrush}}">
            <TextBlock
                x:Name="ResultTextBlock"
                Margin="12"
                Text="No dialog has been shown yet." />
        </controls:InfoCard>
    </StackPanel>
</UserControl>
