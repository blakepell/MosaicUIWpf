<UserControl
    x:Class="MosaicWpfDemo.Views.Examples.FontZoomExample"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Mosaic.UI.Wpf.Behaviors;assembly=Mosaic.UI.Wpf"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:MosaicWpfDemo.Views.Examples"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:themes="clr-namespace:Mosaic.UI.Wpf.Themes;assembly=Mosaic.UI.Wpf"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock
                Margin="0,0,0,8"
                FontSize="18"
                FontWeight="SemiBold"
                Text="Font Zoom" />

            <TextBlock
                Margin="0,0,0,4"
                TextWrapping="Wrap"
                Text="Click inside the text box, hold Ctrl, then scroll the mouse wheel to zoom the font size up or down." />

            <TextBlock
                Foreground="{DynamicResource {x:Static themes:MosaicTheme.ControlDisabledForegroundBrush}}"
                TextWrapping="Wrap"
                Text="This demo uses FrameworkElementZoomFontSizeOnMouseWheelBehavior. The text box below starts at 14pt, and the behavior keeps the size between 4pt and 96pt." />
        </StackPanel>

        <Border
            Grid.Row="2"
            Padding="12"
            Background="{DynamicResource {x:Static themes:MosaicTheme.ControlBackgroundBrush}}"
            BorderBrush="{DynamicResource {x:Static themes:MosaicTheme.ControlBorderBrush}}"
            BorderThickness="1"
            CornerRadius="4">
            <StackPanel>
                <TextBlock
                    Margin="0,0,0,8"
                    FontWeight="SemiBold"
                    Text="Try it here" />

                <TextBox
                    Padding="8"
                    FontSize="14"
                    Text="Hold Ctrl and use the mouse wheel over this text box to zoom the font size.">
                    <i:Interaction.Behaviors>
                        <behaviors:FrameworkElementZoomFontSizeOnMouseWheelBehavior />
                    </i:Interaction.Behaviors>
                </TextBox>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
