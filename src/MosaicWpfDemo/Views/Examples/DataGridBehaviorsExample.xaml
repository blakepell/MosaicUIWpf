<UserControl
    x:Class="MosaicWpfDemo.Views.Examples.DataGridBehaviorsExample"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Mosaic.UI.Wpf.Behaviors;assembly=Mosaic.UI.Wpf"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mosaic="clr-namespace:Mosaic.UI.Wpf.Controls;assembly=Mosaic.UI.Wpf"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Margin="0,0,0,8" FontSize="18" FontWeight="SemiBold" Text="DataGrid Behaviors" />
            <TextBlock Text="Search filters the grid, and the last column fills the remaining space." TextWrapping="Wrap" />

            <mosaic:SearchBox
                x:Name="FilterBox"
                Width="280"
                Margin="0,12,0,0"
                Watermark="Filter rows...">
                <i:Interaction.Behaviors>
                    <behaviors:DataGridFilterBehavior TargetDataGrid="{Binding ElementName=SampleGrid}" />
                </i:Interaction.Behaviors>
            </mosaic:SearchBox>
        </StackPanel>

        <Border
            Grid.Row="2"
            Padding="12"
            Background="{DynamicResource {x:Static SystemColors.ControlLightLightBrushKey}}"
            BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
            BorderThickness="1"
            CornerRadius="4">
            <DataGrid
                x:Name="SampleGrid"
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                IsReadOnly="True"
                ItemsSource="{Binding Rows}">
                <i:Interaction.Behaviors>
                    <behaviors:DataGridLastColumnFillBehavior />
                </i:Interaction.Behaviors>

                <DataGrid.Columns>
                    <DataGridTextColumn Width="180" Binding="{Binding Name}" Header="Name" />
                    <DataGridTextColumn Width="220" Binding="{Binding Category}" Header="Category" />
                    <DataGridTextColumn Binding="{Binding Status}" Header="Status" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
