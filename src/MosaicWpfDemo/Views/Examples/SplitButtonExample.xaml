<UserControl
    x:Class="MosaicWpfDemo.Views.Examples.SplitButtonExample"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mosaic="clr-namespace:Mosaic.UI.Wpf.Controls;assembly=Mosaic.UI.Wpf"
    xmlns:themes="http://schemas.apexgate.net/wpf/mosaic-ui"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <StackPanel Margin="10" Orientation="Vertical">
        <TextBlock Margin="0,0,0,6" Text="True split behavior" />
        <TextBlock Margin="0,0,0,8">
            <Run Foreground="{DynamicResource {x:Static themes:MosaicTheme.ControlTextForegroundBrush}}" Text="Status =" />
            <Run Foreground="CornflowerBlue" Text="{Binding Status}" />
        </TextBlock>

        <mosaic:SplitButton
            Width="150"
            HorizontalAlignment="Left"
            Click="SplitButton_OnClick"
            Command="{Binding PrimaryCommand}"
            Content="Save">
            <mosaic:SplitButton.ContextMenu>
                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                    <MenuItem Command="{Binding PrimaryCommand}" Header="Save" />
                    <MenuItem
                        Command="{Binding MenuCommand}"
                        CommandParameter="Save As"
                        Header="Save As" />
                    <Separator />
                    <MenuItem Click="MenuItem_OnClick" Header="Click menu item" />
                    <MenuItem Header="Disabled menu item" IsEnabled="False" />
                </ContextMenu>
            </mosaic:SplitButton.ContextMenu>
        </mosaic:SplitButton>

        <TextBlock Margin="0,12,0,6" Text="Primary command disabled; drop-down remains available" />
        <mosaic:SplitButton
            Width="190"
            HorizontalAlignment="Left"
            Command="{Binding DisabledPrimaryCommand}"
            Content="Disabled Primary">
            <mosaic:SplitButton.ContextMenu>
                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                    <MenuItem
                        Command="{Binding MenuCommand}"
                        CommandParameter="Available drop-down action"
                        Header="Available drop-down action" />
                    <MenuItem Header="Disabled menu item" IsEnabled="False" />
                </ContextMenu>
            </mosaic:SplitButton.ContextMenu>
        </mosaic:SplitButton>

        <TextBlock Margin="0,12,0,6" Text="Custom menu placement and width" />
        <mosaic:SplitButton
            Width="170"
            HorizontalAlignment="Left"
            Content="More Options"
            DropDownPlacement="Right"
            MatchDropDownWidth="False">
            <mosaic:SplitButton.ContextMenu>
                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                    <MenuItem
                        Command="{Binding MenuCommand}"
                        CommandParameter="Right-placed menu"
                        Header="Right-placed menu" />
                    <MenuItem Header="Another option" />
                </ContextMenu>
            </mosaic:SplitButton.ContextMenu>
        </mosaic:SplitButton>
    </StackPanel>
</UserControl>
