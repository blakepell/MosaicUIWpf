<UserControl
    x:Class="MosaicWpfDemo.Views.Examples.ItemsAutoScrollBehaviorExample"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Mosaic.UI.Wpf.Behaviors;assembly=Mosaic.UI.Wpf"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:themes="clr-namespace:Mosaic.UI.Wpf.Themes;assembly=Mosaic.UI.Wpf"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock
                Margin="0,0,0,8"
                FontSize="18"
                FontWeight="SemiBold"
                Text="Items Auto Scroll Behavior" />

            <TextBlock
                Margin="0,0,0,4"
                Text="Click the button to add items to the list. The behavior keeps the newest item in view automatically."
                TextWrapping="Wrap" />

            <TextBlock
                Foreground="{DynamicResource {x:Static themes:MosaicTheme.ControlDisabledForegroundBrush}}"
                Text="This demo uses ItemsControlAutoScrollBehavior on a ListBox with a fixed height so you can see it scroll as the list grows."
                TextWrapping="Wrap" />
        </StackPanel>

        <Border
            Grid.Row="2"
            Padding="12"
            Background="{DynamicResource {x:Static themes:MosaicTheme.ControlBackgroundBrush}}"
            BorderBrush="{DynamicResource {x:Static themes:MosaicTheme.ControlBorderBrush}}"
            BorderThickness="1"
            CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <Button
                        Padding="10,6"
                        HorizontalAlignment="Left"
                        Click="AddItemButton_OnClick"
                        Content="Add item" />

                    <Button
                        Margin="8,0,0,0"
                        Padding="10,6"
                        HorizontalAlignment="Left"
                        Click="AddTenItems_OnClick"
                        Content="Add 10 items" />
                </StackPanel>

                <ListBox
                    x:Name="ItemsListBox"
                    Grid.Row="2"
                    Height="180"
                    ItemsSource="{Binding Items}">
                    <i:Interaction.Behaviors>
                        <behaviors:ItemsControlAutoScrollBehavior />
                    </i:Interaction.Behaviors>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>
