<UserControl
    x:Class="MosaicWpfDemo.Views.Examples.EnumComboBoxExample"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MosaicWpfDemo.Views.Examples"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mosaic="http://schemas.apexgate.net/wpf/mosaic-ui"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <ScrollViewer
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        CanContentScroll="True"
        ClipToBounds="True"
        Focusable="False"
        HorizontalScrollBarVisibility="Disabled"
        VerticalScrollBarVisibility="Auto">

        <StackPanel Margin="20" Orientation="Vertical">
            <GroupBox
                Margin="0,0,0,20"
                Padding="10"
                Header="Basic Usage">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,10"
                        TextWrapping="Wrap"
                        Text="EnumComboBox populates itself from the enum type assigned to EnumType. The drop-down shows each member's friendly name while SelectedValue reads and writes the actual enum value." />

                    <mosaic:EnumComboBox
                        Width="220"
                        HorizontalAlignment="Left"
                        EnumType="{x:Type local:ProjectStatus}"
                        SelectedValue="{Binding SelectedStatus, Mode=TwoWay}" />

                    <TextBlock
                        Margin="0,10,0,0"
                        FontFamily="Consolas"
                        Text="{Binding SelectedStatus, StringFormat=Selected enum value: {0}}" />
                </StackPanel>
            </GroupBox>

            <GroupBox
                Margin="0,0,0,20"
                Padding="10"
                Header="Attribute Behavior">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,10"
                        TextWrapping="Wrap"
                        Text="Display text resolves with the precedence EnumDisplayName → Description → member name. EnumDisplayName wins when both attributes are present. (EnumDisplayNameAttribute is Mosaic's field-applicable DisplayNameAttribute, since C# does not allow DisplayName directly on enum members.)" />

                    <TextBlock FontFamily="Consolas" Text="NotStarted      → NotStarted             (no attribute, member name)" />
                    <TextBlock FontFamily="Consolas" Text="InProgress      → In Progress            (EnumDisplayName)" />
                    <TextBlock FontFamily="Consolas" Text="AwaitingReview  → Waiting for Review     (Description)" />
                    <TextBlock FontFamily="Consolas" Text="Completed       → Completed Successfully (EnumDisplayName wins over Description)" />
                </StackPanel>
            </GroupBox>

            <GroupBox
                Margin="0,0,0,20"
                Padding="10"
                Header="Nullable Binding">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,10"
                        TextWrapping="Wrap"
                        Text="Binding SelectedValue to a nullable enum property supports an unselected state: when the property is null the control simply has no selection." />

                    <StackPanel Orientation="Horizontal">
                        <mosaic:EnumComboBox
                            Width="220"
                            EnumType="{x:Type local:ProjectStatus}"
                            SelectedValue="{Binding OptionalStatus, Mode=TwoWay}" />
                        <Button
                            Margin="10,0,0,0"
                            Padding="10,2"
                            Command="{Binding ClearOptionalStatusCommand}"
                            Content="Clear" />
                    </StackPanel>

                    <TextBlock
                        Margin="0,10,0,0"
                        FontFamily="Consolas"
                        Text="{Binding OptionalStatus, StringFormat=Optional enum value: {0}, TargetNullValue=Optional enum value: (null)}" />
                </StackPanel>
            </GroupBox>

            <GroupBox Padding="10" Header="Disabled State">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,10"
                        TextWrapping="Wrap"
                        Text="EnumComboBox reuses the standard Mosaic ComboBox styling, including its disabled visuals." />

                    <mosaic:EnumComboBox
                        Width="220"
                        HorizontalAlignment="Left"
                        EnumType="{x:Type local:ProjectStatus}"
                        IsEnabled="False"
                        SelectedValue="{Binding SelectedStatus}" />
                </StackPanel>
            </GroupBox>
        </StackPanel>
    </ScrollViewer>
</UserControl>
