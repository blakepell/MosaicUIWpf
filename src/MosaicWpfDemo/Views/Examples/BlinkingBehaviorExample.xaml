<UserControl
    x:Class="MosaicWpfDemo.Views.Examples.BlinkingBehaviorExample"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Mosaic.UI.Wpf.Behaviors;assembly=Mosaic.UI.Wpf"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid Margin="12">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock
                Margin="0,0,0,8"
                Text="The slider changes the duration of the blink."
                TextAlignment="Center" />

            <Slider
                x:Name="BlinkDurationSlider"
                Width="220"
                IsSnapToTickEnabled="True"
                LargeChange="0.25"
                Maximum="5.0"
                Minimum="0.5"
                SmallChange="0.25"
                TickFrequency="0.25"
                Value="0.5" />

            <Border
                Margin="0,20,0,0"
                Padding="24"
                Background="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"
                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                BorderThickness="1"
                CornerRadius="6">
                <TextBlock
                    FontSize="24"
                    FontWeight="SemiBold"
                    Text="Blinking Behavior">
                    <i:Interaction.Behaviors>
                        <behaviors:BlinkingBehavior BlinkDuration="{Binding ElementName=BlinkDurationSlider, Path=Value}" IsBlinking="True" />
                    </i:Interaction.Behaviors>
                </TextBlock>
            </Border>
        </StackPanel>

    </Grid>
</UserControl>
