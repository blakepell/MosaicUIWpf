<UserControl
    x:Class="MosaicWpfDemo.Views.Examples.FileRenamerExample"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Mosaic.UI.Wpf.Controls;assembly=Mosaic.UI.Wpf"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MosaicWpfDemo.Views.Examples"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:theme="http://schemas.apexgate.net/wpf/mosaic-ui"
    d:DesignHeight="700"
    d:DesignWidth="900"
    mc:Ignorable="d">
    <UserControl.Resources>
        <!--  Converts a bool to Visibility for the second (replacement) input field.  -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <Grid Margin="4">
        <Grid.RowDefinitions>
            <!--  Row 1: File Dropper  -->
            <RowDefinition Height="Auto" />
            <!--  Row 2: Rename operations repeater + preview + execute  -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  ============================ Row 1: File Dropper ============================  -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  Drop target. Accepts any file; supports single or multiple files.  -->
            <StackPanel Grid.Column="0">
                <TextBlock
                    Margin="0,0,0,6"
                    FontWeight="SemiBold"
                    Text="1. Drop files to rename" />
                <controls:FileDropper
                    Height="120"
                    FileDrop="FileDropper_OnFileDrop"
                    Prompt="Drop one or more files here" />
            </StackPanel>

            <!--  List of the files that have been dropped.  -->
            <Grid Grid.Column="1" Margin="16,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,6">
                    <controls:AccentButton
                        Padding="10,2"
                        AccentButtonType="Gray"
                        Click="ClearFiles_OnClick"
                        Content="Clear"
                        DockPanel.Dock="Right" />
                    <TextBlock VerticalAlignment="Center" FontWeight="SemiBold">
                        <Run Text="Dropped files (" /><Run Text="{Binding DroppedFiles.Count, Mode=OneWay}" /><Run Text="):" />
                    </TextBlock>
                </DockPanel>

                <Border
                    Grid.Row="1"
                    MinHeight="120"
                    Background="{DynamicResource {x:Static theme:MosaicTheme.ControlBackgroundBrush}}"
                    BorderBrush="{DynamicResource {x:Static theme:MosaicTheme.ControlBorderBrush}}"
                    BorderThickness="1"
                    CornerRadius="6">
                    <ListBox
                        Height="125"
                        Background="Transparent"
                        BorderThickness="0"
                        ItemsSource="{Binding DroppedFiles}"
                        ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <!--  Show the file name; full path on hover.  -->
                                <TextBlock Text="{Binding FileName}" ToolTip="{Binding FullPath}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </Grid>
        </Grid>

        <!--  ===================== Row 2: Operations + Preview + Execute =====================  -->
        <Grid Grid.Row="1" Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <!--  Left: rename operations repeater  -->
                <ColumnDefinition Width="*" />
                <!--  Right: live preview  -->
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <!--  Operations repeater  -->
            <Grid Grid.Column="0" Margin="0,0,16,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Margin="0,0,0,6"
                    FontWeight="SemiBold"
                    Text="2. Rename operations (applied top to bottom)" />

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Operations}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Margin="0,0,0,8"
                                    Padding="10"
                                    Background="{DynamicResource {x:Static theme:MosaicTheme.ControlBackgroundBrush}}"
                                    BorderBrush="{DynamicResource {x:Static theme:MosaicTheme.ControlBorderBrush}}"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="170" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!--  Operation type dropdown  -->
                                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                            <TextBlock
                                                Margin="0,0,0,3"
                                                FontSize="11"
                                                Opacity="0.7"
                                                Text="Operation" />
                                            <ComboBox
                                                DisplayMemberPath="DisplayName"
                                                ItemsSource="{Binding OperationOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                SelectedValue="{Binding OperationType}"
                                                SelectedValuePath="Type" />
                                        </StackPanel>

                                        <!--  Primary input field (label changes with operation type)  -->
                                        <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                            <TextBlock
                                                Margin="0,0,0,3"
                                                FontSize="11"
                                                Opacity="0.7"
                                                Text="{Binding Field1Label}" />
                                            <TextBox Text="{Binding Field1Value, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>

                                        <!--  Secondary input field (only visible for replacement operations)  -->
                                        <StackPanel
                                            Grid.Column="2"
                                            Margin="0,0,8,0"
                                            Visibility="{Binding IsSecondFieldVisible, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock
                                                Margin="0,0,0,3"
                                                FontSize="11"
                                                Opacity="0.7"
                                                Text="{Binding Field2Label}" />
                                            <TextBox Text="{Binding Field2Value, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>

                                        <!--  Remove this operation  -->
                                        <controls:AccentButton
                                            Grid.Column="3"
                                            Margin="0,16,0,0"
                                            Padding="10,2"
                                            VerticalAlignment="Top"
                                            AccentButtonType="FluentRed"
                                            Click="RemoveOperation_OnClick"
                                            Content="Remove" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!--  Add operation + Execute  -->
                <StackPanel
                    Grid.Row="2"
                    Margin="0,10,0,0"
                    Orientation="Horizontal">
                    <controls:AccentButton
                        Padding="14,4"
                        AccentButtonType="ThemeAccent"
                        Click="AddOperation_OnClick"
                        Content="Add Operation" />
                    <controls:AccentButton
                        Margin="10,0,0,0"
                        Padding="14,4"
                        AccentButtonType="FluentGreen"
                        Click="ExecuteRenames_OnClick"
                        Content="Execute Renames" />
                </StackPanel>
            </Grid>

            <!--  Live preview  -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Margin="0,0,0,6"
                    FontWeight="SemiBold"
                    Text="Preview" />

                <Border
                    Grid.Row="1"
                    Background="{DynamicResource {x:Static theme:MosaicTheme.ControlBackgroundBrush}}"
                    BorderBrush="{DynamicResource {x:Static theme:MosaicTheme.ControlBorderBrush}}"
                    BorderThickness="1"
                    CornerRadius="6">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl Margin="8" ItemsSource="{Binding PreviewItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,8">
                                        <TextBlock
                                            FontSize="11"
                                            Opacity="0.7"
                                            Text="{Binding OriginalName}"
                                            TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            FontWeight="SemiBold"
                                            Text="{Binding NewName}"
                                            TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
