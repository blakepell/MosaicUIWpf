<UserControl
    x:Class="MosaicWpfDemo.Views.Examples.AudioPlayerExample"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Mosaic.UI.Wpf.Controls;assembly=Mosaic.UI.Wpf"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MosaicWpfDemo.Views.Examples"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <StackPanel
        Margin="24"
        HorizontalAlignment="Center"
        VerticalAlignment="Center">
        <TextBlock
            x:Name="NowPlayingText"
            Margin="0,0,0,16"
            HorizontalAlignment="Center"
            FontSize="16"
            FontWeight="SemiBold"
            Text="Now Playing: Sample.mp3" />

        <controls:AudioPlayer
            x:Name="Player"
            Width="420"
            HorizontalAlignment="Center"
            AutoAdvance="True"
            Volume="0.5" />

        <!--  Spectrum analyzer: visualizes whatever the player above is sending to the default output device.  -->
        <Border
            Width="420"
            Margin="0,16,0,0"
            HorizontalAlignment="Center"
            ClipToBounds="True"
            CornerRadius="6">
            <controls:AudioPlayerSpectrumAnalyzer
                x:Name="Spectrum"
                Height="140"
                BandCount="32"
                IsActive="True"
                ShowPeaks="True"
                UseColorIntensity="True" />
        </Border>

        <Button
            x:Name="OpenFileButton"
            Margin="0,16,0,0"
            Padding="14,6"
            HorizontalAlignment="Center"
            Click="OpenFileButton_Click"
            Content="Open Media File..." />
    </StackPanel>
</UserControl>
