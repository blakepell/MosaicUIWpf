<UserControl
    x:Class="MosaicWpfDemo.Views.Examples.AvalonEditVtTerminalBehaviorExample"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
    xmlns:behaviors="clr-namespace:Mosaic.UI.Wpf.Behaviors;assembly=Mosaic.UI.Wpf"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <!--  VT Terminal Container  -->
        <Border
            Background="#0a0a0a"
            BorderBrush="#1a3a1a"
            BorderThickness="3"
            CornerRadius="0">
            <Grid>
                <!--  Main terminal content  -->
                <Border
                    Margin="4"
                    Background="#050505"
                    CornerRadius="0">
                    <Grid>
                        <!--  AvalonEdit TextEditor with VT terminal skin applied via behavior  -->
                        <avalonedit:TextEditor
                            x:Name="TerminalEditor"
                            Padding="10"
                            BorderThickness="0"
                            FontFamily="Consolas, Courier New, Lucida Console"
                            FontSize="14"
                            HorizontalScrollBarVisibility="Auto"
                            ShowLineNumbers="False"
                            VerticalScrollBarVisibility="Auto"
                            WordWrap="True">
                            <i:Interaction.Behaviors>
                                <behaviors:AvalonEditVtTerminalBehavior IsActive="True" />
                            </i:Interaction.Behaviors>
                        </avalonedit:TextEditor>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
