<UserControl
    x:Class="MosaicWpfDemo.Views.Examples.ImageMouseWheelZoomBehaviorExample"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mosaic="http://schemas.apexgate.net/wpf/mosaic-ui"
    xmlns:themes="clr-namespace:Mosaic.UI.Wpf.Themes;assembly=Mosaic.UI.Wpf"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel LastChildFill="False">
            <Button
                MinWidth="104"
                Padding="12,6"
                Click="OpenImageButton_OnClick"
                Content="Open Image" />

            <CheckBox
                Margin="16,0,0,0"
                VerticalAlignment="Center"
                Content="Require Ctrl to zoom"
                IsChecked="{Binding RequireCtrl, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}" />

            <TextBlock
                Margin="16,0,0,0"
                VerticalAlignment="Center"
                Foreground="{DynamicResource {x:Static themes:MosaicTheme.ControlDisabledForegroundBrush}}"
                Text="{Binding ImagePath, RelativeSource={RelativeSource AncestorType=UserControl}, TargetNullValue=Drop an image or open one from disk.}"
                TextTrimming="CharacterEllipsis" />
        </DockPanel>

        <Border
            Grid.Row="2"
            AllowDrop="True"
            Background="{DynamicResource {x:Static themes:MosaicTheme.ControlBackgroundBrush}}"
            BorderBrush="{DynamicResource {x:Static themes:MosaicTheme.ControlBorderBrush}}"
            BorderThickness="1"
            CornerRadius="6"
            DragEnter="ImageDropSurface_OnDragOver"
            DragOver="ImageDropSurface_OnDragOver"
            Drop="ImageDropSurface_OnDrop">
            <Grid ClipToBounds="True">
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="18"
                    Foreground="{DynamicResource {x:Static themes:MosaicTheme.ControlDisabledForegroundBrush}}"
                    Text="Drop an image here">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasImage, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="False">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <Border
                    x:Name="ZoomTargetBorder"
                    Margin="16"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource {x:Static themes:MosaicTheme.WindowBackgroundBrush}}">
                    <Image
                        MaxWidth="640"
                        MaxHeight="420"
                        Source="{Binding ImageSource, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        Stretch="Uniform">
                        <i:Interaction.Behaviors>
                            <mosaic:ImageMouseWheelZoomBehavior
                                MaxZoom="16"
                                RequireCtrl="{Binding RequireCtrl, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                ZoomTarget="{Binding ElementName=ZoomTargetBorder}" />
                        </i:Interaction.Behaviors>
                    </Image>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
