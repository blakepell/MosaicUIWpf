<UserControl
    x:Class="MosaicWpfDemo.Views.Examples.GridViewBehaviorsExample"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Mosaic.UI.Wpf.Behaviors;assembly=Mosaic.UI.Wpf"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Margin="0,0,0,8" FontSize="18" FontWeight="SemiBold" Text="GridView Behaviors" />
            <TextBlock Text="Click a column header to sort. The last column stretches to fill the remaining width." TextWrapping="Wrap" />
        </StackPanel>

        <Border
            Grid.Row="2"
            Padding="12"
            Background="{DynamicResource {x:Static SystemColors.ControlLightLightBrushKey}}"
            BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
            BorderThickness="1"
            CornerRadius="4">
            <ListView behaviors:GridViewSortBehavior.IsEnabled="True" ItemsSource="{Binding Rows}">
                <i:Interaction.Behaviors>
                    <behaviors:GridViewLastColumnFillBehavior />
                </i:Interaction.Behaviors>

                <ListView.View>
                    <GridView>
                        <GridViewColumn
                            Width="220"
                            behaviors:GridViewSortBehavior.SortPropertyName="Name"
                            Header="Name"
                            DisplayMemberBinding="{Binding Name}" />
                        <GridViewColumn
                            Width="260"
                            behaviors:GridViewSortBehavior.SortPropertyName="Identifier"
                            Header="Identifier"
                            DisplayMemberBinding="{Binding Identifier}" />
                        <GridViewColumn
                            behaviors:GridViewSortBehavior.SortPropertyName="Category"
                            Header="Category"
                            DisplayMemberBinding="{Binding Category}" />
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>
    </Grid>
</UserControl>
