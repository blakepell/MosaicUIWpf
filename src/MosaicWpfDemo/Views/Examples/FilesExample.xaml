<UserControl
    x:Class="MosaicWpfDemo.Views.Examples.FilesExample"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:common="clr-namespace:MosaicWpfDemo.Common"
    xmlns:controls="clr-namespace:Mosaic.UI.Wpf.Controls;assembly=Mosaic.UI.Wpf"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MosaicWpfDemo.Views.Examples"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources>
        <!--  Relays this UserControl's DataContext so the folder context menu (a pop-up, outside the
              visual tree) can reach OpenFolderCommand on the example.  -->
        <common:BindingProxy x:Key="RootProxy" Data="{Binding}" />
    </UserControl.Resources>
    <Grid Margin="0,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Toolbar: folder selection and options.  -->
        <StackPanel
            Grid.Row="0"
            Margin="0,0,0,8"
            Orientation="Horizontal">
            <Button
                Padding="10,4"
                Click="BrowseButton_OnClick"
                Content="Browse..." />
            <Button
                Margin="6,0,0,0"
                Padding="10,4"
                Click="RefreshButton_OnClick"
                Content="Refresh" />
            <CheckBox
                Margin="16,0,0,0"
                VerticalAlignment="Center"
                Content="Multi-select"
                IsChecked="{Binding MultiSelect, RelativeSource={RelativeSource AncestorType=UserControl}}" />
            <CheckBox
                Margin="16,0,0,0"
                VerticalAlignment="Center"
                Content="Watch folder"
                IsChecked="{Binding ElementName=FilesControl, Path=EnableFileWatcher}" />
            <CheckBox
                Margin="16,0,0,0"
                VerticalAlignment="Center"
                Content="Show folders"
                IsChecked="{Binding ElementName=FilesControl, Path=ShowFolders}" />
        </StackPanel>

        <!--  The Files control.  -->
        <controls:Files
            x:Name="FilesControl"
            Grid.Row="1"
            Background="{DynamicResource themes:MosaicTheme.ControlTextBackgroundColor}"
            DirectoryPath="{Binding FolderPath, RelativeSource={RelativeSource AncestorType=UserControl}}"
            FileDoubleClick="FilesControl_OnFileDoubleClick"
            SelectionMode="{Binding SelectionMode, RelativeSource={RelativeSource AncestorType=UserControl}}">
            <!--  Right-click a folder (other than '..') to open it in Explorer. The menu's DataContext is
                  the clicked FileItem, so CommandParameter="{Binding}" passes it to the command.  -->
            <controls:Files.FolderContextMenu>
                <ContextMenu>
                    <!--  Tag holds a direct StaticResource (resolved inline at parse time); the command is
                          read back through it with RelativeSource Self. Binding the Source of a Binding to a
                          StaticResource instead defers the lookup past the resource's scope and throws.  -->
                    <MenuItem
                        Command="{Binding Tag.Data.OpenFolderCommand, RelativeSource={RelativeSource Self}}"
                        CommandParameter="{Binding}"
                        Header="Open in Explorer"
                        Tag="{StaticResource RootProxy}" />
                </ContextMenu>
            </controls:Files.FolderContextMenu>
        </controls:Files>

        <!--  Status line.  -->
        <TextBlock
            x:Name="StatusTextBlock"
            Grid.Row="2"
            Margin="0,8,0,0"
            Opacity="0.8"
            Text="Double-click a file to see its FileInfo here." />
    </Grid>
</UserControl>
