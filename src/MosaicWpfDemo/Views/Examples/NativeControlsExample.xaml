<UserControl
    x:Class="MosaicWpfDemo.Views.Examples.NativeControlsExample"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mosaic="clr-namespace:Mosaic.UI.Wpf.Controls;assembly=Mosaic.UI.Wpf"
    xmlns:System="clr-namespace:System;assembly=System.Runtime"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10">
            <mosaic:SettingsItem Title="Button" Description="Native button template." IconSource="../../Assets/toolbox-48.png">
                <Button Padding="12,4" Content="Click me" />
            </mosaic:SettingsItem>

            <mosaic:SettingsItem Title="CheckBox" Description="Native checkbox template." IconSource="../../Assets/toolbox-48.png">
                <CheckBox Content="Enable feature" IsChecked="True" />
            </mosaic:SettingsItem>

            <mosaic:SettingsItem Title="ComboBox" Description="Native combo box template." IconSource="../../Assets/toolbox-48.png">
                <ComboBox Width="180" SelectedIndex="1">
                    <ComboBoxItem Content="First" />
                    <ComboBoxItem Content="Second" />
                    <ComboBoxItem Content="Third" />
                </ComboBox>
            </mosaic:SettingsItem>

            <mosaic:SettingsItem Title="DatePicker" Description="Native date picker template." IconSource="../../Assets/toolbox-48.png">
                <DatePicker Width="180" SelectedDate="{x:Static System:DateTime.Now}" />
            </mosaic:SettingsItem>

            <mosaic:SettingsItem Title="GroupBox" Description="Native group box template." IconSource="../../Assets/toolbox-48.png">
                <GroupBox Width="220" Header="Options">
                    <StackPanel Margin="10,6">
                        <RadioButton Content="Option A" IsChecked="True" />
                        <RadioButton Content="Option B" />
                    </StackPanel>
                </GroupBox>
            </mosaic:SettingsItem>

            <mosaic:SettingsItem Title="ListBox" Description="Native list box template." IconSource="../../Assets/toolbox-48.png">
                <ListBox Width="180" Height="90">
                    <ListBoxItem Content="Alpha" />
                    <ListBoxItem Content="Beta" />
                    <ListBoxItem Content="Gamma" />
                </ListBox>
            </mosaic:SettingsItem>

            <mosaic:SettingsItem Title="ListView" Description="Native list view template." IconSource="../../Assets/toolbox-48.png">
                <ListView Width="220" Height="120">
                    <ListViewItem>
                        <TextBlock Text="Item 1" />
                    </ListViewItem>
                    <ListViewItem>
                        <TextBlock Text="Item 2" />
                    </ListViewItem>
                    <ListViewItem>
                        <TextBlock Text="Item 3" />
                    </ListViewItem>
                </ListView>
            </mosaic:SettingsItem>

            <mosaic:SettingsItem Title="Menu" Description="Native menu template." IconSource="../../Assets/toolbox-48.png">
                <Menu>
                    <MenuItem Header="File">
                        <MenuItem Header="Open" />
                        <MenuItem Header="Save" />
                    </MenuItem>
                    <MenuItem Header="Edit">
                        <MenuItem Header="Copy" />
                        <MenuItem Header="Paste" />
                    </MenuItem>
                </Menu>
            </mosaic:SettingsItem>

            <mosaic:SettingsItem Title="ScrollBar" Description="Native scrollbar template." IconSource="../../Assets/toolbox-48.png">
                <Border Width="220" Height="80" Padding="10" Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
                    <ScrollBar Width="16" Height="60" HorizontalAlignment="Left" Minimum="0" Maximum="100" Orientation="Vertical" Value="45" />
                </Border>
            </mosaic:SettingsItem>

            <mosaic:SettingsItem Title="ScrollViewer" Description="Native scroll viewer template." IconSource="../../Assets/toolbox-48.png">
                <ScrollViewer Width="220" Height="100" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <TextBlock Width="360" TextWrapping="Wrap">
                        This is a native ScrollViewer hosting longer text so the template can be seen in use.
                    </TextBlock>
                </ScrollViewer>
            </mosaic:SettingsItem>

            <mosaic:SettingsItem Title="Separator" Description="Native separator template." IconSource="../../Assets/toolbox-48.png">
                <StackPanel Width="240">
                    <TextBlock Text="Above" />
                    <Separator Margin="0,8" />
                    <TextBlock Text="Below" />
                </StackPanel>
            </mosaic:SettingsItem>

            <mosaic:SettingsItem Title="TextBox" Description="Native text box template." IconSource="../../Assets/toolbox-48.png">
                <TextBox Width="220" Text="Editable text" />
            </mosaic:SettingsItem>

            <mosaic:SettingsItem Title="ToolBar" Description="Native tool bar template." IconSource="../../Assets/toolbox-48.png">
                <ToolBar>
                    <Button Content="New" />
                    <Button Content="Open" />
                    <Button Content="Save" />
                </ToolBar>
            </mosaic:SettingsItem>
        </StackPanel>
    </ScrollViewer>
</UserControl>
