<UserControl
    x:Class="MosaicWpfDemo.Views.Examples.NativeControlsExample"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:System="clr-namespace:System;assembly=System.Runtime"
    xmlns:common="clr-namespace:Mosaic.UI.Wpf.Common;assembly=Mosaic.UI.Wpf"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mosaic="clr-namespace:Mosaic.UI.Wpf.Controls;assembly=Mosaic.UI.Wpf"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10">
            <mosaic:SettingsItem
                Title="Button"
                Description="Native button template."
                IconSource="../../Assets/toolbox-48.png">
                <Button Padding="12,4" Content="Click me" />
            </mosaic:SettingsItem>

            <mosaic:SettingsItem
                Title="CheckBox"
                Description="Native checkbox template."
                IconSource="../../Assets/toolbox-48.png">
                <CheckBox Content="Enable feature" IsChecked="True" />
            </mosaic:SettingsItem>

            <mosaic:SettingsItem
                Title="ComboBox"
                Description="Native combo box template."
                IconSource="../../Assets/toolbox-48.png">
                <ComboBox Width="180" SelectedIndex="1">
                    <ComboBoxItem Content="First" />
                    <ComboBoxItem Content="Second" />
                    <ComboBoxItem Content="Third" />
                </ComboBox>
            </mosaic:SettingsItem>

            <mosaic:SettingsItem
                Title="DatePicker"
                Description="Native date picker template."
                IconSource="../../Assets/toolbox-48.png">
                <DatePicker Width="180" SelectedDate="{x:Static System:DateTime.Now}" />
            </mosaic:SettingsItem>

            <mosaic:SettingsItem
                Title="GroupBox"
                Description="Native group box template."
                IconSource="../../Assets/toolbox-48.png">
                <GroupBox Width="220" Header="Options">
                    <StackPanel Margin="10,6">
                        <RadioButton Content="Option A" IsChecked="True" />
                        <RadioButton Content="Option B" />
                    </StackPanel>
                </GroupBox>
            </mosaic:SettingsItem>

            <mosaic:SettingsItem
                Title="ListBox"
                Description="Native list box template."
                IconSource="../../Assets/toolbox-48.png">
                <ListBox Width="180" Height="90">
                    <ListBoxItem Content="Alpha" />
                    <ListBoxItem Content="Beta" />
                    <ListBoxItem Content="Gamma" />
                </ListBox>
            </mosaic:SettingsItem>

            <mosaic:SettingsItem
                Title="ListView"
                Description="Native list view template."
                IconSource="../../Assets/toolbox-48.png">
                <ListView Width="260" Height="120">
                    <ListView.View>
                        <GridView AllowsColumnReorder="False">
                            <GridViewColumn Width="120" Header="Name">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="120" Header="State">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=Content}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                    <ListViewItem Content="Item 1" />
                    <ListViewItem Content="Item 2" />
                    <ListViewItem Content="Item 3" />
                </ListView>
            </mosaic:SettingsItem>

            <mosaic:SettingsItem
                Title="TreeView"
                Description="Native tree view template with sample nested data."
                IconSource="../../Assets/toolbox-48.png">
                <TreeView
                    Width="240"
                    Height="150"
                    common:TreeViewHelper.IsExpansionAnimation="False">
                    <TreeViewItem Header="Projects" IsExpanded="True">
                        <TreeViewItem Header="Mosaic UI WPF" IsExpanded="True">
                            <TreeViewItem Header="Controls" />
                            <TreeViewItem Header="Themes" />
                            <TreeViewItem Header="Docs" />
                        </TreeViewItem>
                        <TreeViewItem Header="MosaicWpfDemo">
                            <TreeViewItem Header="Views" />
                            <TreeViewItem Header="Assets" />
                        </TreeViewItem>
                    </TreeViewItem>
                    <TreeViewItem Header="Personal" IsExpanded="True">
                        <TreeViewItem Header="Ideas" />
                        <TreeViewItem Header="Backlog">
                            <TreeViewItem Header="TreeView native template" />
                            <TreeViewItem Header="Settings page polish" />
                        </TreeViewItem>
                    </TreeViewItem>
                </TreeView>

            </mosaic:SettingsItem>

            <mosaic:SettingsItem
                Title="Menu"
                Description="Native menu template."
                IconSource="../../Assets/toolbox-48.png">
                <Menu>
                    <MenuItem Header="File">
                        <MenuItem Header="Open" />
                        <MenuItem Header="Save" />
                    </MenuItem>
                    <MenuItem Header="Edit">
                        <MenuItem Header="Copy" />
                        <MenuItem Header="Paste" />
                    </MenuItem>
                </Menu>
            </mosaic:SettingsItem>

            <mosaic:SettingsItem
                Title="ScrollBar"
                Description="Native scrollbar template."
                IconSource="../../Assets/toolbox-48.png">
                <Border
                    Width="220"
                    Height="80"
                    Padding="10"
                    Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
                    <ScrollBar
                        Width="16"
                        Height="60"
                        HorizontalAlignment="Left"
                        Maximum="100"
                        Minimum="0"
                        Orientation="Vertical"
                        Value="45" />
                </Border>
            </mosaic:SettingsItem>

            <mosaic:SettingsItem
                Title="Slider"
                Description="Native slider template."
                IconSource="../../Assets/toolbox-48.png">
                <Border
                    Width="240"
                    Height="100"
                    Padding="10"
                    Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
                    <Slider
                        Height="75"
                        Maximum="100"
                        Minimum="0"
                        Value="65" />
                </Border>
            </mosaic:SettingsItem>

            <mosaic:SettingsItem
                Title="ScrollViewer"
                Description="Native scroll viewer template."
                IconSource="../../Assets/toolbox-48.png">
                <ScrollViewer
                    Width="220"
                    Height="100"
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto">
                    <TextBlock Width="360" TextWrapping="Wrap">
                        This is a native ScrollViewer hosting longer text so the template can be seen in use.
                    </TextBlock>
                </ScrollViewer>
            </mosaic:SettingsItem>

            <mosaic:SettingsItem
                Title="Separator"
                Description="Native separator template."
                IconSource="../../Assets/toolbox-48.png">
                <StackPanel Width="240">
                    <TextBlock Text="Above" />
                    <Separator Margin="0,8" />
                    <TextBlock Text="Below" />
                </StackPanel>
            </mosaic:SettingsItem>

            <mosaic:SettingsItem
                Title="TextBox"
                Description="Native text box template."
                IconSource="../../Assets/toolbox-48.png">
                <TextBox Width="220" Text="Editable text" />
            </mosaic:SettingsItem>

            <mosaic:SettingsItem
                Title="ToolBar"
                Description="Native tool bar template."
                IconSource="../../Assets/toolbox-48.png">
                <ToolBar>
                    <Button Content="New" />
                    <Button Content="Open" />
                    <Button Content="Save" />
                </ToolBar>
            </mosaic:SettingsItem>

            <mosaic:SettingsItem
                Title="Progress Bar"
                Description="The WPF progress bar"
                IconSource="../../Assets/toolbox-48.png">
                <ProgressBar
                    Width="200"
                    Height="20"
                    Maximum="100"
                    Minimum="0"
                    Value="50" />
            </mosaic:SettingsItem>

            <mosaic:SettingsItem
                Title="Expander"
                Description="Native expander template."
                IconSource="../../Assets/toolbox-48.png">
                <Expander Width="240" Header="Advanced options" IsExpanded="True">
                    <StackPanel Margin="10,6">
                        <CheckBox Content="Enable logging" IsChecked="True" />
                        <CheckBox Content="Verbose output" />
                    </StackPanel>
                </Expander>
            </mosaic:SettingsItem>

            <mosaic:SettingsItem
                Title="GridSplitter"
                Description="Native grid splitter template."
                IconSource="../../Assets/toolbox-48.png">
                <Grid Width="260" Height="80">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="5" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Grid.Column="0"
                        Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Text="Left" />
                    </Border>
                    <GridSplitter
                        Grid.Column="1"
                        Width="5"
                        HorizontalAlignment="Stretch" />
                    <Border
                        Grid.Column="2"
                        Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Text="Right" />
                    </Border>
                </Grid>
            </mosaic:SettingsItem>

            <mosaic:SettingsItem
                Title="Label"
                Description="Native label template."
                IconSource="../../Assets/toolbox-48.png">
                <Label Content="_User name:" Target="{Binding ElementName=LabelDemoBox}" />
            </mosaic:SettingsItem>

            <mosaic:SettingsItem
                Title="PasswordBox"
                Description="Native password box template."
                IconSource="../../Assets/toolbox-48.png">
                <PasswordBox
                    x:Name="LabelDemoBox"
                    Width="220"
                    Password="secret" />
            </mosaic:SettingsItem>

            <mosaic:SettingsItem
                Title="RichTextBox"
                Description="Native rich text box template."
                IconSource="../../Assets/toolbox-48.png">
                <RichTextBox Width="260" Height="90">
                    <FlowDocument>
                        <Paragraph>
                            This is a
                            <Bold>native</Bold>
                            <Italic>RichTextBox</Italic>
                            with Mosaic themed colors.
                        </Paragraph>
                    </FlowDocument>
                </RichTextBox>
            </mosaic:SettingsItem>

            <mosaic:SettingsItem
                Title="TabControl"
                Description="Native tab control template."
                IconSource="../../Assets/toolbox-48.png">
                <TabControl Width="260" Height="120">
                    <TabItem Header="General">
                        <TextBlock Margin="8" Text="General settings" />
                    </TabItem>
                    <TabItem Header="Display">
                        <TextBlock Margin="8" Text="Display settings" />
                    </TabItem>
                    <TabItem Header="About">
                        <TextBlock Margin="8" Text="About this app" />
                    </TabItem>
                </TabControl>
            </mosaic:SettingsItem>

            <mosaic:SettingsItem
                Title="StatusBar"
                Description="Native status bar template."
                IconSource="../../Assets/toolbox-48.png">
                <StatusBar Width="280">
                    <StatusBarItem Content="Ready" />
                    <Separator />
                    <StatusBarItem Content="Ln 12, Col 4" />
                    <Separator />
                    <StatusBarItem Content="UTF-8" />
                </StatusBar>
            </mosaic:SettingsItem>

            <mosaic:SettingsItem
                Title="ToolTip"
                Description="Native tooltip template. Hover the button below."
                IconSource="../../Assets/toolbox-48.png">
                <Button
                    Padding="12,4"
                    Content="Hover me"
                    ToolTip="This is a native themed ToolTip." />
            </mosaic:SettingsItem>

        </StackPanel>
    </ScrollViewer>
</UserControl>
