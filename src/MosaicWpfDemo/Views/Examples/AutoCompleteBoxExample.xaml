<UserControl
    x:Class="MosaicWpfDemo.Views.Examples.AutoCompleteBoxExample"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mosaic="clr-namespace:Mosaic.UI.Wpf.Controls;assembly=Mosaic.UI.Wpf"
    xmlns:themes="http://schemas.apexgate.net/wpf/mosaic-ui"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="260" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="135" />
            <RowDefinition Height="135" />
        </Grid.RowDefinitions>

        <StackPanel
            Grid.Row="0"
            Grid.Column="0"
            Orientation="Vertical">
            <TextBlock
                Margin="0,0,0,6"
                FontWeight="SemiBold"
                Text="ObservableCollection" />
            <mosaic:AutoCompleteBox
                Width="240"
                IsTextRequiredForSuggestions="False"
                ItemsSource="{Binding CityOptions}"
                SelectedItem="{Binding SelectedCity, Mode=TwoWay}"
                Text="{Binding CitySearchText, Mode=TwoWay}"
                Watermark="Choose a city" />
            <TextBlock Margin="0,8,0,16" TextWrapping="Wrap">
                <Run Text="Selected city: " />
                <Run Foreground="CornflowerBlue" Text="{Binding SelectedCity}" />
            </TextBlock>

            <Button
                Width="170"
                HorizontalAlignment="Left"
                Click="AddCity_OnClick"
                Content="Add Indianapolis suburb" />
        </StackPanel>

        <StackPanel
            Grid.Row="0"
            Grid.Column="2"
            Orientation="Vertical">
            <TextBlock
                Margin="0,0,0,6"
                FontWeight="SemiBold"
                Text="List with DisplayMemberPath" />
            <mosaic:AutoCompleteBox
                Width="240"
                DisplayMemberPath="Name"
                IsTextRequiredForSuggestions="False"
                ItemsSource="{Binding ProductOptions}"
                SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"
                SelectedValuePath="Sku"
                Text="{Binding ProductSearchText, Mode=TwoWay}"
                Watermark="Find a product" />
            <TextBlock Margin="0,8,0,6" TextWrapping="Wrap">
                <Run Text="Selected product: " />
                <Run Foreground="CornflowerBlue" Text="{Binding SelectedProduct.Name, Mode=OneWay}" />
            </TextBlock>
            <TextBlock TextWrapping="Wrap">
                <Run Text="SKU: " />
                <Run Foreground="CornflowerBlue" Text="{Binding SelectedProduct.Sku, Mode=OneWay}" />
            </TextBlock>
        </StackPanel>

        <StackPanel
            Grid.Row="1"
            Grid.Column="0"
            Orientation="Vertical">
            <TextBlock
                Margin="0,0,0,6"
                FontWeight="SemiBold"
                Text="Async lookup provider" />
            <mosaic:AutoCompleteBox
                Width="240"
                IsTextRequiredForSuggestions="False"
                ItemsProvider="{Binding AsyncProductLookup}"
                LoadingContent="Searching products..."
                NoResultsContent="No matching products"
                SelectedItem="{Binding SelectedAsyncProduct, Mode=TwoWay}"
                Text="{Binding AsyncSearchText, Mode=TwoWay}"
                TextSearch.TextPath="Name"
                Watermark="Search database">
                <mosaic:AutoCompleteBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,1,0,2">
                            <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                            <TextBlock
                                FontSize="{DynamicResource {x:Static themes:MosaicTheme.FontSizeSmall}}"
                                Foreground="{DynamicResource {x:Static themes:MosaicTheme.ControlTextSecondaryForegroundBrush}}"
                                Text="{Binding Category}" />
                        </StackPanel>
                    </DataTemplate>
                </mosaic:AutoCompleteBox.ItemTemplate>
            </mosaic:AutoCompleteBox>
            <TextBlock Margin="0,8,0,0" TextWrapping="Wrap">
                <Run Text="Async selection: " />
                <Run Foreground="CornflowerBlue" Text="{Binding SelectedAsyncProduct.Name, Mode=OneWay}" />
            </TextBlock>
        </StackPanel>
    </Grid>
</UserControl>
