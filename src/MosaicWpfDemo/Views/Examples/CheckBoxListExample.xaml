<UserControl
    x:Class="MosaicWpfDemo.Views.Examples.CheckBoxListExample"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mosaic="clr-namespace:Mosaic.UI.Wpf.Controls;assembly=Mosaic.UI.Wpf"
    xmlns:themes="http://schemas.apexgate.net/wpf/mosaic-ui"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="310" />
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="360" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Orientation="Vertical">
            <TextBlock
                Margin="0,0,0,6"
                FontWeight="SemiBold"
                Text="String Items" />
            <mosaic:CheckBoxList
                x:Name="TaskList"
                Width="300"
                Height="150"
                HorizontalAlignment="Left"
                ItemsSource="{Binding TaskOptions}"
                SelectionChanged="CheckBoxList_OnSelectionChanged" />
            <TextBlock Margin="0,6,0,16" TextWrapping="Wrap">
                <Run Text="Selected tasks: " />
                <Run Foreground="CornflowerBlue" Text="{Binding SelectedTaskSummary}" />
            </TextBlock>

            <TextBlock
                Margin="0,0,0,6"
                FontWeight="SemiBold"
                Text="DisplayMemberPath" />
            <mosaic:CheckBoxList
                x:Name="PermissionList"
                Width="300"
                Height="130"
                HorizontalAlignment="Left"
                DisplayMemberPath="Name"
                ItemsSource="{Binding PermissionOptions}"
                SelectionChanged="CheckBoxList_OnSelectionChanged" />
            <TextBlock Margin="0,6,0,0" TextWrapping="Wrap">
                <Run Text="Selected keys: " />
                <Run Foreground="CornflowerBlue" Text="{Binding SelectedPermissionSummary}" />
            </TextBlock>
        </StackPanel>

        <StackPanel Grid.Column="2" Orientation="Vertical">
            <TextBlock
                Margin="0,0,0,6"
                FontWeight="SemiBold"
                Text="Custom ItemTemplate" />
            <mosaic:CheckBoxList
                x:Name="FeatureList"
                Width="350"
                Height="290"
                HorizontalAlignment="Left"
                ItemsSource="{Binding FeatureOptions}"
                SelectionChanged="CheckBoxList_OnSelectionChanged">
                <mosaic:CheckBoxList.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,1,0,2">
                            <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                            <TextBlock
                                FontSize="{DynamicResource {x:Static themes:MosaicTheme.FontSizeSmall}}"
                                Foreground="{DynamicResource {x:Static themes:MosaicTheme.ControlTextSecondaryForegroundBrush}}"
                                Text="{Binding Description}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </DataTemplate>
                </mosaic:CheckBoxList.ItemTemplate>
            </mosaic:CheckBoxList>
            <TextBlock Margin="0,6,0,0" TextWrapping="Wrap">
                <Run Text="Selected features: " />
                <Run Foreground="CornflowerBlue" Text="{Binding SelectedFeatureSummary}" />
            </TextBlock>
        </StackPanel>
    </Grid>
</UserControl>
