<UserControl
    x:Class="MosaicWpfDemo.Views.Examples.ScalingTextBlockExample"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MosaicWpfDemo.Views.Examples"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mosaic="clr-namespace:Mosaic.UI.Wpf.Controls;assembly=Mosaic.UI.Wpf"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" Orientation="Vertical">

            <TextBlock
                Margin="0,0,0,4"
                FontSize="13"
                FontWeight="SemiBold"
                Text="ScalingTextBlock automatically shrinks the font to fit the available width." />
            <TextBlock
                Margin="0,0,0,20"
                Foreground="Gray"
                Text="MinFontSize=12  MaxFontSize=32 (defaults).  The control starts at MaxFontSize and steps down until text fits." />

            <!--  Same text, different container widths  -->
            <TextBlock
                Margin="0,0,0,6"
                FontWeight="SemiBold"
                Text="Same text — containers shrinking from 600 px → 300 px → 150 px" />

            <Border
                Width="600"
                Margin="0,4"
                HorizontalAlignment="Left"
                BorderBrush="Gray"
                BorderThickness="1">
                <mosaic:ScalingTextBlock
                    Padding="6,4"
                    MaxFontSize="32"
                    MinFontSize="12"
                    Text="Mosaic UI for WPF — ScalingTextBlock" />
            </Border>

            <Border
                Width="300"
                Margin="0,4"
                HorizontalAlignment="Left"
                BorderBrush="Gray"
                BorderThickness="1">
                <mosaic:ScalingTextBlock
                    Padding="6,4"
                    MaxFontSize="32"
                    MinFontSize="12"
                    Text="Mosaic UI for WPF — ScalingTextBlock" />
            </Border>

            <Border
                Width="150"
                Margin="0,4"
                HorizontalAlignment="Left"
                BorderBrush="Gray"
                BorderThickness="1">
                <mosaic:ScalingTextBlock
                    Padding="6,4"
                    MaxFontSize="32"
                    MinFontSize="12"
                    Text="Mosaic UI for WPF — ScalingTextBlock" />
            </Border>

            <!--  Custom font range  -->
            <TextBlock
                Margin="0,20,0,6"
                FontWeight="SemiBold"
                Text="Custom font range — MinFontSize=8, MaxFontSize=48" />

            <Border
                Width="500"
                Margin="0,4"
                HorizontalAlignment="Left"
                BorderBrush="Gray"
                BorderThickness="1">
                <mosaic:ScalingTextBlock
                    Padding="6,4"
                    MaxFontSize="48"
                    MinFontSize="8"
                    Text="Adaptive headline text" />
            </Border>

            <Border
                Width="180"
                Margin="0,4"
                HorizontalAlignment="Left"
                BorderBrush="Gray"
                BorderThickness="1">
                <mosaic:ScalingTextBlock
                    Padding="6,4"
                    MaxFontSize="48"
                    MinFontSize="8"
                    Text="Adaptive headline text" />
            </Border>

            <!--  Live interactive demo  -->
            <TextBlock
                Margin="0,20,0,6"
                FontWeight="SemiBold"
                Text="Live example — type text and watch the font scale inside a 350 px container" />

            <TextBox
                x:Name="LiveTextBox"
                Width="350"
                Margin="0,4"
                HorizontalAlignment="Left"
                Text="Type here to see scaling…" />

            <Border
                Width="350"
                Margin="0,4"
                HorizontalAlignment="Left"
                BorderBrush="Gray"
                BorderThickness="1">
                <mosaic:ScalingTextBlock
                    Padding="6,4"
                    MaxFontSize="36"
                    MinFontSize="10"
                    Text="{Binding ElementName=LiveTextBox, Path=Text}" />
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
