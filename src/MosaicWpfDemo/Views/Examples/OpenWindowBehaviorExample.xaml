<UserControl
    x:Class="MosaicWpfDemo.Views.Examples.OpenWindowBehaviorExample"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Mosaic.UI.Wpf.Behaviors;assembly=Mosaic.UI.Wpf"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:WpfDemo"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid Margin="12">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock
                Margin="0,0,0,8"
                FontSize="18"
                FontWeight="SemiBold"
                Text="OpenWindowBehavior" />

            <TextBlock
                Margin="0,0,0,16"
                Text="Use the File menu below. Clicking Open launches another MainWindow instance."
                TextAlignment="Center"
                TextWrapping="Wrap" />

            <Menu HorizontalAlignment="Center">
                <MenuItem Header="_File">
                    <MenuItem
                        Header="_Open"
                        ToolTip="Open a new MainWindow instance">
                        <i:Interaction.Behaviors>
                            <behaviors:OpenWindowBehavior WindowType="{x:Type local:MainWindow}" />
                        </i:Interaction.Behaviors>
                    </MenuItem>
                </MenuItem>
            </Menu>
        </StackPanel>
    </Grid>
</UserControl>
