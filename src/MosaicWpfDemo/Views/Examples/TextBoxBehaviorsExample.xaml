<UserControl
    x:Class="MosaicWpfDemo.Views.Examples.TextBoxBehaviorsExample"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Mosaic.UI.Wpf.Behaviors;assembly=Mosaic.UI.Wpf"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mosaic="clr-namespace:Mosaic.UI.Wpf.Controls;assembly=Mosaic.UI.Wpf"
    xmlns:themes="clr-namespace:Mosaic.UI.Wpf.Themes;assembly=Mosaic.UI.Wpf"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Orientation="Vertical">
            <TextBlock Margin="0,0,0,8" FontWeight="SemiBold" Text="Copy text from a TextBox" />

            <TextBox
                x:Name="CopySourceTextBox"
                Margin="0,0,0,8"
                Padding="6"
                Text="Select some text, then click Copy." />

            <Button Padding="10,6" HorizontalAlignment="Left" Content="Copy selected text">
                <i:Interaction.Behaviors>
                    <behaviors:TextBoxCopyBehavior TargetTextBox="{Binding ElementName=CopySourceTextBox}" />
                </i:Interaction.Behaviors>
            </Button>

            <TextBlock
                Margin="0,12,0,0"
                Foreground="{DynamicResource {x:Static themes:MosaicTheme.ControlDisabledForegroundBrush}}"
                TextWrapping="Wrap"
                Text="If text is selected, only the selection is copied. Otherwise the full text is copied." />
        </StackPanel>

        <Border
            Grid.Column="2"
            Padding="12"
            Background="{DynamicResource {x:Static themes:MosaicTheme.ControlBackgroundBrush}}"
            BorderBrush="{DynamicResource {x:Static themes:MosaicTheme.ControlBorderBrush}}"
            BorderThickness="1"
            CornerRadius="4">
            <StackPanel Orientation="Vertical">
                <TextBlock Margin="0,0,0,8" FontWeight="SemiBold" Text="Clear a TextBox with Escape" />

                <TextBox
                    x:Name="EscapeTextBox"
                    Margin="0,0,0,8"
                    Padding="6"
                    Text="Focus this box and press Escape to clear it.">
                    <i:Interaction.Behaviors>
                        <behaviors:TextBoxClearTextOnEscapeBehavior />
                    </i:Interaction.Behaviors>
                </TextBox>

                <TextBlock
                    Foreground="{DynamicResource {x:Static themes:MosaicTheme.ControlDisabledForegroundBrush}}"
                    TextWrapping="Wrap"
                    Text="The behavior clears TextBox, RichTextBox, or any control that exposes a writable Text property." />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
