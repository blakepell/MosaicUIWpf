<UserControl
    x:Class="MosaicWpfDemo.Views.Examples.VT52TerminalExample"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:behaviors="http://schemas.apexgate.net/wpf/mosaic"
    xmlns:controls="clr-namespace:Mosaic.UI.Wpf.Controls;assembly=Mosaic.UI.Wpf"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MosaicWpfDemo.Views.Examples"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vt52="clr-namespace:Mosaic.UI.Wpf.Controls.VT52Terminal;assembly=Mosaic.UI.Wpf"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Loaded="VT52TerminalExample_OnLoaded"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="140" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="70" />
                <RowDefinition Height="70" />
            </Grid.RowDefinitions>
            <controls:SettingsItem
                Grid.Row="0"
                Title="Green Phosphor Effect"
                Description="This will somewhat emulate an old green phosphor screen, however, it still supports colors."
                IconSource="../../Assets/black-and-white-48.png">
                <controls:ToggleButton IsChecked="{Binding PhosphorEffectEnabled, Mode=TwoWay, NotifyOnSourceUpdated=True, NotifyOnTargetUpdated=True}" />
            </controls:SettingsItem>
            <controls:SettingsItem
                Grid.Row="1"
                Title="Local Echo"
                Description="Show typed input locally when the remote host does not echo it back."
                IconSource="../../Assets/black-and-white-48.png">
                <controls:ToggleButton IsChecked="{Binding LocalEchoEnabled, Mode=TwoWay, NotifyOnSourceUpdated=True, NotifyOnTargetUpdated=True}" />
            </controls:SettingsItem>
        </Grid>

        <vt52:VT52Terminal
            x:Name="Terminal"
            Grid.Row="1"
            Padding="4,0,0,0"
            FontFamily="Consolas, Courier New, Lucida Console"
            FontSize="14"
            HorizontalScrollBarVisibility="Hidden"
            DisconnectOnUnload="False"
            LocalEcho="{Binding LocalEchoEnabled}"
            ShowLineNumbers="False"
            VerticalScrollBarVisibility="Hidden">
            <b:Interaction.Behaviors>
                <behaviors:AvalonEditVtTerminalBehavior IsActive="{Binding PhosphorEffectEnabled}" />
            </b:Interaction.Behaviors>
        </vt52:VT52Terminal>
    </Grid>
</UserControl>
