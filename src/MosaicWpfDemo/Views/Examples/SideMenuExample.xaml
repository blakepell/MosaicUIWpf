<UserControl
    x:Class="MosaicWpfDemo.Views.Examples.SideMenuExample"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:MosaicWpfDemo.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dialogs="clr-namespace:MosaicWpfDemo.Dialogs"
    xmlns:example="clr-namespace:MosaicWpfDemo.Views.Examples"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="http://schemas.apexgate.net/wpf/mosaic-ui"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mosaic="clr-namespace:Mosaic.UI.Wpf.Controls;assembly=Mosaic.UI.Wpf"
    xmlns:views="clr-namespace:MosaicWpfDemo.Views"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock
            Grid.Row="0"
            Margin="0,5,0,10"
            FontSize="18"
            FontWeight="Bold"
            Text="SideMenu Example" />
        <Separator
            Grid.Row="1"
            Grid.ColumnSpan="2"
            Margin="0,0,0,10" />

        <mosaic:SideMenu
            Grid.Row="2"
            Width="250"
            ContentPresenter="{Binding ElementName=ExampleContent}">
            <mosaic:SideMenuItem
                ContentType="{x:Type views:AboutView}"
                ContentTypeIsSingleton="True"
                ImageSource="pack://application:,,,/Assets/collage-48.png"
                Text="About">
                <mosaic:SideMenuItem.Children>
                    <mosaic:SideMenuItem
                        ContentType="{x:Type example:AvatarExample}"
                        ContentTypeIsSingleton="True"
                        ImageSource="pack://application:,,,/Assets/avatar-48.png"
                        Text="Avatars" />
                </mosaic:SideMenuItem.Children>
            </mosaic:SideMenuItem>

            <!--  Debug  -->
            <mosaic:SideMenuItem
                ContentType="{x:Type example:SideMenuExample}"
                ContentTypeIsSingleton="True"
                ImageSource="/Assets/bug-48.png"
                Text="Debug">
                <mosaic:SideMenuItem.ParameterCollection>
                    <mosaic:SideMenuParameterCollection>
                        <mosaic:SideMenuParameter Key="Title" Value="Debug" />
                        <mosaic:SideMenuParameter Key="XamlFile" Value="MosaicWpfDemo.LinkedSources.DebugExample.xaml" />
                        <mosaic:SideMenuParameter Key="CodeFile" Value="MosaicWpfDemo.LinkedSources.DebugExample.xaml.cs" />
                        <mosaic:SideMenuParameter Key="DocumentationType" Value="{x:Type mosaic:AdaptiveImage}" />
                        <mosaic:SideMenuParameter Key="ExampleType" Value="{x:Type example:DebugExample}" />
                        <mosaic:SideMenuParameter Key="ImageSource" Value="/Assets/bug-48.png" />
                    </mosaic:SideMenuParameterCollection>
                </mosaic:SideMenuItem.ParameterCollection>
            </mosaic:SideMenuItem>

            <!--  Dialog only: opens SampleDialog modally; menu selection stays put  -->
            <mosaic:SideMenuItem
                DialogContentType="{x:Type dialogs:SampleDialog}"
                ImageSource="/Assets/bug-48.png"
                Text="Open Dialog (modal)" />

            <!--  Content + dialog: swaps the content view AND opens the dialog (modeless)  -->
            <mosaic:SideMenuItem
                ContentType="{x:Type views:AboutView}"
                ContentTypeIsSingleton="True"
                DialogContentType="{x:Type dialogs:SampleDialog}"
                DialogIsModal="False"
                ImageSource="pack://application:,,,/Assets/collage-48.png"
                Text="About + Dialog" />

        </mosaic:SideMenu>

        <TextBlock
            Grid.Row="3"
            Margin="0,15,0,10"
            FontSize="18"
            FontWeight="Bold"
            Text="SideMenu (New Outlook Style)" />
        <Separator
            Grid.Row="4"
            Grid.ColumnSpan="2"
            Margin="0,0,0,10" />


        <mosaic:SideMenu
            Grid.Row="5"
            Grid.Column="0"
            Width="250"
            HorizontalAlignment="Left"
            HorizontalContentAlignment="Left"
            Compact="True"
            ContentPresenter="{Binding ElementName=ExampleContent2}"
            SearchBoxVisibility="Collapsed">
            <mosaic:SideMenuItem
                ContentType="{x:Type views:AboutView}"
                ContentTypeIsSingleton="True"
                ImageSource="pack://application:,,,/Assets/collage-48.png"
                Text="About" />

            <!--  Debug  -->
            <mosaic:SideMenuItem
                ContentType="{x:Type example:SideMenuExample}"
                ContentTypeIsSingleton="True"
                ImageSource="/Assets/bug-48.png"
                Text="Debug">
                <mosaic:SideMenuItem.ParameterCollection>
                    <mosaic:SideMenuParameterCollection>
                        <mosaic:SideMenuParameter Key="Title" Value="Debug" />
                        <mosaic:SideMenuParameter Key="XamlFile" Value="MosaicWpfDemo.LinkedSources.DebugExample.xaml" />
                        <mosaic:SideMenuParameter Key="CodeFile" Value="MosaicWpfDemo.LinkedSources.DebugExample.xaml.cs" />
                        <mosaic:SideMenuParameter Key="DocumentationType" Value="{x:Type mosaic:AdaptiveImage}" />
                        <mosaic:SideMenuParameter Key="ExampleType" Value="{x:Type example:DebugExample}" />
                        <mosaic:SideMenuParameter Key="ImageSource" Value="/Assets/bug-48.png" />
                    </mosaic:SideMenuParameterCollection>
                </mosaic:SideMenuItem.ParameterCollection>
            </mosaic:SideMenuItem>

        </mosaic:SideMenu>


        <ContentPresenter
            x:Name="ExampleContent"
            Grid.Row="2"
            Grid.Column="1" />

        <ContentPresenter
            x:Name="ExampleContent2"
            Grid.Row="5"
            Grid.Column="1" />

        <TextBlock
            Grid.Row="6"
            Margin="0,15,0,10"
            FontSize="18"
            FontWeight="Bold"
            Text="SideMenu (Drag-and-Drop Reordering)" />
        <Separator
            Grid.Row="7"
            Grid.ColumnSpan="2"
            Margin="0,0,0,10" />

        <!--
            Compact SideMenu with drag-and-drop reordering enabled.
            Items can be dragged to a new position. Selection requires a
            full click (mouse-up) so that mouse-down is reserved for drag.
        -->
        <mosaic:SideMenu
            Grid.Row="8"
            Grid.Column="0"
            Width="250"
            HorizontalAlignment="Left"
            HorizontalContentAlignment="Left"
            Compact="True"
            EnableDragAndDropReordering="True"
            SearchBoxVisibility="Collapsed"
            VerticalScrollViewerVisibility="Auto">
            <mosaic:SideMenuItem ImageSource="pack://application:,,,/Assets/collage-48.png" Text="Item One" />
            <mosaic:SideMenuItem ImageSource="pack://application:,,,/Assets/avatar-48.png" Text="Item Two" />
            <mosaic:SideMenuItem ImageSource="/Assets/bug-48.png" Text="Item Three" />
            <mosaic:SideMenuItem ImageSource="pack://application:,,,/Assets/collage-48.png" Text="Item Four" />
            <mosaic:SideMenuItem ImageSource="pack://application:,,,/Assets/avatar-48.png" Text="Item Five" />
        </mosaic:SideMenu>

        <StackPanel
            Grid.Row="8"
            Grid.Column="1"
            Margin="20,0,0,0"
            VerticalAlignment="Center">
            <TextBlock
                FontSize="13"
                FontWeight="SemiBold"
                Text="How it works"
                TextWrapping="Wrap" />
            <TextBlock
                Margin="0,6,0,0"
                FontSize="12"
                Opacity="0.75"
                Text="• Drag an item up or down to reorder it."
                TextWrapping="Wrap" />
            <TextBlock
                Margin="0,3,0,0"
                FontSize="12"
                Opacity="0.75"
                Text="• Click (mouse-up) to select an item."
                TextWrapping="Wrap" />
            <TextBlock
                Margin="0,3,0,0"
                FontSize="12"
                Opacity="0.75"
                Text="• Set EnableDragAndDropReordering=&quot;False&quot; (the default) to restore mouse-down selection."
                TextWrapping="Wrap" />
        </StackPanel>

    </Grid>
</UserControl>
