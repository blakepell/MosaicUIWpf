<UserControl
    x:Class="MosaicWpfDemo.Views.Examples.LoopbackWaveformVisualizerExample"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mosaic="http://schemas.apexgate.net/wpf/mosaic-ui"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <StackPanel Margin="10">
        <CheckBox
            x:Name="ListeningToggle"
            Margin="0,0,0,10"
            Content="Listen for audio"
            IsChecked="True" />

        <TextBlock
            Margin="0,0,0,6"
            FontWeight="SemiBold"
            Text="System output" />

        <mosaic:LoopbackWaveformVisualizer
            Height="180"
            Margin="0,0,0,16"
            IsListening="{Binding IsChecked, ElementName=ListeningToggle}"
            OnError="InputVisualizer_OnOnError" />

        <TextBlock
            Margin="0,0,0,6"
            FontWeight="SemiBold"
            Text="Audio input" />

        <ComboBox
            Margin="0,0,0,10"
            DisplayMemberPath="Name"
            ItemsSource="{Binding InputDevices, ElementName=InputVisualizer}"
            SelectedItem="{Binding SelectedInputDevice, ElementName=InputVisualizer, Mode=TwoWay}" />

        <mosaic:InputWaveformVisualizer
            x:Name="InputVisualizer"
            Height="180"
            IsListening="{Binding IsChecked, ElementName=ListeningToggle}"
            OnError="InputVisualizer_OnOnError" />
    </StackPanel>
</UserControl>
