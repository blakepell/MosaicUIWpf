<UserControl
    x:Class="MosaicWpfDemo.Views.Examples.TagBoxExample"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Mosaic.UI.Wpf.Controls;assembly=Mosaic.UI.Wpf"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MosaicWpfDemo.Views.Examples"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:themes="clr-namespace:Mosaic.UI.Wpf.Themes;assembly=Mosaic.UI.Wpf"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <StackPanel Orientation="Vertical">

        <TextBlock
            MaxWidth="560"
            HorizontalAlignment="Left"
            Foreground="{DynamicResource {x:Static themes:MosaicTheme.ControlTextForegroundBrush}}"
            Text="Type a value and press Enter to create a tag. Click the &#x2715; on a tag (or press Backspace with the caret just to the right of the tags) to remove it. The tags are bound to an ObservableCollection&lt;string&gt;."
            TextWrapping="Wrap" />

        <!--  Bound tag editor  -->
        <controls:TagBox
            x:Name="DemoTagBox"
            Width="560"
            Margin="0,14,0,0"
            HorizontalAlignment="Left"
            TagCornerRadius="3"
            Tags="{Binding Tags}"
            TagChanged="DemoTagBox_TagChanged"
            TagChanging="DemoTagBox_TagChanging"
            Watermark="Add a tag and press Enter..." />

        <StackPanel
            Margin="0,10,0,0"
            Orientation="Horizontal">
            <CheckBox
                VerticalAlignment="Center"
                Content="Allow duplicates"
                Foreground="{DynamicResource {x:Static themes:MosaicTheme.ControlTextForegroundBrush}}"
                IsChecked="{Binding AllowDuplicates, ElementName=DemoTagBox}" />
            <TextBlock
                Margin="24,0,0,0"
                VerticalAlignment="Center"
                Foreground="{DynamicResource {x:Static themes:MosaicTheme.ControlTextSecondaryForegroundBrush}}"
                Text="Tip: try adding a tag named &quot;blocked&quot; — TagChanging vetoes it." />
        </StackPanel>

        <!--  Event log demonstrating TagChanging / TagChanged  -->
        <TextBlock
            Margin="0,18,0,0"
            FontWeight="Bold"
            Foreground="{DynamicResource {x:Static themes:MosaicTheme.ControlTextForegroundBrush}}"
            Text="Event log" />
        <ListBox
            x:Name="LogList"
            Width="560"
            Height="180"
            Margin="0,4,0,0"
            HorizontalAlignment="Left"
            ItemsSource="{Binding EventLog}" />
    </StackPanel>
</UserControl>
