<UserControl
    x:Class="MosaicWpfDemo.Views.Examples.KitchenSinkExample"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mosaic="clr-namespace:Mosaic.UI.Wpf.Controls;assembly=Mosaic.UI.Wpf"
    xmlns:themes="http://schemas.apexgate.net/wpf/mosaic-ui"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <mosaic:TabControl
            Grid.Row="0"
            Margin="0,10,0,0"
            ActiveIndicatorPlacement="Bottom"
            EnableDragAndDropReordering="True">
            <mosaic:TabItem Header="Property Grid">
                <Grid Width="{Binding Path=ActualWidth, RelativeSource={RelativeSource FindAncestor, AncestorType=Grid}}" Height="{Binding Path=ActualHeight, RelativeSource={RelativeSource FindAncestor, AncestorType=Grid}}">
                    <mosaic:PropertyGrid Margin="8" Object="{Binding}" />
                </Grid>
            </mosaic:TabItem>

            <mosaic:TabItem Header="Menu">
                <StackPanel Orientation="Vertical">
                    <Menu Margin="2">
                        <MenuItem Header="_File">
                            <MenuItem Header="New">
                                <MenuItem Header="Text File" />
                                <MenuItem Header="Markdown File" />
                            </MenuItem>
                            <Separator />
                            <MenuItem Header="E_xit" />
                        </MenuItem>
                        <MenuItem Header="_Action" />
                    </Menu>

                    <TextBlock
                        Margin="0,4,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Text="Right-click me">
                        <TextBlock.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Open" />
                                <MenuItem Header="Save" />
                                <Separator />
                                <MenuItem Header="Exit" />
                            </ContextMenu>
                        </TextBlock.ContextMenu>
                    </TextBlock>
                </StackPanel>
            </mosaic:TabItem>

            <mosaic:TabItem Header="Other Controls">
                <StackPanel
                    Margin="8"
                    VerticalAlignment="Top"
                    Orientation="Vertical">

                    <TextBlock
                        Margin="0,0,0,8"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="Kitchen Sink Example page" />
                    <!--  Blank example surface: add controls here  -->
                    <Border
                        Width="500"
                        MinHeight="300"
                        Padding="6"
                        Background="{DynamicResource {x:Static themes:MosaicTheme.ControlBackgroundBrush}}"
                        BorderBrush="{DynamicResource {x:Static themes:MosaicTheme.ControlBorderBrush}}"
                        BorderThickness="1"
                        CornerRadius="4">
                        <StackPanel Orientation="Vertical">
                            <StackPanel Orientation="Vertical">
                                <TextBlock Margin="0,0,0,0" Text="Username:" />
                                <TextBox
                                    Width="250"
                                    Margin="0,4,0,0"
                                    HorizontalAlignment="Left"
                                    Text="{Binding Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Orientation="Vertical">
                                <TextBlock Margin="0,0,0,0" Text="Account Type:" />
                                <ComboBox>
                                    <ComboBoxItem>User</ComboBoxItem>
                                    <ComboBoxItem>Admin</ComboBoxItem>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Orientation="Vertical">
                                <TextBlock Margin="0,0,0,0" Text="Enter username:" />
                                <ComboBox IsEditable="True">
                                    <ComboBoxItem>bpell</ComboBoxItem>
                                    <ComboBoxItem>isaac</ComboBoxItem>
                                    <ComboBoxItem>lucy</ComboBoxItem>
                                </ComboBox>
                            </StackPanel>

                            <mosaic:ToggleButton Margin="0,6,0,0" />

                            <CheckBox Margin="4,2,0,0">
                                <TextBlock Text="Enabled" />
                            </CheckBox>

                            <DatePicker />

                        </StackPanel>
                    </Border>
                </StackPanel>
            </mosaic:TabItem>
            <mosaic:TabItem Header="ContentPanel">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <mosaic:ContentPanel
                        Title="Example"
                        Grid.Row="0"
                        MinWidth="400"
                        Margin="12">
                        <TextBlock Text="This is a test" />
                        <mosaic:ContentPanel.FooterContent>
                            <StackPanel Orientation="Vertical">
                                <TextBlock Text="Footer" />
                            </StackPanel>
                        </mosaic:ContentPanel.FooterContent>
                    </mosaic:ContentPanel>

                    <mosaic:ContentPanel
                        Grid.Row="1"
                        MinWidth="400"
                        Margin="12"
                        HeaderVisibility="Collapsed">
                        <TextBlock Text="This is a test" />
                        <mosaic:ContentPanel.FooterContent>
                            <StackPanel Orientation="Vertical">
                                <TextBlock Text="Footer" />
                            </StackPanel>
                        </mosaic:ContentPanel.FooterContent>
                    </mosaic:ContentPanel>

                    <mosaic:ContentPanel
                        Grid.Row="2"
                        MinWidth="400"
                        Margin="12"
                        CornerRadius="0"
                        HeaderVisibility="Collapsed">
                        <TextBlock Text="This is a test" />
                        <mosaic:ContentPanel.FooterContent>
                            <StackPanel Orientation="Vertical">
                                <TextBlock Text="Footer" />
                            </StackPanel>
                        </mosaic:ContentPanel.FooterContent>
                    </mosaic:ContentPanel>

                </Grid>
            </mosaic:TabItem>
        </mosaic:TabControl>
    </Grid>
</UserControl>