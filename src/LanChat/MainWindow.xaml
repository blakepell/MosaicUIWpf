<Window
    x:Class="LanChat.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mosaic="clr-namespace:Mosaic.UI.Wpf.Controls;assembly=Mosaic.UI.Wpf"
    xmlns:theme="http://schemas.apexgate.net/wpf/mosaic-ui"
    xmlns:views="clr-namespace:LanChat.Views"
    Title="LanChat"
    Width="1000"
    Height="600"
    Background="{DynamicResource {x:Static theme:MosaicTheme.WindowBackgroundBrush}}"
    Foreground="{DynamicResource {x:Static theme:MosaicTheme.WindowForegroundBrush}}"
    Icon="/Assets/collage-48.png"
    Loaded="MainWindow_OnLoaded"
    theme:WindowChromeBehavior.CaptionHeight="0"
    theme:WindowChromeBehavior.CornerRadius="10"
    theme:WindowChromeBehavior.GlassFrameThickness="0"
    theme:WindowChromeBehavior.IsEnabled="True"
    theme:WindowChromeBehavior.ResizeBorderThickness="5"
    theme:WindowChromeBehavior.UseAeroCaptionButtons="True"
    WindowStartupLocation="CenterScreen">

    <Grid HorizontalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="35" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="74" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  Title Bar  -->
        <mosaic:WindowTitleBar
            Grid.Row="0"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            IconSource="/Assets/collage-48.png">
            <mosaic:WindowTitleBar.RightContent>
                <Button
                    Width="48"
                    Click="ButtonToggleTheme_OnClick"
                    Style="{DynamicResource {x:Static theme:MosaicTheme.WindowTitleBarButtonStyle}}"
                    ToolTip="Toggle Theme">
                    <Button.ContentTemplate>
                        <DataTemplate>
                            <Viewbox Width="16" Height="16">
                                <Canvas Width="512" Height="512">
                                    <Path
                                        Data="M8 256c0 137 111 248 248 248s248-111 248-248S393 8 256 8 8 119 8 256zm248 184V72c101.7 0 184 82.3 184 184 0 101.7-82.3 184-184 184z"
                                        Fill="{DynamicResource {x:Static theme:MosaicTheme.WindowForegroundBrush}}" />
                                </Canvas>
                            </Viewbox>
                        </DataTemplate>
                    </Button.ContentTemplate>
                </Button>
            </mosaic:WindowTitleBar.RightContent>
        </mosaic:WindowTitleBar>

        <mosaic:SideMenu
            x:Name="TestSideMenu"
            Grid.Row="1"
            Grid.Column="0"
            Margin="5"
            Compact="True"
            SearchBoxVisibility="Collapsed"
            ContentPresenter="{Binding ElementName=MainContent}">
            <mosaic:SideMenu.MenuItems>
                <mosaic:SideMenuItem
                    ContentType="{x:Type views:ChatView}"
                    ContentTypeIsSingleton="True"
                    ImageSource="pack://application:,,,/Assets/chat-48.png"
                    Text="Chat" />

                <mosaic:SideMenuItem
                    ContentType="{x:Type views:ChatServerView}"
                    ContentTypeIsSingleton="True"
                    ImageSource="pack://application:,,,/Assets/server-add-48.png"
                    Text="Server" />

                <mosaic:SideMenuItem
                    ContentType="{x:Type views:AboutView}"
                    ContentTypeIsSingleton="True"
                    ImageSource="pack://application:,,,/Assets/collage-48.png"
                    Text="About" />

                <mosaic:SideMenuItem
                    ContentType="{x:Type views:SettingsView}"
                    ContentTypeIsSingleton="True"
                    ImageSource="pack://application:,,,/Assets/settings-48.png"
                    Text="Settings" />

            </mosaic:SideMenu.MenuItems>
        </mosaic:SideMenu>

        <ContentPresenter
            x:Name="MainContent"
            Grid.Row="1"
            Grid.Column="1" />

        <StatusBar
            Grid.Row="2"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Height="25"
            Background="{DynamicResource {x:Static theme:MosaicTheme.ControlTextBackgroundBrush}}"
            BorderBrush="{DynamicResource {x:Static theme:MosaicTheme.ControlBorderBrush}}"
            BorderThickness="0,.9,0,0"
            FocusManager.IsFocusScope="True"
            Foreground="{DynamicResource {x:Static theme:MosaicTheme.ControlTextForegroundBrush}}">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>

            <StatusBarItem Grid.Column="0" Padding="10,0,5,0">
                <TextBlock Margin="0,0,0,0" Text="{Binding StatusText}" />
            </StatusBarItem>
            <StatusBarItem Grid.Column="1" />
            <StatusBarItem Grid.Column="2" />
            <StatusBarItem Grid.Column="3">
                <mosaic:Shield
                    Label="Lan IP Address:"
                    ValueBackgroundBrush="#03467A"
                    ValueForegroundBrush="White"
                    Value="{Binding LanIpAddress, FallbackValue='127.0.0.1'}" />
            </StatusBarItem>
            <StatusBarItem Grid.Column="4">
                <mosaic:Shield
                    Label="Chat:"
                    ValueBackgroundBrush="{Binding ChatClient.IsConnected, FallbackValue='#901336', Converter={x:Static theme:BoolToBrushConverter.Instance}, ConverterParameter='#0D5F33,#901336'}"
                    Value="{Binding ChatClient.IsConnected, FallbackValue='Not Connected', Converter={x:Static theme:BoolToLabelConverter.Instance}, ConverterParameter='Connected,Not Connected'}" />
            </StatusBarItem>
            <StatusBarItem Grid.Column="5">
                <mosaic:Shield
                    Label="Server:"
                    ValueBackgroundBrush="{Binding ChatServer.IsListening, FallbackValue='#901336', Converter={x:Static theme:BoolToBrushConverter.Instance}, ConverterParameter='#0D5F33,#901336'}"
                    Value="{Binding ChatServer.IsListening, FallbackValue='Off', Converter={x:Static theme:BoolToLabelConverter.Instance}, ConverterParameter='On,Off'}" />
            </StatusBarItem>
            <!--<Separator Grid.Column="6" Background="{DynamicResource {x:Static themes:MosaicTheme.ControlBorderBrush}}" />-->
            <StatusBarItem Grid.Column="6">
                <mosaic:Shield
                    Margin="0,0,6,0"
                    Label="Server Connected Users:"
                    ValueBackgroundBrush="#03467A"
                    Visibility="{Binding ChatServer.IsListening, Converter={x:Static theme:BoolToVisibilityConverter.Instance}}"
                    Value="{Binding UsersConnected}" />
            </StatusBarItem>

        </StatusBar>
    </Grid>
</Window>
