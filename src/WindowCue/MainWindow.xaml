<Window
    x:Class="WindowCue.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mosaic="clr-namespace:Mosaic.UI.Wpf.Controls;assembly=Mosaic.UI.Wpf"
    xmlns:theme="http://schemas.apexgate.net/wpf/mosaic-ui"
    xmlns:themeNs="clr-namespace:Mosaic.UI.Wpf.Themes;assembly=Mosaic.UI.Wpf"
    Title="WindowCue"
    Width="72"
    MinWidth="64"
    MaxWidth="120"
    theme:WindowChromeBehavior.CaptionHeight="0"
    theme:WindowChromeBehavior.CornerRadius="10"
    theme:WindowChromeBehavior.GlassFrameThickness="0"
    theme:WindowChromeBehavior.IsEnabled="True"
    theme:WindowChromeBehavior.ResizeBorderThickness="5"
    theme:WindowChromeBehavior.UseAeroCaptionButtons="True"
    Background="{DynamicResource {x:Static themeNs:MosaicTheme.WindowBackgroundBrush}}"
    Foreground="{DynamicResource {x:Static themeNs:MosaicTheme.WindowForegroundBrush}}"
    Loaded="MainWindow_OnLoaded"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Topmost="True"
    WindowStyle="None">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="38" />
            <RowDefinition Height="*" />
            <RowDefinition Height="50" />
        </Grid.RowDefinitions>

        <!--  Title Bar  -->
        <mosaic:WindowTitleBar
            Grid.Row="0"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            IconSource="/Assets/app.png">
            <mosaic:WindowTitleBar.RightContent>
                <StackPanel Orientation="Horizontal">
                    <Button
                        Width="48"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="SettingsButton_Click"
                        Cursor="Hand"
                        Style="{DynamicResource {x:Static themeNs:MosaicTheme.WindowTitleBarButtonStyle}}"
                        ToolTip="Dock options">
                        <TextBlock FontSize="14" Text="⋮" />
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Dock" Tag="Dock">
                                    <MenuItem
                                        Click="DockMenuItem_Click"
                                        Header="Dock → Left"
                                        Tag="Left" />
                                    <MenuItem
                                        Click="DockMenuItem_Click"
                                        Header="Dock → Right"
                                        Tag="Right" />
                                    <MenuItem
                                        Click="DockMenuItem_Click"
                                        Header="Dock → Top"
                                        Tag="Top" />
                                    <MenuItem
                                        Click="DockMenuItem_Click"
                                        Header="Dock → Bottom"
                                        Tag="Bottom" />
                                </MenuItem>
                                <Separator />
                                <MenuItem Click="Settings_Click" Header="Settings" />
                                <MenuItem Click="ToggleTheme_Click" Header="Toggle Theme" />
                                <Separator />
                                <MenuItem Click="RemoveAll_Click" Header="Remove All" />
                                <MenuItem Click="RemoveInactive_Click" Header="Remove Inactive" />
                                <Separator />
                                <MenuItem Click="Exit_Click" Header="Exit" />
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>

                    <Button
                        Width="48"
                        Click="ToggleTheme_Click"
                        Style="{DynamicResource {x:Static themeNs:MosaicTheme.WindowTitleBarButtonStyle}}"
                        ToolTip="Toggle Theme">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <Viewbox Width="16" Height="16">
                                    <Canvas Width="512" Height="512">
                                        <Path
                                            Data="M8 256c0 137 111 248 248 248s248-111 248-248S393 8 256 8 8 119 8 256zm248 184V72c101.7 0 184 82.3 184 184 0 101.7-82.3 184-184 184z"
                                            Fill="{DynamicResource {x:Static themeNs:MosaicTheme.WindowForegroundBrush}}" />
                                    </Canvas>
                                </Viewbox>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                </StackPanel>
            </mosaic:WindowTitleBar.RightContent>
        </mosaic:WindowTitleBar>

        <!--  ══ Pinned items via SideMenu compact ══  -->
        <Grid Grid.Row="1">
            <mosaic:SideMenu
                x:Name="ToolbarMenu"
                Compact="True"
                EnableDragAndDropReordering="True"
                ItemClicked="ToolbarMenu_ItemClicked"
                MouseRightButtonDown="ToolbarMenu_MouseRightButtonDown"
                SearchBoxVisibility="Collapsed"
                VerticalScrollViewerVisibility="Auto" />

            <!--  Loading overlay — visible while pinned items are being restored  -->
            <ProgressBar
                Height="3"
                VerticalAlignment="Top"
                IsIndeterminate="True"
                Visibility="{Binding IsRestoringPinnedItems, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </Grid>

        <!--  ══ Add button ══  -->
        <Button
            x:Name="AddButton"
            Grid.Row="2"
            Width="40"
            Height="40"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="Transparent"
            BorderBrush="{DynamicResource {x:Static themeNs:MosaicTheme.ControlBorderBrush}}"
            BorderThickness="1"
            Click="AddButton_Click"
            Content="+"
            Cursor="Hand"
            FontSize="22"
            FontWeight="Light"
            Foreground="{DynamicResource {x:Static themeNs:MosaicTheme.ControlForegroundBrush}}"
            ToolTip="Pin a running window">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border
                                    x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource {x:Static themeNs:MosaicTheme.SidebarSelectedBackgroundBrush}}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Style>
        </Button>
    </Grid>
</Window>
