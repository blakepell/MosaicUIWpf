<Window
    x:Class="WindowCue.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mosaic="clr-namespace:Mosaic.UI.Wpf.Controls;assembly=Mosaic.UI.Wpf"
    xmlns:theme="http://schemas.apexgate.net/wpf/mosaic-ui"
    xmlns:themeNs="clr-namespace:Mosaic.UI.Wpf.Themes;assembly=Mosaic.UI.Wpf"
    Title="WindowCue"
    Width="72"
    MinWidth="64"
    MaxWidth="120"
    theme:WindowChromeBehavior.CaptionHeight="0"
    theme:WindowChromeBehavior.CornerRadius="8"
    theme:WindowChromeBehavior.GlassFrameThickness="0"
    theme:WindowChromeBehavior.IsEnabled="True"
    theme:WindowChromeBehavior.ResizeBorderThickness="0"
    theme:WindowChromeBehavior.UseAeroCaptionButtons="False"
    Background="{DynamicResource {x:Static themeNs:MosaicTheme.WindowBackgroundBrush}}"
    Foreground="{DynamicResource {x:Static themeNs:MosaicTheme.WindowForegroundBrush}}"
    Loaded="MainWindow_OnLoaded"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Topmost="True"
    WindowStyle="None">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="38" />
            <RowDefinition Height="*" />
            <RowDefinition Height="50" />
        </Grid.RowDefinitions>

        <!--  ══ Drag handle / header ══  -->
        <Border
            Grid.Row="0"
            Background="{DynamicResource {x:Static themeNs:MosaicTheme.WindowBackgroundBrush}}"
            Cursor="SizeAll"
            MouseLeftButtonDown="DragArea_MouseLeftButtonDown">
            <Grid>
                <!--  Grip dots  -->
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="16"
                    Foreground="{DynamicResource {x:Static themeNs:MosaicTheme.WindowForegroundBrush}}"
                    Opacity="0.45"
                    Text="⠿" />

                <!--  Settings context button (top-right)  -->
                <Button
                    x:Name="SettingsButton"
                    Width="20"
                    Height="20"
                    Margin="0,0,4,0"
                    Padding="0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="SettingsButton_Click"
                    Cursor="Hand"
                    Foreground="{DynamicResource {x:Static themeNs:MosaicTheme.WindowForegroundBrush}}"
                    Opacity="0.55"
                    ToolTip="Dock options">
                    <TextBlock FontSize="14" Text="⋮" />
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem
                                Click="DockMenuItem_Click"
                                Header="Dock → Left"
                                Tag="Left" />
                            <MenuItem
                                Click="DockMenuItem_Click"
                                Header="Dock → Right"
                                Tag="Right" />
                            <MenuItem
                                Click="DockMenuItem_Click"
                                Header="Dock → Top"
                                Tag="Top" />
                            <MenuItem
                                Click="DockMenuItem_Click"
                                Header="Dock → Bottom"
                                Tag="Bottom" />
                            <Separator />
                            <MenuItem Click="ToggleTheme_Click" Header="Toggle Theme" />
                            <Separator />
                            <MenuItem Click="RemoveAll_Click" Header="Remove All" />
                            <Separator />
                            <MenuItem Click="Exit_Click" Header="Exit" />
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
            </Grid>
        </Border>

        <!--  ══ Pinned items via SideMenu compact ══  -->
        <mosaic:SideMenu
            x:Name="ToolbarMenu"
            Grid.Row="1"
            Compact="True"
            ItemClicked="ToolbarMenu_ItemClicked"
            MouseRightButtonDown="ToolbarMenu_MouseRightButtonDown"
            SearchBoxVisibility="Collapsed"
            VerticalScrollViewerVisibility="Auto" />

        <!--  ══ Add button ══  -->
        <Button
            x:Name="AddButton"
            Grid.Row="2"
            Width="40"
            Height="40"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="Transparent"
            BorderBrush="{DynamicResource {x:Static themeNs:MosaicTheme.ControlBorderBrush}}"
            BorderThickness="1"
            Click="AddButton_Click"
            Content="+"
            Cursor="Hand"
            FontSize="22"
            FontWeight="Light"
            Foreground="{DynamicResource {x:Static themeNs:MosaicTheme.ControlForegroundBrush}}"
            ToolTip="Pin a running window">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border
                                    x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource {x:Static themeNs:MosaicTheme.SidebarSelectedBackgroundBrush}}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Style>
        </Button>
    </Grid>
</Window>
