<Window
    x:Class="WindowCue.Views.SelectWindowDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mosaic="http://schemas.apexgate.net/wpf/mosaic-ui"
    xmlns:controls="http://schemas.apexgate.net/wpf/mosaic"
    xmlns:theme="clr-namespace:Mosaic.UI.Wpf.Themes;assembly=Mosaic.UI.Wpf"
    xmlns:vm="clr-namespace:WindowCue.ViewModels"
    Title="Add Window or Tab — WindowCue"
    Width="530"
    Height="450"
    controls:WindowChromeBehavior.CaptionHeight="0"
    controls:WindowChromeBehavior.CornerRadius="10"
    controls:WindowChromeBehavior.GlassFrameThickness="0"
    controls:WindowChromeBehavior.IsEnabled="True"
    controls:WindowChromeBehavior.ResizeBorderThickness="5"
    controls:WindowChromeBehavior.UseAeroCaptionButtons="True"    
    Background="{DynamicResource {x:Static theme:MosaicTheme.WindowBackgroundBrush}}"
    Foreground="{DynamicResource {x:Static theme:MosaicTheme.WindowForegroundBrush}}"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterScreen">

    <Grid Margin="0,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="35" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="*" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Title Bar  -->
        <controls:WindowTitleBar
            Grid.Row="0"
            IconSource="/Assets/app.png"
            ShowMaxRestoreButton="False"
            ShowMinimizeButton="False" />
        
        <!--  Search box  -->
        <mosaic:SearchBox
            x:Name="SearchBox"
            Grid.Row="1"
            Padding="6,4"
            Margin="8,0,8,0"
            Background="{DynamicResource {x:Static theme:MosaicTheme.ControlBackgroundBrush}}"
            BorderBrush="{DynamicResource {x:Static theme:MosaicTheme.ControlBorderBrush}}"
            FontSize="14"
            Foreground="{DynamicResource {x:Static theme:MosaicTheme.ControlForegroundBrush}}"
            Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

        <!--  Running windows + Edge tabs list  -->
        <Grid Grid.Row="3">
            <ListBox
                x:Name="WindowList"
                Margin="8,0,8,0"
                Background="{DynamicResource {x:Static theme:MosaicTheme.ControlBackgroundBrush}}"
                BorderBrush="{DynamicResource {x:Static theme:MosaicTheme.ControlBorderBrush}}"
                ItemsSource="{Binding FilteredWindows}"
                MouseDoubleClick="WindowList_MouseDoubleClick"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                SelectionMode="Extended"
                Visibility="{Binding IsLoading, Converter={mosaic:InvertedBoolToVisibilityConverter}}">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="4,3" />
                        <Setter Property="Foreground" Value="{DynamicResource {x:Static theme:MosaicTheme.ControlForegroundBrush}}" />
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource {x:Static theme:MosaicTheme.SidebarSelectedBackgroundBrush}}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource {x:Static theme:MosaicTheme.SidebarSelectedBackgroundBrush}}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:RunningWindowViewModel}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!--  Icon  -->
                            <Image
                                Grid.Column="0"
                                Width="28"
                                Height="28"
                                Margin="2"
                                RenderOptions.BitmapScalingMode="HighQuality"
                                Source="{Binding Icon}" />

                            <!--  Title + subtitle (process name or "Edge Tab")  -->
                            <StackPanel
                                Grid.Column="1"
                                Margin="4,0,0,0"
                                VerticalAlignment="Center">
                                <TextBlock
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource {x:Static theme:MosaicTheme.ControlForegroundBrush}}"
                                    Text="{Binding Title}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    FontSize="11"
                                    Foreground="{DynamicResource {x:Static theme:MosaicTheme.ControlTextSecondaryForegroundBrush}}"
                                    Text="{Binding DisplaySubtitle}"
                                    TextTrimming="CharacterEllipsis">
                                    <TextBlock.ToolTip>
                                        <ToolTip Content="{Binding ExecutablePath}" />
                                    </TextBlock.ToolTip>
                                </TextBlock>
                            </StackPanel>

                            <!--  "Tab" badge shown only for browser-tab items  -->
                            <Border
                                Grid.Column="2"
                                Margin="6,0,2,0"
                                Padding="5,2"
                                VerticalAlignment="Center"
                                Background="{DynamicResource {x:Static theme:MosaicTheme.AccentBrush}}"
                                CornerRadius="3"
                                Visibility="{Binding IsEdgeTab, Converter={mosaic:BoolToVisibilityConverter}}">
                                <TextBlock
                                    FontSize="10"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    Text="TAB" />
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!--  Loading overlay — covers the list area while enumeration is running  -->
            <Border
                Background="{DynamicResource {x:Static theme:MosaicTheme.ControlBackgroundBrush}}"
                BorderBrush="{DynamicResource {x:Static theme:MosaicTheme.ControlBorderBrush}}"
                BorderThickness="1"
                Visibility="{Binding IsLoading, Converter={mosaic:BoolToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar
                        Width="220"
                        Height="4"
                        IsIndeterminate="True" />
                    <TextBlock
                        Margin="0,10,0,0"
                        HorizontalAlignment="Center"
                        FontSize="12"
                        Foreground="{DynamicResource {x:Static theme:MosaicTheme.ControlTextSecondaryForegroundBrush}}"
                        Text="Loading windows and tabs…" />
                </StackPanel>
            </Border>
        </Grid>

        <!--  Buttons  -->
        <StackPanel
            Grid.Row="5"
            Margin="0,0,8,8"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                x:Name="ConfirmButton"
                Width="80"
                Height="30"
                Margin="0,0,8,0"
                Background="{DynamicResource {x:Static theme:MosaicTheme.AccentBrush}}"
                Click="ConfirmButton_Click"
                Content="Add"
                Foreground="White"
                IsDefault="True" />
            <Button
                Width="80"
                Height="30"
                Background="{DynamicResource {x:Static theme:MosaicTheme.ControlBackgroundBrush}}"
                BorderBrush="{DynamicResource {x:Static theme:MosaicTheme.ControlBorderBrush}}"
                Click="CancelButton_Click"
                Content="Cancel"
                Foreground="{DynamicResource {x:Static theme:MosaicTheme.ControlForegroundBrush}}"
                IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
