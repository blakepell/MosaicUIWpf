<Window
    x:Class="WindowCue.Views.SelectWindowDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mosaic="http://schemas.apexgate.net/wpf/mosaic-ui"
    xmlns:theme="clr-namespace:Mosaic.UI.Wpf.Themes;assembly=Mosaic.UI.Wpf"
    xmlns:vm="clr-namespace:WindowCue.ViewModels"
    Title="Add Window — WindowCue"
    Width="520"
    Height="440"
    MinWidth="400"
    MinHeight="300"
    Background="{DynamicResource {x:Static theme:MosaicTheme.WindowBackgroundBrush}}"
    Foreground="{DynamicResource {x:Static theme:MosaicTheme.WindowForegroundBrush}}"
    ResizeMode="CanResize"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="*" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Search box -->
        <TextBox
            Grid.Row="0"
            x:Name="SearchBox"
            FontSize="14"
            Padding="6,4"
            Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
            BorderBrush="{DynamicResource {x:Static theme:MosaicTheme.ControlBorderBrush}}"
            Background="{DynamicResource {x:Static theme:MosaicTheme.ControlBackgroundBrush}}"
            Foreground="{DynamicResource {x:Static theme:MosaicTheme.ControlForegroundBrush}}">
            <TextBox.Style>
                <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                    <Style.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4" />
                        </Style>
                    </Style.Resources>
                </Style>
            </TextBox.Style>
        </TextBox>

        <!-- Running windows list -->
        <ListBox
            Grid.Row="2"
            x:Name="WindowList"
            ItemsSource="{Binding FilteredWindows}"
            SelectedItem="{Binding SelectedWindow, Mode=TwoWay}"
            Background="{DynamicResource {x:Static theme:MosaicTheme.ControlBackgroundBrush}}"
            BorderBrush="{DynamicResource {x:Static theme:MosaicTheme.ControlBorderBrush}}"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
            MouseDoubleClick="WindowList_MouseDoubleClick">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="4,3" />
                    <Setter Property="Foreground" Value="{DynamicResource {x:Static theme:MosaicTheme.ControlForegroundBrush}}" />
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource {x:Static theme:MosaicTheme.SidebarSelectedBackgroundBrush}}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource {x:Static theme:MosaicTheme.SidebarSelectedBackgroundBrush}}" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:RunningWindowViewModel}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Icon -->
                        <Image
                            Grid.Column="0"
                            Width="28"
                            Height="28"
                            Margin="2"
                            Source="{Binding Icon}"
                            RenderOptions.BitmapScalingMode="HighQuality" />

                        <!-- Title + process name -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="4,0,0,0">
                            <TextBlock
                                Text="{Binding Title}"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource {x:Static theme:MosaicTheme.ControlForegroundBrush}}"
                                TextTrimming="CharacterEllipsis" />
                            <TextBlock
                                Text="{Binding ProcessName}"
                                FontSize="11"
                                Foreground="{DynamicResource {x:Static theme:MosaicTheme.ControlTextSecondaryForegroundBrush}}"
                                TextTrimming="CharacterEllipsis">
                                <TextBlock.ToolTip>
                                    <ToolTip Content="{Binding ExecutablePath}" />
                                </TextBlock.ToolTip>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Buttons -->
        <StackPanel
            Grid.Row="4"
            Orientation="Horizontal"
            HorizontalAlignment="Right">
            <Button
                Content="Add"
                Width="80"
                Height="30"
                Margin="0,0,8,0"
                IsDefault="True"
                Command="{Binding ConfirmCommand}"
                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                Background="{DynamicResource {x:Static theme:MosaicTheme.AccentBrush}}"
                Foreground="White" />
            <Button
                Content="Cancel"
                Width="80"
                Height="30"
                IsCancel="True"
                Click="CancelButton_Click"
                Background="{DynamicResource {x:Static theme:MosaicTheme.ControlBackgroundBrush}}"
                Foreground="{DynamicResource {x:Static theme:MosaicTheme.ControlForegroundBrush}}"
                BorderBrush="{DynamicResource {x:Static theme:MosaicTheme.ControlBorderBrush}}" />
        </StackPanel>
    </Grid>
</Window>
