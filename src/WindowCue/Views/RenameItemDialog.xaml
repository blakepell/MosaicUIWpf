<Window
    x:Class="WindowCue.Views.RenameItemDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="http://schemas.apexgate.net/wpf/mosaic"
    xmlns:theme="clr-namespace:Mosaic.UI.Wpf.Themes;assembly=Mosaic.UI.Wpf"
    Title="Rename Item"
    Width="400"
    Height="140"
    controls:WindowChromeBehavior.CaptionHeight="0"
    controls:WindowChromeBehavior.CornerRadius="10"
    controls:WindowChromeBehavior.GlassFrameThickness="0"
    controls:WindowChromeBehavior.IsEnabled="True"
    controls:WindowChromeBehavior.ResizeBorderThickness="5"
    controls:WindowChromeBehavior.UseAeroCaptionButtons="True"
    Background="{DynamicResource {x:Static theme:MosaicTheme.WindowBackgroundBrush}}"
    Foreground="{DynamicResource {x:Static theme:MosaicTheme.WindowForegroundBrush}}"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="35" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Title Bar  -->
        <controls:WindowTitleBar
            Grid.Row="0"
            IconSource="/Assets/app.png"
            ShowMaxRestoreButton="False"
            ShowMinimizeButton="False" />

        <TextBlock
            Grid.Row="1"
            Margin="14,0,14,0"
            Foreground="{DynamicResource {x:Static theme:MosaicTheme.ControlForegroundBrush}}"
            Text="Enter a new label for this item:" />

        <TextBox
            x:Name="LabelTextBox"
            Grid.Row="3"
            Margin="14,0,14,0"
            Padding="5,3"
            Background="{DynamicResource {x:Static theme:MosaicTheme.ControlBackgroundBrush}}"
            BorderBrush="{DynamicResource {x:Static theme:MosaicTheme.ControlBorderBrush}}"
            FontSize="14"
            Foreground="{DynamicResource {x:Static theme:MosaicTheme.ControlForegroundBrush}}"
            KeyDown="LabelTextBox_KeyDown"
            Text="{Binding NewLabel, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" />

        <StackPanel
            Grid.Row="5"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Width="72"
                Height="28"
                Margin="0,0,8,0"
                Background="{DynamicResource {x:Static theme:MosaicTheme.AccentBrush}}"
                Click="OkButton_Click"
                Content="OK"
                Foreground="White"
                IsDefault="True" />
            <Button
                Width="72"
                Height="28"
                Margin="0,0,14,0"
                Background="{DynamicResource {x:Static theme:MosaicTheme.ControlBackgroundBrush}}"
                BorderBrush="{DynamicResource {x:Static theme:MosaicTheme.ControlBorderBrush}}"
                Click="CancelButton_Click"
                Content="Cancel"
                Foreground="{DynamicResource {x:Static theme:MosaicTheme.ControlForegroundBrush}}"
                IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
