<UserControl
    x:Class="ChromaSwap.Dialogs.SwapColorsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mosaic="clr-namespace:Mosaic.UI.Wpf.Controls;assembly=Mosaic.UI.Wpf"
    xmlns:theme="http://schemas.apexgate.net/wpf/mosaic-ui"
    Width="380">
    <StackPanel>

        <!--  From / To color row  -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock
                    Margin="0,0,0,6"
                    FontSize="{DynamicResource {x:Static theme:MosaicTheme.FontSizeSmall}}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource {x:Static theme:MosaicTheme.ControlTextSecondaryForegroundBrush}}"
                    Text="FROM" />
                <Border
                    Padding="8"
                    Background="{DynamicResource {x:Static theme:MosaicTheme.ControlBackgroundLightBrush}}"
                    BorderBrush="{DynamicResource {x:Static theme:MosaicTheme.ControlBorderBrush}}"
                    BorderThickness="1"
                    CornerRadius="6">
                    <StackPanel Orientation="Horizontal">
                        <Border
                            x:Name="FromSwatch"
                            Width="28"
                            Height="28"
                            BorderBrush="{DynamicResource {x:Static theme:MosaicTheme.ControlBorderBrush}}"
                            BorderThickness="1"
                            CornerRadius="4" />
                        <TextBlock
                            x:Name="FromHexText"
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            FontFamily="{DynamicResource {x:Static theme:MosaicTheme.MonospaceFontFamily}}"
                            Text="#FFFFFF" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <TextBlock
                Grid.Column="1"
                Margin="10,22,10,0"
                VerticalAlignment="Center"
                FontFamily="Segoe MDL2 Assets"
                FontSize="14"
                Foreground="{DynamicResource {x:Static theme:MosaicTheme.ControlTextSecondaryForegroundBrush}}"
                Text="&#xE72A;" />

            <StackPanel Grid.Column="2">
                <TextBlock
                    Margin="0,0,0,6"
                    FontSize="{DynamicResource {x:Static theme:MosaicTheme.FontSizeSmall}}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource {x:Static theme:MosaicTheme.ControlTextSecondaryForegroundBrush}}"
                    Text="TO" />
                <mosaic:HexColorTextBox
                    x:Name="TargetHexBox"
                    Height="46"
                    VerticalContentAlignment="Center"
                    CornerRadius="6" />
            </StackPanel>
        </Grid>

        <!--  Match shading option  -->
        <Border
            Margin="0,16,0,0"
            Padding="12"
            Background="{DynamicResource {x:Static theme:MosaicTheme.ControlBackgroundLightBrush}}"
            BorderBrush="{DynamicResource {x:Static theme:MosaicTheme.ControlBorderBrush}}"
            BorderThickness="1"
            CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <mosaic:ToggleSwitch
                    x:Name="MatchShadingToggle"
                    Grid.Column="0"
                    Margin="0,2,12,0"
                    VerticalAlignment="Top" />
                <StackPanel Grid.Column="1">
                    <TextBlock FontWeight="SemiBold" Text="Match Shading" />
                    <TextBlock
                        FontSize="{DynamicResource {x:Static theme:MosaicTheme.FontSizeSmall}}"
                        Foreground="{DynamicResource {x:Static theme:MosaicTheme.ControlTextSecondaryForegroundBrush}}"
                        Text="Preserve gradients (e.g., Red→White becomes Blue→White)"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <!--  Tolerance  -->
        <Grid Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock FontWeight="SemiBold" Text="Tolerance" />
            <TextBlock
                x:Name="ToleranceValueText"
                Grid.Column="1"
                FontFamily="{DynamicResource {x:Static theme:MosaicTheme.MonospaceFontFamily}}"
                Foreground="{DynamicResource {x:Static theme:MosaicTheme.AccentBrush}}"
                Text="10%" />
        </Grid>
        <Slider
            x:Name="ToleranceSlider"
            Margin="0,8,0,0"
            IsSnapToTickEnabled="True"
            Maximum="100"
            Minimum="0"
            TickFrequency="1"
            ValueChanged="ToleranceSlider_OnValueChanged"
            Value="10" />
        <TextBlock
            Margin="0,6,0,0"
            FontSize="{DynamicResource {x:Static theme:MosaicTheme.FontSizeSmall}}"
            Foreground="{DynamicResource {x:Static theme:MosaicTheme.ControlTextSecondaryForegroundBrush}}"
            Text="Higher tolerance includes similar shades. Required for JPEGs."
            TextWrapping="Wrap" />

        <!--  Actions  -->
        <StackPanel
            Margin="0,20,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                x:Name="CancelButton"
                MinWidth="80"
                Padding="12,6"
                Click="CancelButton_OnClick"
                Content="Cancel" />
            <mosaic:AccentButton
                x:Name="ConfirmButton"
                MinWidth="120"
                Margin="10,0,0,0"
                Padding="12,6"
                AccentButtonType="ThemeAccent"
                Click="ConfirmButton_OnClick"
                Content="Confirm Swap"
                IsDefault="True" />
        </StackPanel>
    </StackPanel>
</UserControl>
