<Window
    x:Class="ChromaSwap.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mosaic="clr-namespace:Mosaic.UI.Wpf.Controls;assembly=Mosaic.UI.Wpf"
    xmlns:theme="http://schemas.apexgate.net/wpf/mosaic-ui"
    Title="ChromaSwap"
    Width="1200"
    Height="800"
    theme:WindowChromeBehavior.CaptionHeight="0"
    theme:WindowChromeBehavior.CornerRadius="10"
    theme:WindowChromeBehavior.GlassFrameThickness="0"
    theme:WindowChromeBehavior.IsEnabled="True"
    theme:WindowChromeBehavior.ResizeBorderThickness="5"
    theme:WindowChromeBehavior.RoundBorder="True"
    theme:WindowChromeBehavior.UseAeroCaptionButtons="True"
    Background="{DynamicResource {x:Static theme:MosaicTheme.WindowBackgroundBrush}}"
    BorderBrush="{DynamicResource {x:Static theme:MosaicTheme.AccentBrush}}"
    BorderThickness="0"
    Foreground="{DynamicResource {x:Static theme:MosaicTheme.WindowForegroundBrush}}"
    Icon="/Assets/app.png"
    Loaded="MainWindow_OnLoaded"
    WindowStartupLocation="CenterScreen">

    <Window.InputBindings>
        <KeyBinding
            Key="Z"
            Command="{Binding UndoCommand, RelativeSource={RelativeSource AncestorType=Window}}"
            Modifiers="Control" />
        <KeyBinding
            Key="V"
            Command="{Binding PasteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
            Modifiers="Control" />
    </Window.InputBindings>

    <Window.Resources>
        <!--  Checkerboard used behind transparent pixels (fixed dark palette like the original app).  -->
        <DrawingBrush
            x:Key="CheckerboardBrush"
            Stretch="None"
            TileMode="Tile"
            Viewport="0,0,20,20"
            ViewportUnits="Absolute">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#FF1F2937">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,20,20" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#FF374151" Geometry="M0,0 L10,0 10,10 0,10 Z M10,10 L20,10 20,20 10,20 Z" />
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <!--  Quiet toolbar-style button (icon + text, transparent until hovered).  -->
        <Style x:Key="QuietButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static theme:MosaicTheme.ControlTextSecondaryForegroundBrush}}" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource {x:Static theme:MosaicTheme.ControlHoverBackgroundBrush}}" />
                    <Setter Property="Foreground" Value="{DynamicResource {x:Static theme:MosaicTheme.ControlTextForegroundBrush}}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.35" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  Small icon-only copy button used in the value cards.  -->
        <Style
            x:Key="CopyButtonStyle"
            BasedOn="{StaticResource QuietButtonStyle}"
            TargetType="{x:Type Button}">
            <Setter Property="Padding" Value="6" />
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="35" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Title Bar  -->
        <mosaic:WindowTitleBar
            Grid.Row="0"
            IconSource="/Assets/app.png"
            TitleAlignment="Center">
            <mosaic:WindowTitleBar.RightContent>
                <Button
                    Width="48"
                    Click="ButtonToggleTheme_OnClick"
                    Style="{DynamicResource {x:Static theme:MosaicTheme.WindowTitleBarButtonStyle}}"
                    ToolTip="Toggle Theme">
                    <Button.ContentTemplate>
                        <DataTemplate>
                            <Viewbox Width="16" Height="16">
                                <Canvas Width="512" Height="512">
                                    <Path Data="M8 256c0 137 111 248 248 248s248-111 248-248S393 8 256 8 8 119 8 256zm248 184V72c101.7 0 184 82.3 184 184 0 101.7-82.3 184-184 184z" Fill="{DynamicResource {x:Static theme:MosaicTheme.WindowForegroundBrush}}" />
                                </Canvas>
                            </Viewbox>
                        </DataTemplate>
                    </Button.ContentTemplate>
                </Button>
            </mosaic:WindowTitleBar.RightContent>
        </mosaic:WindowTitleBar>

        <!--  Header  -->
        <Border
            Grid.Row="1"
            Padding="16,10"
            Background="{DynamicResource {x:Static theme:MosaicTheme.ControlBackgroundBrush}}"
            BorderBrush="{DynamicResource {x:Static theme:MosaicTheme.ControlBorderBrush}}"
            BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  Logo + title  -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Border
                        Width="32"
                        Height="32"
                        CornerRadius="8">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Offset="0" Color="#3B82F6" />
                                <GradientStop Offset="1" Color="#9333EA" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="16"
                            Foreground="White"
                            Text="&#xE790;" />
                    </Border>
                    <TextBlock
                        Margin="10,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="18"
                        FontWeight="Bold">
                        <Run Text="Chroma" /><Run Foreground="{DynamicResource {x:Static theme:MosaicTheme.AccentBrush}}" Text="Swap" />
                    </TextBlock>
                </StackPanel>

                <!--  Actions  -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button
                        x:Name="UndoButton"
                        Click="UndoButton_OnClick"
                        IsEnabled="False"
                        Style="{StaticResource QuietButtonStyle}"
                        ToolTip="Undo (Ctrl+Z)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                VerticalAlignment="Center"
                                FontFamily="Segoe MDL2 Assets"
                                Text="&#xE7A7;" />
                            <TextBlock Margin="6,0,0,0" Text="Undo" />
                        </StackPanel>
                    </Button>

                    <Border
                        Width="1"
                        Height="22"
                        Margin="10,0"
                        Background="{DynamicResource {x:Static theme:MosaicTheme.ControlSeparatorBrush}}" />

                    <Button
                        x:Name="OpenButton"
                        Padding="12,6"
                        Click="OpenButton_OnClick">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                VerticalAlignment="Center"
                                FontFamily="Segoe MDL2 Assets"
                                Text="&#xE8E5;" />
                            <TextBlock Margin="6,0,0,0" Text="Open Image" />
                        </StackPanel>
                    </Button>

                    <mosaic:AccentButton
                        x:Name="SaveButton"
                        Margin="10,0,0,0"
                        Padding="14,6"
                        AccentButtonType="ThemeAccent"
                        Click="SaveButton_OnClick"
                        IsEnabled="False">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                VerticalAlignment="Center"
                                FontFamily="Segoe MDL2 Assets"
                                Text="&#xE74E;" />
                            <TextBlock Margin="6,0,0,0" Text="Save" />
                        </StackPanel>
                    </mosaic:AccentButton>
                </StackPanel>
            </Grid>
        </Border>

        <!--  Workspace  -->
        <Grid
            x:Name="WorkspaceGrid"
            Grid.Row="2"
            AllowDrop="True"
            Background="{DynamicResource {x:Static theme:MosaicTheme.WindowBackgroundBrush}}"
            DragOver="WorkspaceGrid_OnDragOver"
            Drop="WorkspaceGrid_OnDrop">

            <!--  Empty state  -->
            <StackPanel
                x:Name="EmptyState"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                IsHitTestVisible="False">
                <Border
                    Width="96"
                    Height="96"
                    HorizontalAlignment="Center"
                    Background="{DynamicResource {x:Static theme:MosaicTheme.ControlBackgroundBrush}}"
                    BorderBrush="{DynamicResource {x:Static theme:MosaicTheme.ControlBorderBrush}}"
                    BorderThickness="1"
                    CornerRadius="16">
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="36"
                        Foreground="{DynamicResource {x:Static theme:MosaicTheme.ControlTextSecondaryForegroundBrush}}"
                        Text="&#xEB9F;" />
                </Border>
                <TextBlock
                    Margin="0,16,0,0"
                    HorizontalAlignment="Center"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Text="No Image Selected" />
                <TextBlock
                    Margin="0,6,0,0"
                    HorizontalAlignment="Center"
                    Foreground="{DynamicResource {x:Static theme:MosaicTheme.ControlTextSecondaryForegroundBrush}}"
                    Text="Drag &amp; drop, paste, or click Open Image" />
            </StackPanel>

            <!--  Image canvas  -->
            <Border
                x:Name="CanvasContainer"
                Margin="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{StaticResource CheckerboardBrush}"
                BorderBrush="{DynamicResource {x:Static theme:MosaicTheme.ControlBorderBrush}}"
                BorderThickness="1"
                Visibility="Collapsed">
                <Image
                    x:Name="MainImage"
                    Cursor="Cross"
                    MouseLeave="MainImage_OnMouseLeave"
                    MouseLeftButtonDown="MainImage_OnMouseLeftButtonDown"
                    MouseMove="MainImage_OnMouseMove"
                    Stretch="Uniform"
                    StretchDirection="DownOnly" />
            </Border>

            <!--  Loupe overlay (never hit-testable)  -->
            <Canvas x:Name="LoupeCanvas" IsHitTestVisible="False">
                <Grid
                    x:Name="Loupe"
                    Width="100"
                    Height="100"
                    Visibility="Collapsed">
                    <Grid.Clip>
                        <EllipseGeometry
                            Center="50,50"
                            RadiusX="50"
                            RadiusY="50" />
                    </Grid.Clip>
                    <Rectangle Fill="{StaticResource CheckerboardBrush}" />
                    <Image
                        x:Name="LoupeImage"
                        RenderOptions.BitmapScalingMode="NearestNeighbor"
                        Stretch="Fill" />
                    <Path
                        Data="M50,0 L50,100 M0,50 L100,50"
                        Stroke="#80FFFFFF"
                        StrokeThickness="1" />
                    <Ellipse Stroke="#CC3B82F6" StrokeThickness="3" />
                </Grid>
            </Canvas>

            <!--  Shades & Tints slide-in panel  -->
            <Border
                x:Name="ShadesPanel"
                Width="300"
                HorizontalAlignment="Left"
                Background="{DynamicResource {x:Static theme:MosaicTheme.ControlBackgroundBrush}}"
                BorderBrush="{DynamicResource {x:Static theme:MosaicTheme.ControlBorderBrush}}"
                BorderThickness="0,0,1,0"
                RenderTransformOrigin="0,0"
                Visibility="Collapsed">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="ShadesPanelTransform" X="-310" />
                </Border.RenderTransform>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border
                        Grid.Row="0"
                        Padding="14,12"
                        BorderBrush="{DynamicResource {x:Static theme:MosaicTheme.ControlSeparatorBrush}}"
                        BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock FontWeight="Bold" Text="Shades &amp; Tints" />
                                <TextBlock
                                    FontSize="{DynamicResource {x:Static theme:MosaicTheme.FontSizeSmall}}"
                                    Foreground="{DynamicResource {x:Static theme:MosaicTheme.ControlTextSecondaryForegroundBrush}}"
                                    Text="Click to copy hex" />
                            </StackPanel>
                            <Button
                                Grid.Column="1"
                                Click="ExportCssButton_OnClick"
                                Style="{StaticResource QuietButtonStyle}"
                                ToolTip="Export CSS Variables">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontFamily="Segoe MDL2 Assets"
                                        Text="&#xEDE1;" />
                                    <TextBlock Margin="5,0,0,0" Text="Export" />
                                </StackPanel>
                            </Button>
                            <Button
                                Grid.Column="2"
                                Margin="4,0,0,0"
                                Click="CloseShadesButton_OnClick"
                                Style="{StaticResource QuietButtonStyle}"
                                ToolTip="Close">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE711;" />
                            </Button>
                        </Grid>
                    </Border>

                    <ScrollViewer
                        Grid.Row="1"
                        Padding="8"
                        VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ShadesItems">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button
                                        Margin="0,1"
                                        HorizontalContentAlignment="Stretch"
                                        Click="Swatch_OnClick"
                                        Style="{StaticResource QuietButtonStyle}"
                                        ToolTip="Copy hex">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border
                                                Grid.Column="0"
                                                Width="38"
                                                Height="38"
                                                Background="{StaticResource CheckerboardBrush}"
                                                BorderBrush="{DynamicResource {x:Static theme:MosaicTheme.ControlBorderBrush}}"
                                                BorderThickness="1"
                                                CornerRadius="4">
                                                <Border Background="{Binding Brush}" CornerRadius="3" />
                                            </Border>
                                            <StackPanel
                                                Grid.Column="1"
                                                Margin="10,0,0,0"
                                                VerticalAlignment="Center">
                                                <TextBlock
                                                    FontFamily="{DynamicResource {x:Static theme:MosaicTheme.MonospaceFontFamily}}"
                                                    FontWeight="{Binding FontWeight}"
                                                    Foreground="{Binding HexForeground}"
                                                    Text="{Binding Hex}" />
                                                <TextBlock
                                                    FontSize="{DynamicResource {x:Static theme:MosaicTheme.FontSizeSmall}}"
                                                    Foreground="{DynamicResource {x:Static theme:MosaicTheme.ControlTextSecondaryForegroundBrush}}"
                                                    Text="{Binding Name}" />
                                            </StackPanel>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!--  Footer / Color Info  -->
        <Border
            Grid.Row="3"
            Padding="16,12"
            Background="{DynamicResource {x:Static theme:MosaicTheme.ControlBackgroundBrush}}"
            BorderBrush="{DynamicResource {x:Static theme:MosaicTheme.ControlBorderBrush}}"
            BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  Selected color preview  -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button
                        Click="ColorPreview_OnClick"
                        Style="{StaticResource QuietButtonStyle}"
                        ToolTip="Click to view shades &amp; tints">
                        <Border
                            Width="48"
                            Height="48"
                            Background="{StaticResource CheckerboardBrush}"
                            BorderBrush="{DynamicResource {x:Static theme:MosaicTheme.ControlBorderBrush}}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Border x:Name="ColorPreviewFill" CornerRadius="7" />
                        </Border>
                    </Button>
                    <StackPanel Margin="10,0,24,0" VerticalAlignment="Center">
                        <TextBlock
                            FontSize="{DynamicResource {x:Static theme:MosaicTheme.FontSizeSmall}}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource {x:Static theme:MosaicTheme.ControlTextSecondaryForegroundBrush}}"
                            Text="ACTIVE COLOR" />
                        <TextBlock
                            x:Name="ColorNameText"
                            FontFamily="{DynamicResource {x:Static theme:MosaicTheme.MonospaceFontFamily}}"
                            Text="Select a pixel" />
                    </StackPanel>
                </StackPanel>

                <!--  Color values  -->
                <UniformGrid
                    Grid.Column="1"
                    MaxWidth="700"
                    Columns="3">
                    <Border
                        Margin="4,0"
                        Padding="10,6"
                        Background="{DynamicResource {x:Static theme:MosaicTheme.ControlBackgroundLightBrush}}"
                        BorderBrush="{DynamicResource {x:Static theme:MosaicTheme.ControlBorderBrush}}"
                        BorderThickness="1"
                        CornerRadius="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock
                                    FontSize="{DynamicResource {x:Static theme:MosaicTheme.FontSizeSmall}}"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource {x:Static theme:MosaicTheme.ControlTextSecondaryForegroundBrush}}"
                                    Text="HEX" />
                                <TextBlock
                                    x:Name="HexValueText"
                                    FontFamily="{DynamicResource {x:Static theme:MosaicTheme.MonospaceFontFamily}}"
                                    Foreground="{DynamicResource {x:Static theme:MosaicTheme.AccentBrush}}"
                                    Text="#------" />
                            </StackPanel>
                            <Button
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Click="CopyHex_OnClick"
                                Style="{StaticResource CopyButtonStyle}"
                                ToolTip="Copy HEX">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8C8;" />
                            </Button>
                        </Grid>
                    </Border>

                    <Border
                        Margin="4,0"
                        Padding="10,6"
                        Background="{DynamicResource {x:Static theme:MosaicTheme.ControlBackgroundLightBrush}}"
                        BorderBrush="{DynamicResource {x:Static theme:MosaicTheme.ControlBorderBrush}}"
                        BorderThickness="1"
                        CornerRadius="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock
                                    FontSize="{DynamicResource {x:Static theme:MosaicTheme.FontSizeSmall}}"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource {x:Static theme:MosaicTheme.ControlTextSecondaryForegroundBrush}}"
                                    Text="RGB" />
                                <TextBlock
                                    x:Name="RgbValueText"
                                    FontFamily="{DynamicResource {x:Static theme:MosaicTheme.MonospaceFontFamily}}"
                                    Foreground="{DynamicResource {x:Static theme:MosaicTheme.SuccessBrush}}"
                                    Text="---, ---, ---" />
                            </StackPanel>
                            <Button
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Click="CopyRgb_OnClick"
                                Style="{StaticResource CopyButtonStyle}"
                                ToolTip="Copy RGB">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8C8;" />
                            </Button>
                        </Grid>
                    </Border>

                    <Border
                        Margin="4,0"
                        Padding="10,6"
                        Background="{DynamicResource {x:Static theme:MosaicTheme.ControlBackgroundLightBrush}}"
                        BorderBrush="{DynamicResource {x:Static theme:MosaicTheme.ControlBorderBrush}}"
                        BorderThickness="1"
                        CornerRadius="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock
                                    FontSize="{DynamicResource {x:Static theme:MosaicTheme.FontSizeSmall}}"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource {x:Static theme:MosaicTheme.ControlTextSecondaryForegroundBrush}}"
                                    Text="HSV" />
                                <TextBlock
                                    x:Name="HsvValueText"
                                    FontFamily="{DynamicResource {x:Static theme:MosaicTheme.MonospaceFontFamily}}"
                                    Foreground="{DynamicResource {x:Static theme:MosaicTheme.InfoBrush}}"
                                    Text="---, ---, ---" />
                            </StackPanel>
                            <Button
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Click="CopyHsv_OnClick"
                                Style="{StaticResource CopyButtonStyle}"
                                ToolTip="Copy HSV">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8C8;" />
                            </Button>
                        </Grid>
                    </Border>
                </UniformGrid>

                <!--  Swap action  -->
                <mosaic:AccentButton
                    x:Name="SwapButton"
                    Grid.Column="2"
                    Margin="16,0,0,0"
                    Padding="18,8"
                    AccentButtonType="ThemeAccent"
                    Click="SwapButton_OnClick"
                    IsEnabled="False">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="Segoe MDL2 Assets"
                            Text="&#xE8AB;" />
                        <TextBlock
                            Margin="8,0,0,0"
                            FontWeight="SemiBold"
                            Text="Swap Colors" />
                    </StackPanel>
                </mosaic:AccentButton>
            </Grid>
        </Border>
    </Grid>
</Window>
