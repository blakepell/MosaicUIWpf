<wpf:MosaicApp
    x:Class="ChromaSwap.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:ChromaSwap"
    xmlns:mosaic="http://schemas.apexgate.net/wpf/mosaic-ui"
    xmlns:vm="clr-namespace:ChromaSwap.Common"
    xmlns:wpf="clr-namespace:Mosaic.UI.Wpf;assembly=Mosaic.UI.Wpf"
    x:TypeArguments="vm:AppSettings, vm:AppViewModel"
    DispatcherUnhandledException="App_OnDispatcherUnhandledException"
    Exit="App_OnExit"
    Startup="App_OnStartup"
    StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <mosaic:ThemeManager
                    Native="True"
                    SystemColors="True"
                    Theme="Dark" />
            </ResourceDictionary.MergedDictionaries>

            <CornerRadius x:Key="{x:Static mosaic:MosaicTheme.ButtonCornerRadius}">4</CornerRadius>
        </ResourceDictionary>
    </Application.Resources>
</wpf:MosaicApp>
