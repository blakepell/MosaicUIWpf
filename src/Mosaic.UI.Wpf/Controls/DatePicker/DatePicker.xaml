<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Mosaic.UI.Wpf.Controls"
    xmlns:themes="clr-namespace:Mosaic.UI.Wpf.Themes">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Mosaic.UI.Wpf;component/Controls/DatePicker/DayOfWeek.xaml" />
        <ResourceDictionary Source="/Mosaic.UI.Wpf;component/Controls/DatePicker/ChevronBUtton.xaml" />
        <ResourceDictionary Source="/Mosaic.UI.Wpf;component/Controls/DatePicker/CalendarBoxItem.xaml" />
        <ResourceDictionary Source="/Mosaic.UI.Wpf;component/Controls/DatePicker/CalendarBox.xaml" />
        <ResourceDictionary Source="/Mosaic.UI.Wpf;component/Controls/DatePicker/CalendarSwitch.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Style x:Key="MonthStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="Text" Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=CurrentMonth, StringFormat={}{0:yyyy.MM}}" />
        <Setter Property="Foreground" Value="{DynamicResource {x:Static themes:MosaicTheme.ControlTextForegroundBrush}}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Margin" Value="10,10,10,5" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style TargetType="{x:Type controls:DatePicker}">
        <Setter Property="Background" Value="{DynamicResource {x:Static themes:MosaicTheme.ControlTextBackgroundBrush}}" />
        <Setter Property="BorderBrush" Value="{DynamicResource {x:Static themes:MosaicTheme.ControlBorderBrush}}" />
        <Setter Property="Foreground" Value="{DynamicResource {x:Static themes:MosaicTheme.ControlTextForegroundBrush}}" />
        <Setter Property="Height" Value="30" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:DatePicker}">
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="4">
                        <Grid>
                            <controls:CalendarSwitch x:Name="PART_Switch" />
                            <Popup
                                x:Name="PART_Popup"
                                AllowsTransparency="True"
                                StaysOpen="False"
                                VerticalOffset="2">
                                <Border
                                    Padding="10"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="4">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition />
                                            <RowDefinition />
                                            <RowDefinition />
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition />
                                                <ColumnDefinition />
                                                <ColumnDefinition />
                                            </Grid.ColumnDefinitions>

                                            <controls:ChevronButton
                                                x:Name="PART_Left"
                                                Grid.Column="0"
                                                Tag="Left" />
                                            <TextBlock Grid.Column="1" Style="{StaticResource MonthStyle}" />
                                            <controls:ChevronButton
                                                x:Name="PART_Right"
                                                Grid.Column="2"
                                                Tag="Right" />
                                        </Grid>
                                        <UniformGrid Grid.Row="1" Columns="7">
                                            <controls:DayOfWeek Grid.Column="0" Content="Su" />
                                            <controls:DayOfWeek Grid.Column="1" Content="Mo" />
                                            <controls:DayOfWeek Grid.Column="2" Content="Tu" />
                                            <controls:DayOfWeek Grid.Column="3" Content="We" />
                                            <controls:DayOfWeek Grid.Column="4" Content="Th" />
                                            <controls:DayOfWeek Grid.Column="5" Content="Fr" />
                                            <controls:DayOfWeek Grid.Column="6" Content="Sa" />
                                        </UniformGrid>
                                        <controls:CalendarBox x:Name="PART_ListBox" Grid.Row="2" />
                                    </Grid>
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
