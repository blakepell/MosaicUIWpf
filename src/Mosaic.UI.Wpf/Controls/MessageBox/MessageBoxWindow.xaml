<Window
    x:Class="Mosaic.UI.Wpf.Controls.MessageBoxWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Mosaic.UI.Wpf.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:themes="clr-namespace:Mosaic.UI.Wpf.Themes"
    MinWidth="320"
    MaxWidth="520"
    x:ClassModifier="internal"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    SizeToContent="WidthAndHeight"
    SnapsToDevicePixels="True"
    TextOptions.TextFormattingMode="Display"
    UseLayoutRounding="True"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None"
    mc:Ignorable="d">

    <!--  Transparent margin leaves room for the soft drop shadow around the rounded dialog.  -->
    <controls:ClipBorder
        Margin="12"
        Background="{DynamicResource {x:Static themes:MosaicTheme.MessageBoxFooterBackgroundBrush}}"
        BorderBrush="{DynamicResource {x:Static themes:MosaicTheme.ControlBorderBrush}}"
        BorderThickness="1"
        CornerRadius="6"
        SnapsToDevicePixels="True">
        <controls:ClipBorder.Effect>
            <DropShadowEffect
                BlurRadius="12"
                Direction="270"
                Opacity="0.35"
                ShadowDepth="2"
                Color="#000000" />
        </controls:ClipBorder.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Top portion: title bar + icon/message  -->
            <Border
                Grid.Row="0"
                Background="{DynamicResource {x:Static themes:MosaicTheme.MessageBoxHeaderBackgroundBrush}}"
                CornerRadius="5,5,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  Title bar (drag region) with title text and close button only  -->
                    <Grid
                        x:Name="TitleBar"
                        Grid.Row="0"
                        Background="Transparent"
                        MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            x:Name="TitleTextBlock"
                            Grid.Column="0"
                            Margin="12,0,8,0"
                            VerticalAlignment="Center"
                            FontFamily="{DynamicResource {x:Static themes:MosaicTheme.FontFamily}}"
                            FontSize="{DynamicResource {x:Static themes:MosaicTheme.FontSizeNormal}}"
                            Foreground="{DynamicResource {x:Static themes:MosaicTheme.WindowForegroundBrush}}"
                            TextTrimming="CharacterEllipsis" />

                        <Button
                            x:Name="CloseButton"
                            Grid.Column="1"
                            Click="OnCloseClick"
                            Content="&#xE8BB;"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="10"
                            Style="{DynamicResource {x:Static themes:MosaicTheme.WindowTitleBarCloseButtonStyle}}"
                            ToolTip="Close" />
                    </Grid>

                    <!--  Icon + message  -->
                    <Grid Grid.Row="1" Margin="16,8,16,22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Image
                            x:Name="IconImage"
                            Grid.Column="0"
                            Width="40"
                            Height="40"
                            Margin="0,0,8,0"
                            VerticalAlignment="Top"
                            SnapsToDevicePixels="True"
                            Stretch="Uniform" />

                        <TextBlock
                            x:Name="MessageTextBlock"
                            Grid.Column="1"
                            MaxWidth="380"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            FontFamily="{DynamicResource {x:Static themes:MosaicTheme.FontFamily}}"
                            FontSize="{DynamicResource {x:Static themes:MosaicTheme.FontSizeNormal}}"
                            Foreground="{DynamicResource {x:Static themes:MosaicTheme.ControlTextForegroundBrush}}"
                            TextWrapping="Wrap" />
                    </Grid>
                </Grid>
            </Border>

            <!--  Bottom portion: buttons. 1px separator divides it from the top portion.  -->
            <Border
                Grid.Row="1"
                Background="{DynamicResource {x:Static themes:MosaicTheme.MessageBoxFooterBackgroundBrush}}"
                BorderBrush="{DynamicResource {x:Static themes:MosaicTheme.ControlSeparatorBrush}}"
                BorderThickness="0,1,0,0"
                CornerRadius="0,0,5,5">
                <StackPanel
                    x:Name="ButtonPanel"
                    Margin="12,10"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal" />
            </Border>
        </Grid>
    </controls:ClipBorder>
</Window>
