<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Mosaic.UI.Wpf.Controls"
    xmlns:themes="clr-namespace:Mosaic.UI.Wpf.Themes">

    <Style x:Key="{x:Type controls:SplitButton}" TargetType="{x:Type controls:SplitButton}">
        <Setter Property="MinHeight" Value="26" />
        <Setter Property="MinWidth" Value="72" />
        <Setter Property="Padding" Value="10,3,8,3" />
        <Setter Property="Background" Value="{DynamicResource Button.Static.Background}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Button.Static.Border}" />
        <Setter Property="BorderThickness" Value="{DynamicResource {x:Static themes:MosaicTheme.ButtonBorderThickness}}" />
        <Setter Property="Foreground" Value="{DynamicResource {x:Static themes:MosaicTheme.ControlTextForegroundBrush}}" />
        <Setter Property="FontFamily" Value="{DynamicResource {x:Static themes:MosaicTheme.FontFamily}}" />
        <Setter Property="FontSize" Value="{DynamicResource {x:Static themes:MosaicTheme.FontSizeNormal}}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:SplitButton}">
                    <Border
                        x:Name="PART_Root"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{DynamicResource {x:Static themes:MosaicTheme.ButtonCornerRadius}}"
                        SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="{Binding DropDownButtonWidth, RelativeSource={RelativeSource TemplatedParent}}" />
                            </Grid.ColumnDefinitions>

                            <Border
                                x:Name="PART_PrimaryButton"
                                Grid.Column="0"
                                Padding="{TemplateBinding Padding}"
                                Background="Transparent"
                                SnapsToDevicePixels="True">
                                <ContentPresenter
                                    x:Name="PART_ContentPresenter"
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                    Content="{TemplateBinding Content}"
                                    ContentStringFormat="{TemplateBinding ContentStringFormat}"
                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                    ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}"
                                    Focusable="False"
                                    RecognizesAccessKey="True"
                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                    TextElement.Foreground="{TemplateBinding Foreground}" />
                            </Border>

                            <Border
                                x:Name="PART_Separator"
                                Grid.Column="1"
                                Width="{Binding BorderThickness.Left, RelativeSource={RelativeSource TemplatedParent}}"
                                Margin="0"
                                Background="{DynamicResource {x:Static themes:MosaicTheme.ControlSeparatorBrush}}"
                                SnapsToDevicePixels="True" />

                            <Border
                                x:Name="PART_DropDownButton"
                                Grid.Column="2"
                                Background="Transparent"
                                SnapsToDevicePixels="True">
                                <Viewbox
                                    Width="8"
                                    Height="5"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Stretch="Fill">
                                    <Path
                                        x:Name="PART_Arrow"
                                        Data="M 0 0 L 8 0 L 4 5 Z"
                                        Fill="{TemplateBinding Foreground}" />
                                </Viewbox>
                            </Border>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_Root" Property="Background" Value="{DynamicResource Button.MouseOver.Background}" />
                            <Setter TargetName="PART_Root" Property="BorderBrush" Value="{DynamicResource Button.MouseOver.Border}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="PART_Root" Property="BorderBrush" Value="{DynamicResource {x:Static themes:MosaicTheme.ControlSelectedBorderBrush}}" />
                        </Trigger>
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource SplitButton.Open.Foreground}" />
                            <Setter TargetName="PART_Root" Property="Background" Value="{DynamicResource SplitButton.Open.Background}" />
                            <Setter TargetName="PART_Root" Property="BorderBrush" Value="{DynamicResource SplitButton.Open.Border}" />
                        </Trigger>
                        <Trigger Property="IsPrimaryActionEnabled" Value="False">
                            <Setter TargetName="PART_PrimaryButton" Property="Opacity" Value="0.55" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="PART_Root" Property="Background" Value="{DynamicResource Button.Disabled.Background}" />
                            <Setter TargetName="PART_Root" Property="BorderBrush" Value="{DynamicResource Button.Disabled.Border}" />
                            <Setter Property="Foreground" Value="{DynamicResource Button.Disabled.Foreground}" />
                            <Setter TargetName="PART_Separator" Property="Opacity" Value="0.6" />
                            <Setter TargetName="PART_ContentPresenter" Property="Opacity" Value="0.65" />
                            <Setter TargetName="PART_Arrow" Property="Opacity" Value="0.65" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
