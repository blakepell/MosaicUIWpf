<UserControl
    x:Class="Mosaic.UI.Wpf.Controls.WindowTitleBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:Mosaic.UI.Wpf.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:themes="clr-namespace:Mosaic.UI.Wpf.Themes"
    x:Name="TitleBarControl"
    d:DesignHeight="35"
    d:DesignWidth="800"
    MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <Grid Background="{DynamicResource {x:Static themes:MosaicTheme.WindowBackgroundBrush}}">
        <DockPanel LastChildFill="True">

            <!--  System Buttons (Right)  -->
            <StackPanel
                VerticalAlignment="Center"
                DockPanel.Dock="Right"
                Orientation="Horizontal">

                <!--  User-supplied right content (e.g. theme toggle, settings)  -->
                <ContentPresenter Content="{Binding RightContent, ElementName=TitleBarControl}" />

                <!--  Minimize  -->
                <Button
                    x:Name="MinimizeButton"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Click="OnMinimizeClick"
                    Content="&#xE921;"
                    FontFamily="Segoe MDL2 Assets"
                    Style="{DynamicResource {x:Static themes:MosaicTheme.WindowTitleBarButtonStyle}}"
                    ToolTip="Minimize"
                    Visibility="{Binding ShowMinimizeButton, ElementName=TitleBarControl, Converter={StaticResource BoolToVisibility}}" />

                <!--  Maximize / Restore  -->
                <Button
                    x:Name="MaxRestoreButton"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Click="OnMaxRestoreClick"
                    Content="&#xE922;"
                    FontFamily="Segoe MDL2 Assets"
                    Style="{DynamicResource {x:Static themes:MosaicTheme.WindowTitleBarButtonStyle}}"
                    ToolTip="Maximize/Restore"
                    Visibility="{Binding ShowMaxRestoreButton, ElementName=TitleBarControl, Converter={StaticResource BoolToVisibility}}" />

                <!--  Close  -->
                <Button
                    x:Name="CloseButton"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Click="OnCloseClick"
                    Content="&#xE8BB;"
                    FontFamily="Segoe MDL2 Assets"
                    Style="{DynamicResource {x:Static themes:MosaicTheme.WindowTitleBarCloseButtonStyle}}"
                    ToolTip="Close"
                    Visibility="{Binding ShowCloseButton, ElementName=TitleBarControl, Converter={StaticResource BoolToVisibility}}" />
            </StackPanel>

            <!--  App Icon  -->
            <Image
                x:Name="WindowIconImage"
                Width="16"
                Height="16"
                Margin="8,0,4,0"
                VerticalAlignment="Center"
                Cursor="Arrow"
                DockPanel.Dock="Left"
                MouseLeftButtonDown="OnWindowIconMouseLeftButtonDown"
                Source="{Binding IconSource, ElementName=TitleBarControl}"
                Visibility="{Binding ShowIcon, ElementName=TitleBarControl, Converter={StaticResource BoolToVisibility}}" />

            <!--  User-supplied left content (e.g. breadcrumbs, search)  -->
            <ContentPresenter
                VerticalAlignment="Center"
                Content="{Binding LeftContent, ElementName=TitleBarControl}"
                DockPanel.Dock="Left" />

            <!--  Transparent fill keeps mouse-hit-test intact for dragging empty title bar space.  -->
            <Border Background="Transparent" />
        </DockPanel>

        <!--  Title text overlays the full title bar so Center means the window's true center.  -->
        <Border Background="Transparent" IsHitTestVisible="False">
            <TextBlock
                x:Name="TitleTextBlock"
                HorizontalAlignment="{Binding TitleAlignment, ElementName=TitleBarControl}"
                VerticalAlignment="Center"
                FontFamily="Segoe UI"
                FontSize="12"
                FontWeight="Normal"
                Foreground="{DynamicResource {x:Static themes:MosaicTheme.WindowForegroundBrush}}"
                TextTrimming="CharacterEllipsis">
                <TextBlock.Style>
                    <Style TargetType="{x:Type TextBlock}">
                        <Setter Property="Margin" Value="32,0,8,0" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding TitleAlignment, ElementName=TitleBarControl}" Value="Center">
                                <Setter Property="Margin" Value="0" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Border>
    </Grid>
</UserControl>
