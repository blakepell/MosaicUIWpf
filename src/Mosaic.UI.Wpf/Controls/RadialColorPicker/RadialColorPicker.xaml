<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:Mosaic.UI.Wpf.Converters"
    xmlns:local="clr-namespace:Mosaic.UI.Wpf.Controls"
    xmlns:themes="clr-namespace:Mosaic.UI.Wpf.Themes">

    <!--  Checkerboard used behind translucent color swatches so alpha is visible.  -->
    <DrawingBrush
        x:Key="MosaicRadialColorPickerChecker"
        Stretch="None"
        TileMode="Tile"
        Viewport="0,0,12,12"
        ViewportUnits="Absolute">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="#FFFFFFFF">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="0,0,12,12" />
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing Brush="#FFCCCCCC">
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <RectangleGeometry Rect="0,0,6,6" />
                            <RectangleGeometry Rect="6,6,6,6" />
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <!--  Shared style for the small channel text boxes (R/G/B/A/Hex).  -->
    <Style x:Key="MosaicRadialColorPickerTextBox" TargetType="{x:Type TextBox}">
        <Setter Property="Background" Value="{DynamicResource {x:Static themes:MosaicTheme.ControlTextBackgroundBrush}}" />
        <Setter Property="Foreground" Value="{DynamicResource {x:Static themes:MosaicTheme.ControlTextForegroundBrush}}" />
        <Setter Property="BorderBrush" Value="{DynamicResource {x:Static themes:MosaicTheme.ControlBorderBrush}}" />
        <Setter Property="CaretBrush" Value="{DynamicResource {x:Static themes:MosaicTheme.ControlTextForegroundBrush}}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="4,2" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style TargetType="{x:Type local:RadialColorPicker}">
        <Setter Property="Background" Value="{DynamicResource {x:Static themes:MosaicTheme.ControlBackgroundBrush}}" />
        <Setter Property="BorderBrush" Value="{DynamicResource {x:Static themes:MosaicTheme.ControlBorderBrush}}" />
        <Setter Property="Foreground" Value="{DynamicResource {x:Static themes:MosaicTheme.ControlForegroundBrush}}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:RadialColorPicker}">
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                        <Grid Margin="{TemplateBinding Padding}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" MinWidth="160" />
                            </Grid.ColumnDefinitions>

                            <!--  Radial hue wheel + inner saturation/value square  -->
                            <Canvas
                                x:Name="PART_WheelCanvas"
                                Grid.Column="0"
                                VerticalAlignment="Top">
                                <Image
                                    x:Name="PART_HueImage"
                                    Canvas.Left="0"
                                    Canvas.Top="0" />

                                <!--  Inscribed saturation/value square (position/size set in code-behind)  -->
                                <Border
                                    x:Name="PART_SVBorder"
                                    BorderBrush="{DynamicResource {x:Static themes:MosaicTheme.ControlBorderBrush}}"
                                    BorderThickness="1"
                                    SnapsToDevicePixels="True">
                                    <Image x:Name="PART_SVImage" Stretch="Fill" />
                                </Border>

                                <!--  Saturation/value selection thumb  -->
                                <Ellipse
                                    x:Name="PART_SVThumb"
                                    Width="14"
                                    Height="14"
                                    IsHitTestVisible="False"
                                    Stroke="White"
                                    StrokeThickness="2">
                                    <Ellipse.Effect>
                                        <DropShadowEffect
                                            BlurRadius="3"
                                            Opacity="0.7"
                                            ShadowDepth="0"
                                            Color="Black" />
                                    </Ellipse.Effect>
                                </Ellipse>

                                <!--  Hue selection thumb  -->
                                <Ellipse
                                    x:Name="PART_HueThumb"
                                    Width="18"
                                    Height="18"
                                    Fill="Transparent"
                                    IsHitTestVisible="False"
                                    Stroke="White"
                                    StrokeThickness="3">
                                    <Ellipse.Effect>
                                        <DropShadowEffect
                                            BlurRadius="3"
                                            Opacity="0.7"
                                            ShadowDepth="0"
                                            Color="Black" />
                                    </Ellipse.Effect>
                                </Ellipse>
                            </Canvas>

                            <!--  Editor panel  -->
                            <StackPanel
                                Grid.Column="1"
                                Margin="16,0,0,0"
                                VerticalAlignment="Top">

                                <!--  Preview swatch (over checkerboard so alpha is visible)  -->
                                <Border
                                    Height="44"
                                    Background="{StaticResource MosaicRadialColorPickerChecker}"
                                    BorderBrush="{DynamicResource {x:Static themes:MosaicTheme.ControlBorderBrush}}"
                                    BorderThickness="1"
                                    CornerRadius="3">
                                    <Border Background="{Binding SelectedBrush, RelativeSource={RelativeSource TemplatedParent}}" CornerRadius="2" />
                                </Border>

                                <!--  Hex value + copy button  -->
                                <TextBlock
                                    Margin="0,12,0,3"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource {x:Static themes:MosaicTheme.ControlTextSecondaryForegroundBrush}}"
                                    Text="Hex" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox
                                        x:Name="PART_HexTextBox"
                                        Grid.Column="0"
                                        FontFamily="Consolas"
                                        Style="{StaticResource MosaicRadialColorPickerTextBox}"
                                        ToolTip="Hex color (#AARRGGBB, #RRGGBB, or #RGB)" />
                                    <Button
                                        x:Name="PART_CopyButton"
                                        Grid.Column="1"
                                        Width="28"
                                        Margin="4,0,0,0"
                                        Padding="0"
                                        Background="{DynamicResource {x:Static themes:MosaicTheme.ControlBackgroundBrush}}"
                                        BorderBrush="{DynamicResource {x:Static themes:MosaicTheme.ControlBorderBrush}}"
                                        BorderThickness="1"
                                        ToolTip="Copy hex value to clipboard">
                                        <Path
                                            Width="12"
                                            Height="12"
                                            Data="M4,2 L11,2 L11,11 L4,11 Z M2,5 L2,14 L9,14"
                                            Stretch="Uniform"
                                            Stroke="{DynamicResource {x:Static themes:MosaicTheme.ControlForegroundBrush}}"
                                            StrokeThickness="1.4" />
                                    </Button>
                                </Grid>

                                <!--  RGBA channels  -->
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        Width="20"
                                        Margin="0,0,8,6"
                                        VerticalAlignment="Center"
                                        Foreground="{DynamicResource {x:Static themes:MosaicTheme.ControlTextSecondaryForegroundBrush}}"
                                        Text="R" />
                                    <TextBox
                                        x:Name="PART_RedTextBox"
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        Margin="0,0,0,6"
                                        Style="{StaticResource MosaicRadialColorPickerTextBox}" />

                                    <TextBlock
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Width="20"
                                        Margin="0,0,8,6"
                                        VerticalAlignment="Center"
                                        Foreground="{DynamicResource {x:Static themes:MosaicTheme.ControlTextSecondaryForegroundBrush}}"
                                        Text="G" />
                                    <TextBox
                                        x:Name="PART_GreenTextBox"
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Margin="0,0,0,6"
                                        Style="{StaticResource MosaicRadialColorPickerTextBox}" />

                                    <TextBlock
                                        Grid.Row="2"
                                        Grid.Column="0"
                                        Width="20"
                                        Margin="0,0,8,6"
                                        VerticalAlignment="Center"
                                        Foreground="{DynamicResource {x:Static themes:MosaicTheme.ControlTextSecondaryForegroundBrush}}"
                                        Text="B" />
                                    <TextBox
                                        x:Name="PART_BlueTextBox"
                                        Grid.Row="2"
                                        Grid.Column="1"
                                        Margin="0,0,0,6"
                                        Style="{StaticResource MosaicRadialColorPickerTextBox}" />

                                    <TextBlock
                                        Grid.Row="3"
                                        Grid.Column="0"
                                        Width="20"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center"
                                        Foreground="{DynamicResource {x:Static themes:MosaicTheme.ControlTextSecondaryForegroundBrush}}"
                                        Text="A"
                                        Visibility="{Binding ShowAlpha, RelativeSource={RelativeSource TemplatedParent}, Converter={conv:BoolToVisibilityConverter}}" />
                                    <TextBox
                                        x:Name="PART_AlphaTextBox"
                                        Grid.Row="3"
                                        Grid.Column="1"
                                        Style="{StaticResource MosaicRadialColorPickerTextBox}"
                                        ToolTip="Alpha / transparency (0-255)"
                                        Visibility="{Binding ShowAlpha, RelativeSource={RelativeSource TemplatedParent}, Converter={conv:BoolToVisibilityConverter}}" />
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
