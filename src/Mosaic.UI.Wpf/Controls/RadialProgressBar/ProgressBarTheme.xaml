<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Mosaic.UI.Wpf.Controls"
    xmlns:xrpb="http://XamlRadialProgressBar/DotNet">

    <SolidColorBrush x:Key="ThemeBackground" Color="#1A1A22" />
    <SolidColorBrush x:Key="ThemeForeground" Color="#4FD0FF" />
    <SolidColorBrush x:Key="ThemeForeground2" Color="#4F70FF" />

    <RadialGradientBrush x:Key="ProgressBarRadialGradientBrush" Center="0.5,0.5" GradientOrigin="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
        <RadialGradientBrush.GradientStops>
            <GradientStop Offset="0" Color="CornflowerBlue" />
            <GradientStop Offset="0.25" Color="DodgerBlue" />
            <GradientStop Offset="0.75" Color="DeepSkyBlue" />
            <GradientStop Offset="1" Color="LightSkyBlue" />
        </RadialGradientBrush.GradientStops>
    </RadialGradientBrush>

    <controls:ProgressToAngleConverter x:Key="ProgressConverter" />

</ResourceDictionary>