<UserControl
    x:Class="Mosaic.UI.Wpf.Logging.LogViewer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Mosaic.UI.Wpf.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Mosaic.UI.Wpf.Logging"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="LogViewerControl"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <ListView
            Name="ListView"
            x:FieldModifier="public"
            FontFamily="Segoe UI"
            FontSize="12"
            ItemsSource="{Binding Source={x:Static local:Logger.LogEntries}}">
            <ListView.Resources>
                <ResourceDictionary>
                    <local:LogSeverityToBrushConverter x:Key="LogSeverityToBrushConverter" />
                    <local:BoolToWidthConverter x:Key="BoolToWidthConverter" />
                </ResourceDictionary>
            </ListView.Resources>
            <ListView.View>
                <GridView>
                    <GridViewColumn Width="90" Header="Type">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                                    <controls:Badge
                                        Width="70"
                                        Background="{Binding Severity, Converter={StaticResource LogSeverityToBrushConverter}}"
                                        Text="{Binding Severity}" />
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn
                        Width="{Binding DateTimeVisible, Converter={StaticResource BoolToWidthConverter}, ConverterParameter=140}"
                        DisplayMemberBinding="{Binding Time}"
                        Header="Date/Time" />
                    <GridViewColumn
                        Width="{Binding TimeVisible, Converter={StaticResource BoolToWidthConverter}, ConverterParameter=90}"
                        DisplayMemberBinding="{Binding Time, Converter={local:LogEntryTimeOnlyConverter}}"
                        Header="Time" />
                    <GridViewColumn
                        Width="{Binding CountVisible, Converter={StaticResource BoolToWidthConverter}, ConverterParameter=50}"
                        DisplayMemberBinding="{Binding Count}"
                        Header="Count" />
                    <GridViewColumn
                        Width="{Binding IpAddressVisible, Converter={StaticResource BoolToWidthConverter}, ConverterParameter=150}"
                        DisplayMemberBinding="{Binding IpAddress}"
                        Header="IP Address" />
                    <GridViewColumn
                        Width="{Binding UsernameVisible, Converter={StaticResource BoolToWidthConverter}, ConverterParameter=100}"
                        DisplayMemberBinding="{Binding Username}"
                        Header="Username" />
                    <GridViewColumn
                        Width="800"
                        DisplayMemberBinding="{Binding Message}"
                        Header="Message" />
                </GridView>
            </ListView.View>
            <ListView.ItemContainerStyle>
                <Style BasedOn="{StaticResource {x:Type ListViewItem}}" TargetType="ListViewItem">
                    <Setter Property="ContextMenu" Value="{Binding ContextMenu, UpdateSourceTrigger=PropertyChanged}" />
                    <EventSetter Event="MouseDoubleClick" Handler="ListItem_OnMouseDoubleClick" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ContextMenu>
                <ContextMenu x:Name="LogViewerContextMenu">
                    <MenuItem
                        Command="{Binding CopyCommand}"
                        CommandParameter="{Binding Path=PlacementTarget, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ContextMenu}}"
                        Header="Copy"
                        IsEnabled="{Binding CopyEnabled}" />
                    <Separator />
                    <MenuItem
                        Command="{Binding ClearAllCommand}"
                        CommandParameter="{Binding Path=PlacementTarget, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ContextMenu}}"
                        Header="Clear All" />
                    <Separator />
                    <MenuItem
                        Command="{Binding ViewExceptionCommand}"
                        CommandParameter="{Binding Path=PlacementTarget, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ContextMenu}}"
                        Header="View Exception Details"
                        IsEnabled="{Binding Path=PlacementTarget.SelectedItem.Exception, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ContextMenu}, Converter={local:IsNotNullConverter}}" />
                </ContextMenu>
            </ListView.ContextMenu>
        </ListView>
    </Grid>
</UserControl>
