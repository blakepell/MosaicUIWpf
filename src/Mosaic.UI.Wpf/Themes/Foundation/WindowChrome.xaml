<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Mosaic.UI.Wpf.Behaviors"
    xmlns:controls="clr-namespace:Mosaic.UI.Wpf.Controls"
    xmlns:themes="clr-namespace:Mosaic.UI.Wpf.Themes">

    <!--
        A Window template whose border follows the rounded WindowChrome corners. The window's own
        BorderBrush/BorderThickness are drawn by a ClipBorder with a CornerRadius that tracks
        WindowChromeBehavior.CornerRadius, so a border set on the window rounds with the chrome instead
        of being clipped at the corners. Applied automatically by WindowChromeBehavior.RoundBorder.
    -->
    <ControlTemplate x:Key="{x:Static themes:MosaicTheme.RoundedWindowTemplate}" TargetType="{x:Type Window}">
        <!--
            A full-rectangle background fill sits behind the rounded border so the corner triangles outside the
            rounded border are painted with the window background (clipped to the rounded window shape by the chrome)
            instead of showing the opaque window as black.
        -->
        <Border Background="{TemplateBinding Background}">
            <controls:ClipBorder
                x:Name="PART_WindowBorder"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{Binding Path=(behaviors:WindowChromeBehavior.CornerRadius), RelativeSource={RelativeSource TemplatedParent}}">
                <AdornerDecorator>
                    <ContentPresenter />
                </AdornerDecorator>
            </controls:ClipBorder>
        </Border>
        <ControlTemplate.Triggers>
            <!--  When maximized the rounded corners and resize border no longer apply; square the border and inset the content so it is not pushed off-screen.  -->
            <Trigger Property="WindowState" Value="Maximized">
                <Setter TargetName="PART_WindowBorder" Property="CornerRadius" Value="0" />
                <Setter TargetName="PART_WindowBorder" Property="Padding" Value="{x:Static SystemParameters.WindowResizeBorderThickness}" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="{x:Static themes:MosaicTheme.WindowTitleBarButtonStyle}" TargetType="{x:Type Button}">
        <Setter Property="Width" Value="48" />
        <Setter Property="Height" Value="36" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource {x:Static themes:MosaicTheme.WindowForegroundBrush}}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="0">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource {x:Static themes:MosaicTheme.ControlHoverBackgroundBrush}}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="{DynamicResource {x:Static themes:MosaicTheme.ControlPressedBackgroundBrush}}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style
        x:Key="{x:Static themes:MosaicTheme.WindowTitleBarCloseButtonStyle}"
        BasedOn="{StaticResource {x:Static themes:MosaicTheme.WindowTitleBarButtonStyle}}"
        TargetType="{x:Type Button}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="0">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#E2342E" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#9A100C" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
