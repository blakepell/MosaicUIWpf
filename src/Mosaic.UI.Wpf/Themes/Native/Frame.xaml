<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:themes="clr-namespace:Mosaic.UI.Wpf.Themes">

    <!--  Mosaic themed navigation button (back / forward) used by the Frame chrome.  -->
    <Style x:Key="Frame.NavButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="OverridesDefaultStyle" Value="true" />
        <Setter Property="Focusable" Value="false" />
        <Setter Property="Width" Value="22" />
        <Setter Property="Height" Value="18" />
        <Setter Property="Foreground" Value="{DynamicResource {x:Static themes:MosaicTheme.ControlForegroundBrush}}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border
                        x:Name="border"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="1"
                        CornerRadius="3"
                        SnapsToDevicePixels="true">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="true">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource {x:Static themes:MosaicTheme.ControlHoverBackgroundBrush}}" />
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource {x:Static themes:MosaicTheme.ControlHoverBorderBrush}}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="true">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource {x:Static themes:MosaicTheme.ControlPressedBackgroundBrush}}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="false">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ControlTemplate x:Key="FrameNavChromeTemplateKey" TargetType="{x:Type Frame}">
        <Border
            Padding="{TemplateBinding Padding}"
            Background="{TemplateBinding Background}"
            BorderBrush="{TemplateBinding BorderBrush}"
            BorderThickness="{TemplateBinding BorderThickness}">
            <DockPanel>
                <Border
                    x:Name="NavChrome"
                    Height="28"
                    Background="{DynamicResource {x:Static themes:MosaicTheme.ControlBackgroundBrush}}"
                    BorderBrush="{DynamicResource {x:Static themes:MosaicTheme.ControlBorderBrush}}"
                    BorderThickness="0,0,0,1"
                    DockPanel.Dock="Top">
                    <StackPanel
                        Margin="4,0"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <Button
                            x:Name="BackButton"
                            Command="NavigationCommands.BrowseBack"
                            CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                            Style="{StaticResource Frame.NavButtonStyle}"
                            ToolTip="Back">
                            <Path
                                Width="7"
                                Height="10"
                                Data="M 6,0 L 1,5 L 6,10"
                                Stroke="{DynamicResource {x:Static themes:MosaicTheme.AccentBrush}}"
                                StrokeEndLineCap="Round"
                                StrokeStartLineCap="Round"
                                StrokeThickness="2" />
                        </Button>
                        <Button
                            x:Name="ForwardButton"
                            Margin="2,0,0,0"
                            Command="NavigationCommands.BrowseForward"
                            CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                            Style="{StaticResource Frame.NavButtonStyle}"
                            ToolTip="Forward">
                            <Path
                                Width="7"
                                Height="10"
                                Data="M 1,0 L 6,5 L 1,10"
                                Stroke="{DynamicResource {x:Static themes:MosaicTheme.AccentBrush}}"
                                StrokeEndLineCap="Round"
                                StrokeStartLineCap="Round"
                                StrokeThickness="2" />
                        </Button>
                    </StackPanel>
                </Border>
                <ContentPresenter x:Name="PART_FrameCP" />
            </DockPanel>
        </Border>
    </ControlTemplate>

    <Style x:Key="{x:Type Frame}" TargetType="{x:Type Frame}">
        <Setter Property="Foreground" Value="{DynamicResource {x:Static themes:MosaicTheme.ControlForegroundBrush}}" />
        <Setter Property="FontFamily" Value="{DynamicResource {x:Static themes:MosaicTheme.FontFamily}}" />
        <Setter Property="FontSize" Value="{DynamicResource {x:Static themes:MosaicTheme.FontSizeNormal}}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Frame}">
                    <Border
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter x:Name="PART_FrameCP" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="NavigationUIVisibility" Value="Visible">
                <Setter Property="Template" Value="{StaticResource FrameNavChromeTemplateKey}" />
            </Trigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="JournalOwnership" Value="OwnsJournal" />
                    <Condition Property="NavigationUIVisibility" Value="Automatic" />
                </MultiTrigger.Conditions>
                <Setter Property="Template" Value="{StaticResource FrameNavChromeTemplateKey}" />
            </MultiTrigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
