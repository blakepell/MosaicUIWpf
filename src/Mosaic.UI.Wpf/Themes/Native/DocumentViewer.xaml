<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Mosaic.UI.Wpf.Controls"
    xmlns:themes="clr-namespace:Mosaic.UI.Wpf.Themes"
    xmlns:ui="clr-namespace:System.Windows.Documents;assembly=PresentationUI">

    <!--
        Default DocumentViewer toolbar icons.  These are plain vector DrawingImages so the theme
        works out of the box with no extra assets.  Consumers can supply their own artwork (any
        ImageSource, e.g. a PNG) by re-defining these keys in their Application resources; because
        the buttons host a Mosaic AdaptiveImage, a supplied bitmap will also be lightness-mirrored
        for the active theme automatically.
    -->
    <DrawingImage x:Key="Mosaic.DocumentViewer.PrintIcon">
        <DrawingImage.Drawing>
            <GeometryDrawing Brush="#FF9E9E9E" Geometry="M7,3 H17 V7 H7 Z M4,7 H20 V16 H17 V12 H7 V16 H4 Z M7,14 H17 V21 H7 Z M9,16 H15 V18 H9 Z" />
        </DrawingImage.Drawing>
    </DrawingImage>
    <DrawingImage x:Key="Mosaic.DocumentViewer.CopyIcon">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="#FF9E9E9E" Geometry="M9,2 H20 V16 H9 Z" />
                <GeometryDrawing Brush="#FFFFFFFF" Geometry="M11,4 H18 V14 H11 Z" />
                <GeometryDrawing Brush="#FF9E9E9E" Geometry="M4,7 H15 V22 H4 Z" />
                <GeometryDrawing Brush="#FFFFFFFF" Geometry="M6,9 H13 V20 H6 Z" />
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>
    <DrawingImage x:Key="Mosaic.DocumentViewer.FindIcon">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Geometry="M10,10 m-6,0 a6,6 0 1,0 12,0 a6,6 0 1,0 -12,0 M14.5,14.5 L21,21">
                    <GeometryDrawing.Pen>
                        <Pen Brush="#FF9E9E9E" Thickness="2.2" StartLineCap="Round" EndLineCap="Round" />
                    </GeometryDrawing.Pen>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>
    <DrawingImage x:Key="Mosaic.DocumentViewer.ZoomInIcon">
        <DrawingImage.Drawing>
            <GeometryDrawing Brush="#FF9E9E9E" Geometry="M10,3 H13 V10 H20 V13 H13 V20 H10 V13 H3 V10 H10 Z" />
        </DrawingImage.Drawing>
    </DrawingImage>
    <DrawingImage x:Key="Mosaic.DocumentViewer.ZoomOutIcon">
        <DrawingImage.Drawing>
            <GeometryDrawing Brush="#FF9E9E9E" Geometry="M3,10 H20 V13 H3 Z" />
        </DrawingImage.Drawing>
    </DrawingImage>
    <DrawingImage x:Key="Mosaic.DocumentViewer.FitWidthIcon">
        <DrawingImage.Drawing>
            <GeometryDrawing Brush="#FF9E9E9E" Geometry="M2,12 L8,6 V9.5 H16 V6 L22,12 L16,18 V14.5 H8 V18 Z" />
        </DrawingImage.Drawing>
    </DrawingImage>
    <DrawingImage x:Key="Mosaic.DocumentViewer.WholePageIcon">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="#FF9E9E9E" Geometry="M6,2 H15 L19,6 V22 H6 Z" />
                <GeometryDrawing Brush="#FFFFFFFF" Geometry="M8,5 H13 V7 H8 Z M8,9 H17 V11 H8 Z M8,13 H17 V15 H8 Z M8,17 H17 V19 H8 Z" />
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!--  Compact, themed toolbar button used by the DocumentViewer chrome.  -->
    <Style x:Key="Mosaic.DocumentViewer.ToolBarButton" TargetType="{x:Type Button}">
        <Setter Property="OverridesDefaultStyle" Value="true" />
        <Setter Property="Focusable" Value="false" />
        <Setter Property="Padding" Value="5" />
        <Setter Property="Margin" Value="1,0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border
                        x:Name="border"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="1"
                        CornerRadius="3"
                        SnapsToDevicePixels="true">
                        <ContentPresenter
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="true">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource {x:Static themes:MosaicTheme.ControlHoverBackgroundBrush}}" />
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource {x:Static themes:MosaicTheme.ControlHoverBorderBrush}}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="true">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource {x:Static themes:MosaicTheme.ControlPressedBackgroundBrush}}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="false">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style
        x:Key="{x:Type DocumentViewer}"
        BasedOn="{x:Null}"
        TargetType="{x:Type DocumentViewer}">
        <Setter Property="Foreground" Value="{DynamicResource {x:Static themes:MosaicTheme.ControlForegroundBrush}}" />
        <Setter Property="Background" Value="{DynamicResource {x:Static themes:MosaicTheme.ControlBackgroundBrush}}" />
        <Setter Property="BorderBrush" Value="{DynamicResource {x:Static themes:MosaicTheme.ControlBorderBrush}}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontFamily" Value="{DynamicResource {x:Static themes:MosaicTheme.FontFamily}}" />
        <Setter Property="FontSize" Value="{DynamicResource {x:Static themes:MosaicTheme.FontSizeNormal}}" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="themes:DocumentViewerNativeHelper.ThemeFindToolBar" Value="True" />
        <Setter Property="ContextMenu" Value="{DynamicResource {ComponentResourceKey TypeInTargetAssembly={x:Type ui:PresentationUIStyleResources}, ResourceId=PUIDocumentViewerContextMenu}}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type DocumentViewer}">
                    <Border
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        Focusable="False">
                        <Grid Background="{TemplateBinding Background}" KeyboardNavigation.TabNavigation="Local">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!--  Mosaic themed toolbar (replaces the PresentationUI toolbar)  -->
                            <Border
                                Grid.Row="0"
                                Background="{DynamicResource {x:Static themes:MosaicTheme.ControlBackgroundBrush}}"
                                BorderBrush="{DynamicResource {x:Static themes:MosaicTheme.ControlBorderBrush}}"
                                BorderThickness="0,0,0,1"
                                KeyboardNavigation.TabNavigation="Local">
                                <StackPanel
                                    Margin="4,3"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                                    <Button
                                        Style="{StaticResource Mosaic.DocumentViewer.ToolBarButton}"
                                        Command="ApplicationCommands.Print"
                                        CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                        ToolTip="Print">
                                        <controls:AdaptiveImage
                                            Width="16"
                                            Height="16"
                                            Source="{DynamicResource Mosaic.DocumentViewer.PrintIcon}" />
                                    </Button>
                                    <Button
                                        Style="{StaticResource Mosaic.DocumentViewer.ToolBarButton}"
                                        Command="ApplicationCommands.Copy"
                                        CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                        ToolTip="Copy">
                                        <controls:AdaptiveImage
                                            Width="16"
                                            Height="16"
                                            Source="{DynamicResource Mosaic.DocumentViewer.CopyIcon}" />
                                    </Button>
                                    <Button
                                        Style="{StaticResource Mosaic.DocumentViewer.ToolBarButton}"
                                        Command="ApplicationCommands.Find"
                                        CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                        ToolTip="Find">
                                        <controls:AdaptiveImage
                                            Width="16"
                                            Height="16"
                                            Source="{DynamicResource Mosaic.DocumentViewer.FindIcon}" />
                                    </Button>

                                    <Border
                                        Width="1"
                                        Margin="4,2"
                                        Background="{DynamicResource {x:Static themes:MosaicTheme.ControlSeparatorBrush}}" />

                                    <Button
                                        Style="{StaticResource Mosaic.DocumentViewer.ToolBarButton}"
                                        Command="NavigationCommands.DecreaseZoom"
                                        CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                        ToolTip="Zoom out">
                                        <controls:AdaptiveImage
                                            Width="16"
                                            Height="16"
                                            Source="{DynamicResource Mosaic.DocumentViewer.ZoomOutIcon}" />
                                    </Button>
                                    <TextBlock
                                        MinWidth="40"
                                        VerticalAlignment="Center"
                                        Foreground="{DynamicResource {x:Static themes:MosaicTheme.ControlForegroundBrush}}"
                                        Text="{Binding Zoom, RelativeSource={RelativeSource TemplatedParent}, StringFormat={}{0:0}%}"
                                        TextAlignment="Center" />
                                    <Button
                                        Style="{StaticResource Mosaic.DocumentViewer.ToolBarButton}"
                                        Command="NavigationCommands.IncreaseZoom"
                                        CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                        ToolTip="Zoom in">
                                        <controls:AdaptiveImage
                                            Width="16"
                                            Height="16"
                                            Source="{DynamicResource Mosaic.DocumentViewer.ZoomInIcon}" />
                                    </Button>

                                    <Border
                                        Width="1"
                                        Margin="4,2"
                                        Background="{DynamicResource {x:Static themes:MosaicTheme.ControlSeparatorBrush}}" />

                                    <Button
                                        Style="{StaticResource Mosaic.DocumentViewer.ToolBarButton}"
                                        Command="{x:Static DocumentViewer.FitToWidthCommand}"
                                        CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                        ToolTip="Fit width">
                                        <controls:AdaptiveImage
                                            Width="16"
                                            Height="16"
                                            Source="{DynamicResource Mosaic.DocumentViewer.FitWidthIcon}" />
                                    </Button>
                                    <Button
                                        Style="{StaticResource Mosaic.DocumentViewer.ToolBarButton}"
                                        Command="{x:Static DocumentViewer.FitToMaxPagesAcrossCommand}"
                                        CommandParameter="1"
                                        CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                        ToolTip="Whole page">
                                        <controls:AdaptiveImage
                                            Width="16"
                                            Height="16"
                                            Source="{DynamicResource Mosaic.DocumentViewer.WholePageIcon}" />
                                    </Button>
                                </StackPanel>
                            </Border>

                            <ScrollViewer
                                x:Name="PART_ContentHost"
                                Grid.Row="1"
                                Grid.Column="0"
                                CanContentScroll="true"
                                Focusable="{TemplateBinding Focusable}"
                                HorizontalScrollBarVisibility="Auto"
                                IsTabStop="true"
                                TabIndex="1" />
                            <DockPanel Grid.Row="1">
                                <FrameworkElement Width="{DynamicResource {x:Static SystemParameters.VerticalScrollBarWidthKey}}" DockPanel.Dock="Right" />
                                <Rectangle
                                    Height="10"
                                    VerticalAlignment="top"
                                    Visibility="Visible">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientBrush.GradientStops>
                                                <GradientStopCollection>
                                                    <GradientStop Offset="0" Color="#66000000" />
                                                    <GradientStop Offset="1" Color="Transparent" />
                                                </GradientStopCollection>
                                            </GradientBrush.GradientStops>
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>
                            </DockPanel>
                            <ContentControl
                                x:Name="PART_FindToolBarHost"
                                Grid.Row="2"
                                Grid.Column="0"
                                Background="{DynamicResource {x:Static themes:MosaicTheme.ControlBackgroundBrush}}"
                                Focusable="{TemplateBinding Focusable}"
                                TabIndex="2" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
