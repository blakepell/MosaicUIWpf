<Window
    x:Class="MosaicTextEditor.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ad="https://github.com/blakepell/MosaicUIWpf"
    xmlns:mosaic="http://schemas.apexgate.net/wpf/mosaic-ui"
    xmlns:theme="http://schemas.apexgate.net/wpf/mosaic-ui"
    x:Name="RootWindow"
    Title="MosaicTextEditor"
    Width="1200"
    Height="760"
    MinWidth="900"
    MinHeight="560"
    theme:WindowChromeBehavior.CaptionHeight="0"
    theme:WindowChromeBehavior.CornerRadius="10"
    theme:WindowChromeBehavior.GlassFrameThickness="0"
    theme:WindowChromeBehavior.IsEnabled="True"
    theme:WindowChromeBehavior.ResizeBorderThickness="5"
    theme:WindowChromeBehavior.RoundBorder="True"
    theme:WindowChromeBehavior.UseAeroCaptionButtons="True"
    Background="{DynamicResource {x:Static theme:MosaicTheme.WindowBackgroundBrush}}"
    BorderBrush="{DynamicResource {x:Static theme:MosaicTheme.AccentBrush}}"
    BorderThickness="0"
    Foreground="{DynamicResource {x:Static theme:MosaicTheme.WindowForegroundBrush}}"
    Icon="/Assets/collage-48.png"
    Closing="MainWindow_OnClosing"
    Loaded="MainWindow_OnLoaded"
    WindowStartupLocation="CenterScreen">

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding NewFileCommand}" />
        <KeyBinding Key="O" Modifiers="Control" Command="{Binding OpenFileCommand}" />
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveCommand}" />
        <KeyBinding Key="S" Modifiers="Control+Shift" Command="{Binding SaveAsCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="35" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <mosaic:WindowTitleBar Grid.Row="0" IconSource="/Assets/collage-48.png">
            <mosaic:WindowTitleBar.RightContent>
                <Button
                    Width="48"
                    Click="ButtonToggleTheme_OnClick"
                    Style="{DynamicResource {x:Static theme:MosaicTheme.WindowTitleBarButtonStyle}}"
                    ToolTip="Toggle Theme">
                    <Button.ContentTemplate>
                        <DataTemplate>
                            <Viewbox Width="16" Height="16">
                                <Canvas Width="512" Height="512">
                                    <Path Data="M8 256c0 137 111 248 248 248s248-111 248-248S393 8 256 8 8 119 8 256zm248 184V72c101.7 0 184 82.3 184 184 0 101.7-82.3 184-184 184z" Fill="{DynamicResource {x:Static theme:MosaicTheme.WindowForegroundBrush}}" />
                                </Canvas>
                            </Viewbox>
                        </DataTemplate>
                    </Button.ContentTemplate>
                </Button>
            </mosaic:WindowTitleBar.RightContent>
        </mosaic:WindowTitleBar>

        <Menu Grid.Row="1" Padding="2" Background="{DynamicResource {x:Static theme:MosaicTheme.WindowBackgroundBrush}}">
            <MenuItem Header="_File">
                <MenuItem Header="_New File" Command="{Binding NewFileCommand}" InputGestureText="Ctrl+N" />
                <MenuItem Header="New _Markdown File" Command="{Binding NewMarkdownFileCommand}" />
                <Separator />
                <MenuItem Header="_Open File..." Command="{Binding OpenFileCommand}" InputGestureText="Ctrl+O" />
                <MenuItem Header="Open _Folder..." Command="{Binding OpenFolderCommand}" />
                <Separator />
                <MenuItem Header="_Save" Command="{Binding SaveCommand}" InputGestureText="Ctrl+S" />
                <MenuItem Header="Save _As..." Command="{Binding SaveAsCommand}" InputGestureText="Ctrl+Shift+S" />
                <Separator />
                <MenuItem Header="Recent _Files" ItemsSource="{Binding RecentFiles}">
                    <MenuItem.ItemContainerStyle>
                        <Style TargetType="{x:Type MenuItem}">
                            <Setter Property="Header" Value="{Binding}" />
                            <Setter Property="Command" Value="{Binding DataContext.OpenRecentFileCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" />
                            <Setter Property="CommandParameter" Value="{Binding}" />
                        </Style>
                    </MenuItem.ItemContainerStyle>
                </MenuItem>
                <MenuItem Header="Recent F_olders" ItemsSource="{Binding RecentFolders}">
                    <MenuItem.ItemContainerStyle>
                        <Style TargetType="{x:Type MenuItem}">
                            <Setter Property="Header" Value="{Binding}" />
                            <Setter Property="Command" Value="{Binding DataContext.OpenRecentFolderCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" />
                            <Setter Property="CommandParameter" Value="{Binding}" />
                        </Style>
                    </MenuItem.ItemContainerStyle>
                </MenuItem>
                <Separator />
                <MenuItem Header="E_xit" Command="{Binding ExitCommand}" />
            </MenuItem>

            <MenuItem Header="_Edit">
                <MenuItem Header="Cu_t" Command="Cut" InputGestureText="Ctrl+X" />
                <MenuItem Header="_Copy" Command="Copy" InputGestureText="Ctrl+C" />
                <MenuItem Header="_Paste" Command="Paste" InputGestureText="Ctrl+V" />
                <MenuItem Header="_Delete" Command="Delete" InputGestureText="Del" />
                <Separator />
                <MenuItem Header="Select _All" Command="SelectAll" InputGestureText="Ctrl+A" />
            </MenuItem>

            <MenuItem Header="_View">
                <MenuItem Header="View _File Explorer" Command="{Binding ViewFileExplorerCommand}" />
                <MenuItem Header="View _Properties" Command="{Binding ViewPropertiesCommand}" />
                <MenuItem Header="View _Output" Command="{Binding ViewOutputCommand}" />
                <Separator />
                <MenuItem Header="_Theme">
                    <MenuItem
                        x:Name="ThemeLightMenuItem"
                        Header="_Light"
                        IsCheckable="True"
                        Click="ThemeLightMenuItem_OnClick" />
                    <MenuItem
                        x:Name="ThemeDarkMenuItem"
                        Header="_Dark"
                        IsCheckable="True"
                        Click="ThemeDarkMenuItem_OnClick" />
                    <MenuItem
                        x:Name="ThemeBlueMenuItem"
                        Header="_Blue"
                        IsCheckable="True"
                        Click="ThemeBlueMenuItem_OnClick" />
                </MenuItem>
            </MenuItem>
        </Menu>

        <ad:DockingManager
            x:Name="DockingManager"
            Grid.Row="2"
            ActiveContentChanged="DockingManager_OnActiveContentChanged"
            AnchorableClosed="DockingManager_OnAnchorableClosed"
            DocumentClosing="DockingManager_OnDocumentClosing"
            DocumentClosed="DockingManager_OnDocumentClosed">
            <ad:DockingManager.Theme>
                <ad:MosaicTheme />
            </ad:DockingManager.Theme>

            <ad:LayoutRoot>
                <ad:LayoutPanel Orientation="Vertical">
                    <ad:LayoutPanel Orientation="Horizontal">
                        <ad:LayoutAnchorablePane DockMinWidth="220" DockWidth="300">
                            <ad:LayoutAnchorable
                                x:Name="FilesAnchorable"
                                Title="File Explorer"
                                CanClose="True"
                                ContentId="files">
                                <mosaic:Files
                                    Background="{DynamicResource {x:Static theme:MosaicTheme.WindowBackgroundBrush}}"
                                    DirectoryPath="{Binding CurrentFolder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    EnableFileWatcher="True"
                                    FileActivatedCommand="{Binding OpenActivatedFileCommand}"
                                    Filter="*"
                                    ShowFolders="True" />
                            </ad:LayoutAnchorable>
                        </ad:LayoutAnchorablePane>

                        <ad:LayoutDocumentPaneGroup>
                            <ad:LayoutDocumentPane x:Name="DocumentPane" />
                        </ad:LayoutDocumentPaneGroup>

                        <ad:LayoutAnchorablePane DockMinWidth="220" DockWidth="280">
                            <ad:LayoutAnchorable
                                x:Name="PropertiesAnchorable"
                                Title="Properties"
                                CanClose="True"
                                ContentId="properties">
                                <Grid Margin="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock FontWeight="SemiBold" Text="Name" />
                                    <TextBlock Grid.Column="1" Margin="12,0,0,0" Text="{Binding ActiveDocument.FileName, TargetNullValue=-}" TextTrimming="CharacterEllipsis" />

                                    <TextBlock Grid.Row="1" Margin="0,8,0,0" FontWeight="SemiBold" Text="Path" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Margin="12,8,0,0" Text="{Binding ActiveDocument.FilePath, TargetNullValue=(unsaved)}" TextTrimming="CharacterEllipsis" />

                                    <TextBlock Grid.Row="2" Margin="0,8,0,0" FontWeight="SemiBold" Text="Type" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Margin="12,8,0,0" Text="{Binding ActiveDocument.Kind, TargetNullValue=-}" />

                                    <TextBlock Grid.Row="3" Margin="0,8,0,0" FontWeight="SemiBold" Text="Modified" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Margin="12,8,0,0" Text="{Binding ActiveDocument.IsModified, TargetNullValue=False}" />
                                </Grid>
                            </ad:LayoutAnchorable>
                        </ad:LayoutAnchorablePane>
                    </ad:LayoutPanel>

                    <ad:LayoutAnchorablePane DockHeight="150" DockMinHeight="100">
                        <ad:LayoutAnchorable
                            x:Name="OutputAnchorable"
                            Title="Output"
                            CanClose="True"
                            ContentId="output">
                            <TextBox
                                Margin="0"
                                Padding="8"
                                BorderThickness="0"
                                IsReadOnly="True"
                                Text="{Binding StatusText}"
                                TextWrapping="Wrap" />
                        </ad:LayoutAnchorable>
                    </ad:LayoutAnchorablePane>
                </ad:LayoutPanel>
            </ad:LayoutRoot>
        </ad:DockingManager>
    </Grid>
</Window>
